<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> kopparakecaripaṉ
<lb n="2" break="no"/>maṟku yāṇṭu <hi rend="grantha"><unclear>6</unclear></hi><g ref="sym:dash" type="punctuation"/>Āvatu miṟaik
<lb n="3" break="no"/>kūṟṟattut tevatāna<supplied reason="omitted">m</supplied> tiruppaḻanat
<lb n="4" break="no"/>tu ma<hi rend="grantha">hāde</hi>vaṟku Āvūrkkūnṟattukka
<lb n="5" break="no"/>rukāvūr kiḻavaṉ marutampaṭṭaṉāna co
<lb n="6" break="no"/>ḻa veḷār cevakaṉ nampan kaṇṭan Ira
<lb n="7" break="no"/>vum pakalum cantirātittaval Oru non
<lb n="8" break="no"/>tāviḷakku Eriya vaitta poṉ <num value="25">2 <g type="numeral">10</g> 5</num><unclear>ka</unclear>
<lb n="9" break="no"/>ḻañcu Ivaṉ Ivviḷak keriya vaitta ni
<lb n="10" break="no"/>laiviḷakku Oṉṟu Ippoṉ koṇṭu
<lb n="11"/>viḷak kerippomāṉom vai<unclear>ku</unclear>ntaṉ tā
<lb n="12" break="no"/>motiran <hi rend="grantha">śrī</hi>taranum Ittaḷi naṭṭavaṉ mo
<lb n="13" break="no"/>ṭaṉāticcanum Ittaḷit tevanār makaṉ
<lb n="14"/>nakkaṉ matamāḷiyum Immuvom Iv
<lb n="15" break="no"/>viḷakku muṭṭil Ivvūr Eṅkaḷ nilamup
<lb n="16" break="no"/>pattaṟu veliyile talaicāṉmāṭāka vai
<lb n="17" break="no"/>ttom Ivvaṉaivom Itu paṉmā<hi rend="grantha">he</hi>
<lb n="18" break="no"/><hi rend="grantha">śvararakṣai</hi> <g ref="sym:doubleBar" type="punctuation">.</g><g ref="sym:dash-long" type="punctuation">.</g> 
