<lb n="2"/> <gap reason="lost" quantity="5" unit="character"/> gāvuṇḍugeydu sukhadiniralpatikāra
<lb n="3"/> <gap reason="lost" quantity="5" unit="character"/> yamarasaṁ dayeyi <g ref="sym:doubleBar" type="punctuation">.</g> Enage talego
<lb n="4" break="no"/> <gap reason="lost" quantity="5" unit="character"/> mmarasaṁ manamosederaḍuṁ kēriya mane
<lb n="5" break="no"/> <gap reason="lost" quantity="1" unit="character"/> ttavagrahadoḷ talegoṭṭanudagrabaḷaṁ basava
<lb n="6" break="no"/> <gap reason="lost" quantity="2" unit="character"/> grahadiṁdaṁ samastapariha<supplied reason="omitted">ra</supplied> mārca<unclear>ṁ</unclear>dratāramaṁtāgittu
<lb n="7"/> <gap reason="lost" quantity="2" unit="character"/> gadu piriduṁ puṇyamartthadāpēkṣateyiṁdidanaḷidavaṁ 
<lb n="8"/> <gap reason="lost" quantity="5" unit="character"/> ṟidu naḍege naḍevavarella <g ref="sym:doubleBar" type="punctuation">.</g> svadatta paradatta vā yōha
