<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>svasti samastā Ābhyudaya śa 
<lb n="2" break="no"/>ta varuṣaṁbulu 1322 A 
<lb n="3" break="no"/>gunēṁṭi vikrama saṁvatsara mā 
<lb n="4" break="no"/>gha su 10 sō harihara<unclear>rā</unclear> 
<lb n="5" break="no"/>yaṁḍu prithivirājyamu 
<lb n="6"/>nēyucuṁḍaṁgānu cē<unclear>ma</unclear> 
<lb n="7" break="no"/>kurti Annamanāyaniṁgā 
<lb n="8" break="no"/>ru kuṇuṁdōṟu <unclear>grā</unclear>maṁ 
<lb n="9" break="no"/>bunu doḍḍamalnātadē 
<lb n="10" break="no"/>vara dēvaḷa mavasarānaku 
<lb n="11"/>kuṇuṁdoṟiti nāgulaceṟu 
<lb n="12" break="no"/>vu<unclear>mōci</unclear> Addaṁki teruvu da 
<lb n="13" break="no"/>kṣiṇāna gaṭṭu lōgaḍa daṁ 
<lb n="14" break="no"/>ḍavrittipāṭiki cēnu ma 
<lb n="15" break="no"/>lināthu tyāgavarttanakugā 
<lb n="16" break="no"/>nu krayabhujyaṁgānu 
<lb n="17"/>bhaktajanula cēta peṭṭi 
<lb n="18"/>gonipiṁce Ācaṁdrārkastā 
<lb n="19" break="no"/>yi Avunaṭigānu dē 
<lb n="20" break="no"/>varaku sarvva<unclear>mā</unclear>niyaṁ 
<lb n="21" break="no"/>gānu <g ref="sym:bar" type="punctuation">.</g> svadattā dviguṇaṁ 
<lb n="22"/>puṇyaṁ paradattānu 
<lb n="23" break="no"/>pālanaṁ <g ref="sym:bar" type="punctuation">.</g> varadattā 
<lb n="24" break="no"/>pahārēṇa svadattaṁ ni 
<lb n="25" break="no"/>ṣphalaṁ bhavēt <g ref="sym:bar" type="punctuation">.</g> svada 
<lb n="26" break="no"/>ttaṁ parada ttaṁ vā yō 
<lb n="27"/>harēti vasuṁdharā <g ref="sym:bar" type="punctuation">.</g> ṣa 
<lb n="28" break="no"/>ṣṭirvaruṣa sahasrāṇi 
<lb n="29"/>viṣṭāyāṁ jāyatē krimiḥ <g ref="sym:bar" type="punctuation">.</g> 
</p>

