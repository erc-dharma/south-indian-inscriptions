<!--<h4>Fragment I</h4>-->

<p>
<lb n="1"/>—cakecaripaṟmarāṉa tiripuvaṉaccakkaravattikaḷ <hi rend="grantha">śrī</hi>
<lb n="2"/>—cantiyātipam I<supplied reason="omitted">ṭu</supplied>vāṉākavum
<lb n="3" break="no"/>—nāyaṉār nacciṉāṟkiṉiyārṟku cantiyātipam Iṭuvā
<lb n="4"/>—can=ti Oṉṟuṅ kuṭutteṉ pūmaṉ Araiyaṉeṉ tevaṉ
</p>

<!--<h4>Fragment II</h4>-->

<p>
<lb n="1"/>—rapāṇṭiya tevaṟku yā<unclear>ṇṭu</unclear>
<lb n="2" break="no"/>—yār tirukkāmakkoṭṭa nācciyāṟku tirup
<lb n="3" break="no"/>—ḷur nāyiṉār nacciṉāṟkiṉiyār tirukkā<unclear>makko</unclear>
<lb n="4" break="no"/>—kavum Amutupaṭi tiruviḷakku maṟṟum Ivaṉe
</p>

<!--<h4>Fragment III</h4>-->

<p>
<lb n="1" break="no"/>—mutu tāṅka
<lb n="2" break="no"/>—nāṭṭārum ta
<lb n="3" break="no"/>—yāṇṭu <num value="11"><g type="numeral">10</g> 1</num><g ref="sym:dash" type="punctuation"/>vatu
</p>

