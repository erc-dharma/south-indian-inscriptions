<lb n="2"/>catācivatevama<hi rend="grantha">hā</hi>rāyar <hi rend="grantha">prithi</hi>vi<hi rend="grantha">rājyam</hi> paṇṇi Aruḷāniṉṟa <hi rend="grantha">śakābdam <num value="148"><g type="numeral">100</g> 4 <g type="numeral">10</g> 8</num>[*]9</hi>
