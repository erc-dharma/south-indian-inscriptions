<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> sā</hi>[ <hi rend="grantha">rvabhū</hi> ma] cak<hi rend="grantha">kra</hi> vattikaḷ <hi rend="grantha">śrī</hi>
<lb n="2" break="no"/><hi rend="grantha">bho ja</hi>ḷa virarāmanā<hi rend="grantha">thade</hi> varkku yā 
<lb n="3" break="no"/>ṇṭu pataṉmuṉṟāvatu kaṉṉināyaṟṟu
<lb n="4"/><hi rend="grantha">pūrva</hi> pa<hi rend="grantha">kṣa</hi>ttu <hi rend="grantha">Ekādaśi</hi> yum putaṉ
<lb n="5" break="no"/>kiḻamaiyum peṟṟa Uttirāṭa
<lb n="6" break="no"/>ttu nāḷ vaṭakarai Irā[<hi rend="grantha">ja</hi>*]r[ā<hi rend="grantha">ja</hi>*]vaḷa
<lb n="7" break="no"/>ṉāṭṭu poykaiṉāṭṭu Uṭai
<lb n="8" break="no"/>yār tirumaḻapāṭiuṭaiyār koyilukku
<lb n="9"/>nāyaṉār niṉaippiṭṭaruḷiṉa cāmutāya kaṇakku
<lb n="10"/>kāṇiyuṭaiya neṟkuppaiyuṭaiyāṉ paṭṭāla
<lb n="11" break="no"/>kaṉ tirumaḻapāṭiyuṭaiyāṉ tiru<supplied reason="omitted">c</supplied>ciṟṟampalamuṭai
<lb n="12" break="no"/>yāṉ vaiyicciyanāta muventaveḷāṉ pakkal Aṭ<unclear>ai</unclear>
<lb n="13" break="no"/>ytta kuṭiyāṉa coḻakulacuntaracatu<hi rend="grantha">rvedi</hi> maṅ<unclear>ka</unclear>
<lb n="14" break="no"/>lattu tirumayattu tirucciṟṟampalamuṭaiyāṉ Āṇṭā
<lb n="15" break="no"/>ṉ paṭṭaṉ vilaikoṇṭu tirunāmattukkāṇiyāka
<lb n="16"/>viṭṭa Iṉṉāyaṉār tevatāṉam poṉṉā<supplied reason="omitted">r</supplied>meṉivi
<lb n="17" break="no"/>ḷākattu kaṇṭarātittavitikku kiḻakku kulamāṇik
<lb n="18" break="no"/>kavāykkālukku va<unclear>ṭa</unclear>kku Ai<unclear>ñcā</unclear>ṅ kaṇṇāṟṟu Iraṇ
<lb n="19" break="no"/>ṭām catirattu kulottuṅkacoḻamaṅkala Ūrpaṭi
<lb n="20" break="no"/>nilam kāṇi muntirikaik kiḻaraiye Irumā varaiyil Iṟai
<lb n="21"/>mikutikku niccayittu viṭṭa nilam Araikkāṇiyuṅ
<lb n="22"/>koṇṭu kāveri Āṟṟil niṉṟum nāḷ Oṉṟukku Orukuṭa
<lb n="23"/>tirumañcaṉam ca<hi rend="grantha">ndrāditya</hi> vaṟc celvatāka viṭṭamaikku
<lb n="24"/>Ivai tirumayattu Āṇṭāṉpaṭṭa ṉeḻuttu <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
</p>

