<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> [<g ref="sym:bar" type="punctuation">.</g><g ref="sym:bar" type="punctuation">.</g><g ref="sym:bar" type="punctuation">.</g>*] tiripuvaṉaccakkaravarttikaḷ koṉerimelkoṇṭaruḷiya
<lb n="2"/>ma<unclear>h</unclear>ā<hi rend="grantha">rājādhi</hi> rāca narapati <hi rend="grantha">śrī</hi>irācentiracoḻatevaṟku yāṇṭu <num value="31">3 <g type="numeral">10</g> 1</num> Āvatu
<lb n="3"/>Etirāmāṇṭu <hi rend="grantha">vra</hi> cci<supplied reason="omitted">ka</supplied>nāyaṟṟu Aparapa<hi rend="grantha">kṣa</hi>ttu pañcamiyum putaṉkiḻamaiyum
<lb n="4"/><unclear>p</unclear>eṟṟa <unclear>Āyi</unclear>leyattu nāḷ Irā<supplied reason="omitted">ca</supplied>rā<supplied reason="omitted">ca</supplied>vaḷanāṭṭu poykaināṭṭu Uṭaiyār tiru
<lb n="5" break="no"/>maḻa<unclear>pā</unclear>ṭi Uṭaiyār koyilil Ātica<hi rend="grantha">ṇḍeśva ra</hi> tevar Aruḷāl kaṉmikaḷuk<supplied reason="omitted">ku</supplied>
<lb n="6"/>Iṉ<unclear>ṉāya</unclear>nār koyil tirunantāviḷakku kuṭimakkaḷil toṇṭappāṭi Uṭai<unclear>yā</unclear>
<lb n="7" break="no"/>ṉ makaṉ ta <gap reason="lost" quantity="2" unit="character"/> raṉum celvakoṉ makaṉ Allāḷaṉum cempiyatarai<unclear>ya</unclear>koṉ makaṉ peramaṉum
<lb n="8"/>Emapperkkoṉ vayiravaṉum Ivāṭṭai kāttikaimā<hi rend="grantha">sa</hi>ttu <hi rend="grantha">śrī</hi>paṇṭārattu nāṅka
<lb n="9"/>ḷ kai<supplied reason="omitted">k</supplied>koṇṭa cevvāṭu toṇṇūṟum kai<supplied reason="omitted">k</supplied>koṇṭamaiyil Itukku Upaiyamāka
<lb n="10"/>mācam Oṉṟukku nāṅkaḷ Aḷappatāṉa cempiyaṉmāteviyāl Aḷakkum ney nā
<lb n="11" break="no"/>ṉāḻiyum muṉṉiṉṟār cantirātittavarai Eṅkaḷ kuṭiyilārum <unclear>Aḷa</unclear>p<unclear>pa</unclear>tāka kai<supplied reason="omitted">k</supplied>ko
<lb n="12" break="no"/><unclear>ṇṭa</unclear>maikku <g ref="sym:tam-pillaiyarCuli" type="punctuation"> <gap reason="lost" quantity="1" unit="character"/> </g>
<lb n="13"/>Āṉi<unclear>mātam</unclear> mutal kuṟukkaiyuṭaiyāṉ tiruvaiyāṟuṭaiyāṉ paṇṭārattu kaikkoṇ
<lb n="14" break="no"/>ṭa <unclear>cevvā</unclear>ṭu Irupattaiñcum takar Oṉṟum kaikkoṇṭu mātam Oṉṟukku cempiyaṉmātevi
<lb n="15" break="no"/>yāle nāṉā <gap reason="lost" quantity="5" unit="character"/> kkakaṭavatāṉamaikku [*<g ref="sym:doubleBar" type="punctuation">.</g>]
