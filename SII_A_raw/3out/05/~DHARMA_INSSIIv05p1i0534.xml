<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> korā<hi rend="grantha">ja</hi>ke<hi rend="grantha">sa</hi>riva<hi rend="grantha">rmma</hi> ṟkku yāṇṭu <num value="17"><g type="numeral">10</g> 7</num> Āvatu tiruvai<note n="217-1">Built in at the right end.</note> <gap reason="lost" quantity="3" unit="character"/> 
<lb n="2"/><hi rend="grantha">hāde</hi> varkku Ārkkāṭṭukkūṟṟattu kiḻpi <gap reason="lost" quantity="1" unit="character"/> pil parivaṇṭattuṟai <gap reason="lost" quantity="3" unit="character"/> 
<lb n="3"/>ḻāṉ mārava ṉakkaṉum māravaṅ kaṇṭaṉum <hi rend="grantha">candrādi</hi>tta val nicati nāḻi ne <gap reason="lost" quantity="3" unit="character"/> 
<lb n="4"/>rivatāka vaitta nantāviḷakku Iraṇṭu Ivviraṇṭu nantāviḷakkiṉukku <gap reason="lost" quantity="3" unit="character"/> 
<lb n="5"/>nāṭṭuk kiḻpilāṟṟut tiruvaiyāṟṟut tevatāṉam Antaṉūr Ūrārriṭai <gap reason="lost" quantity="4" unit="character"/> 
<lb n="6"/>mārava ṉakkaṉum māravaṅ kaṇṭaṉum maṇalūrntu mayakkiṉa nilattukkuk kiḻa<unclear>p</unclear> <gap reason="lost" quantity="4" unit="character"/> 
<lb n="7"/>Eṭṭumācce<unclear>yp</unclear>paṭum Orumāvarai<unclear>kkum</unclear> Oṭaiyiṟpaṭum Iraṇṭumāvukku mekkum te <gap reason="lost" quantity="2" unit="character"/> 
<lb n="8"/>lai karuṅkuḻicceykku vaṭakkum melpāṟ kellai ciṟukkāṟceyppaṭum nāṟṟu <gap reason="lost" quantity="3" unit="character"/> 
<lb n="9"/>m ciṟukkāṟ ceykkuk kiḻakkum vaṭapāṟ kellai muṅkiṟce<supplied reason="omitted">y</supplied>ppaṭum Araikkā <gap reason="lost" quantity="3" unit="character"/> 
<lb n="10"/>ṭaiyiṟppaṭum mūṉṟumāvukku <gap reason="lost" quantity="2" unit="character"/> ku teṟkum Iv<unclear>vic</unclear>aitta peru <gap reason="lost" quantity="3" unit="character"/> 
<lb n="11"/>laiyil Akappa<supplied reason="omitted">ṭ</supplied>ṭa nilamuḻu(ḻu)tu Aṭṭuvatāṉa ney n<unclear>ā</unclear>ḻi Itu paṉ <gap reason="lost" quantity="2" unit="character"/> 
<lb n="12"/><hi rend="grantha">śvara ratṣai—</hi>
</p>

