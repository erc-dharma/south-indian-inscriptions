<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> koṟcaṭapaṉmarāṉa <hi rend="grantha">tribhu</hi> vanaccakkaravattikaḷ <hi rend="grantha">śrī</hi>
<lb n="2"/>cuntarapāṇṭiyatevaṟku yāṇṭu patinmuṉṟāvatu <hi rend="grantha">siṁ ha</hi>nāyaṟṟu
<lb n="3"/>Aparapa<hi rend="grantha">kṣa</hi>ttu <hi rend="grantha">tri</hi>ti yaiyum veḷḷikkiḻamaiyum peṟṟa Uttiraṭ
<lb n="4" break="no"/>ṭāti nāḷ Uṭaiyār tiruvoṟṟiyūruṭaiyanāyaṉāṟku puḻaṟkoṭṭattu
<lb n="5"/>nā<supplied reason="omitted">ṭ</supplied>ṭavarom niccayittapaṭi tiruvoṟṟiyūr vaṭakarai tenkaraiyil
<lb n="6"/>poṉvari vakuppāl Uḷḷa māṭai nāṭṭu tanmamāṉa <hi rend="grantha">vyākhyā</hi> ṉa maṇ 
<lb n="7" break="no"/>ṭapattukkum maṟṟum Uḷḷa tiruppaṇikaḷukkum Uṭalāka Iṟai yiḻicci
<lb n="8"/>kuṭuttu Ivvūṟku varum māṭai nāṭṭile Eṟiṭṭukoṇṭu Iṟukkakka
<lb n="9" break="no"/>ṭavomākavum Ippaṭikku ca<hi rend="grantha">ntrādi</hi> ttavarai celvatāka niccayi
<lb n="10" break="no"/>ttom puḻaṟkoṭṭattu nāṭṭav(ā)r<unclear>o</unclear>m Ippaṭikkup paṇiyālc citti
<lb n="11" break="no"/>rameḻiveḷāṉ Eḻuttu Ittanmam vilaṅka niṉaintavar <hi rend="grantha">ga</hi> ṅkaiyil <hi rend="grantha">bho</hi> vati<hi rend="grantha">tya</hi> vaṉ <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
</p>

