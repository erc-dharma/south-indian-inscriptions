<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>Ōm <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> śrīvallabhasya vibudhādhipavallabhasya
<lb n="2"/>nārāyaṇasya jagadēkaparāyaṇasya <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> nābhya
<lb n="3" break="no"/>ṁbujādudabhavadbhagavānviriṁcastatpā 
<lb n="4" break="no"/>datōjani caturtthajanānvavāyaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 1*] Asmi
<lb n="5" break="no"/>nbabhrāja rājadrajanikarakarakṣīranīhāra
<lb n="6" break="no"/>hāraśvētōdgītōrukīrttistribhuvanavinutā
<lb n="7" break="no"/>gaṇyasādguṇyapuṇyaḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> śrīmānbhīmābhidhā
<lb n="8" break="no"/>nō nṛpatiratimahān dhārmmikānāmudagrasta
<lb n="9" break="no"/>sya śrībiṁbamāṁbā suriciracaritādharmma
<lb n="10" break="no"/><unclear>pa</unclear>tnī babhūva [<g ref="sym:doubleBar" type="punctuation">.</g> 2*] gaṁḍakṣitipatistābhyā
<lb n="11" break="no"/>mībhyassabhyābhibhāṣaṇaḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> sudhīssama
<lb n="12" break="no"/><unclear>bha</unclear>vadrājadrājadharmmavicakṣaṇaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 3*] śacī
<lb n="13" break="no"/>va śakrasya sarasvatīva svayaṁbhuva<supplied reason="omitted">ḥ</supplied> śrī
<lb n="14" break="no"/>riva śārjñapāṇēḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> śivēva sarvvasya mahiṣya
<lb n="15" break="no"/>muṣya śrīviṁjamāṁbā nitarāṁ vyarājat [<g ref="sym:doubleBar" type="punctuation">.</g> 4*]
<lb n="16"/><unclear>ta</unclear> drakṣātprajānāmiva divasapatirddē<note n="297-1">The continuation on the next face is built in.</note>
</p>

