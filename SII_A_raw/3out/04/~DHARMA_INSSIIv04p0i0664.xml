<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śrīmatyaṁdramahītalēsti nagara
<lb n="2" break="no"/>ṁ tēnāṁjanāsūnunā dattaṁ vānarasai
<lb n="3" break="no"/>jñita<unclear>ṁ</unclear> prakaṭitaṁ kammadvijēbhyaściraṁ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> tē
<lb n="4" break="no"/>ṣāmanvayakalpabhūruhavanē nānā
<lb n="5" break="no"/>dhvaraśrībhṛtāṁ pōtaḥ pūtacaritra
<lb n="6" break="no"/>sūtramatimān jātō rarāja
<lb n="7"/>kṣitau [<g ref="sym:doubleBar" type="punctuation">.</g> 1*] tatpōtanākhyayajamānava
<lb n="8" break="no"/>rasya putrādvēṁgīcalukyajanapālasa
<lb n="9" break="no"/>bhāgragaṇyāddoḍḍābhidhānayajamā
<lb n="10" break="no"/>navarēṇyadhanyātsūryyōjani svajana
<lb n="11" break="no"/>vārijaṣaṇḍasūryyaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 2*] sūryyana
<lb n="12" break="no"/>ṁdanavadānyatatparānmaṁtrisūryya
<lb n="13" break="no"/>ma<unclear>hi</unclear>tōjani kṣitau <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> nirmalaprabalakī
<lb n="14" break="no"/>rttivittama<supplied reason="omitted">ḥ</supplied> śrīdharō bahukalāka
<lb n="15" break="no"/><unclear>lā</unclear>dharaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 3*] tasya śrīdharanāyakasya vani
<lb n="16" break="no"/>tā sūrāṁbikā suvratā daṁppatyōsta
<lb n="17" break="no"/><supplied reason="omitted">na</supplied>yastayō<unclear>ḥ</unclear> śubhakarassāhityavidyā<unclear>dha</unclear>raḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied>
<lb n="18"/>kaṁṭa<unclear>ḥ</unclear> śrīvelanāṁṭigoṁkanṛpatiṁ rā<unclear>jē</unclear>
<lb n="19" break="no"/>ṁdracōḍātmajaṁ bhaktyārādhya mahāniyō
<lb n="20" break="no"/>gavadavīṁ prāpya sthiraṁ vartta(r)tē [<g ref="sym:doubleBar" type="punctuation">.</g> 4*] vyōma
<lb n="21" break="no"/>rttukhēṁdupramitē śakābdē nā
<lb n="22" break="no"/>diṁḍlamūlasthamṛḍāya dīpaṁ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> prā
<lb n="23" break="no"/>dātsa kaṁṭa<supplied reason="omitted">ḥ</supplied> stutanīlakaṁṭṭhaḥ dīptyā<unclear>ṁ</unclear>
<lb n="24" break="no"/>citājāṇḍamakhaṇḍavartti [<g ref="sym:doubleBar" type="punctuation">.</g> 5*] svasti <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied>
<lb n="25"/>śrīśakavarṣaṁbulu 1060 gunēṁṭi
<lb n="26"/>phālguṇa śuddha pāḍiva śukravārāmunā
<lb n="27" break="no"/>ṁḍu gaṁ<unclear>ṭṭi</unclear>yaveggaḍa śrīmūlasthānamahā
<lb n="28" break="no"/>dēvaraku nakhaṇḍavarttidīpamuna kicci
<lb n="29" break="no"/><unclear>na go</unclear>ṟiyalu 55 <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> vīniṁ jēkoni prōlebō
<lb n="30" break="no"/> <gap reason="lost" quantity="3" unit="character"/> koḍuku kāpana Ācaṁdrārkamu
<lb n="31"/> <gap reason="lost" quantity="5" unit="character"/> nupautrikamu nitya māneṁḍu ne
<lb n="32" break="no"/> <gap reason="lost" quantity="5" unit="character"/> <unclear>ya</unclear>kuṁ bōyaṁgalavāṁḍu <g ref="sym:doubleBar" type="punctuation">.</g>
<lb n="33"/> <gap reason="lost" quantity="5" unit="character"/> <unclear>rā</unclear>jula <unclear>mā</unclear>diseḍlunuṁ goṁḍa
<lb n="34" break="no"/> <gap reason="lost" quantity="2" unit="character"/> maṭi maṁḍḍaṁḍḍunu samasta
<lb n="35" break="no"/> <gap reason="lost" quantity="5" unit="character"/> ṁggaḍlakommayaku<note n="202-2">The bottom of the pillar</note> 
