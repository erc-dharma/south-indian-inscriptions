<p>
<lb n="1"/><hi rend="grantha">svastiśrī</hi> kOpparakecaripa<hi rend="grantha">nma</hi>rāṉa
<lb n="2"/><hi rend="grantha">śrī</hi>rā<hi rend="grantha">jēntra</hi>cōḻa <hi rend="grantha">de</hi>vaṟku
<lb n="3"/>yāṇṭu 3 pāṇṭi ku
<lb n="4" break="no"/>lācaṉi vaḷanāṭṭu viḷānāṭṭu <hi rend="grantha">bra</hi>
<lb n="5" break="no"/><hi rend="grantha">hmade</hi>yam <hi rend="grantha">śrīkaṇṭha ca</hi>tu<hi rend="grantha">rvvedi</hi> maṅkalattu
<lb n="6"/>yāḷuṅkaṇattāruḷ <hi rend="grantha">dve</hi>taikōmapu
<lb n="7" break="no"/>ṟattu mā<hi rend="grantha">dha</hi>va<hi rend="grantha"> kra</hi>mavittaṉ makaṉ
<lb n="8"/><hi rend="grantha">do</hi>ṇaya<hi rend="grantha"> kra</hi>mavittaṉ tiruveṟum
<lb n="9" break="no"/>[pī<hi rend="grantha">śvara</hi>muṭaiya <hi rend="grantha">mahāde</hi>varkku <hi rend="grantha">sa</hi>]
<lb n="10"/><hi rend="grantha">ndhi<unclear>3</unclear></hi>m Eriya vaitta <hi rend="grantha">sandhi</hi>vi<hi rend="grantha"/>
<lb n="11" break="no"/>ḷakku 1 Oṉṟum Erikka vaitta
<lb n="12"/>kācu 8 Ikkācu Eṭṭum koṇṭu
<lb n="13"/>Ivai yaṟṟil palikoṇṭu <hi rend="grantha">candrā</hi>
<lb n="14" break="no"/><hi rend="grantha">di</hi>tta val ErippatāṉO<hi rend="grantha">m</hi>
<lb n="15"/>[<hi rend="grantha">śrī</hi>]<hi rend="grantha">śrī</hi>kōyiluṭaiyōm
<lb n="16"/><unclear>Itu</unclear> pa<hi rend="grantha">nmāheśvara rakṣaiḥ—</hi> 
