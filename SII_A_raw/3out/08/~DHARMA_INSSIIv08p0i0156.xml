<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> śrīma</hi> nu<hi rend="grantha">ma hāmaṇḍaliśvaran harirā</hi>yavi<hi rend="grantha">bhā</hi>ṭa<hi rend="grantha">n bhāṣai</hi> kku tappuvarāyarakaṇṭaṉ muvarāyar
<lb n="2" break="no"/>kaṇṭaṉ <hi rend="grantha">pūrvvadakṣi</hi>ṇa<hi rend="grantha">paścimasamudrādipa</hi> ti <hi rend="grantha">śrī</hi>ariyappauṭaiyār kumārar <hi rend="grantha">śrī</hi>vīraviruppaṇṇauṭaiyar
<lb n="3"/><hi rend="grantha">prithi</hi>vi<hi rend="grantha">rājyam</hi> paṇṇiyaruḷāniṉṟa <hi rend="grantha">śakābdam <num value="1310"><g type="numeral">1000</g> 3 <g type="numeral">100</g> <g type="numeral">10</g></num></hi>- <unclear>ṉ</unclear>mel cellāniṉṟa vi<hi rend="grantha">bha</hi>va<hi rend="grantha">samvatsara</hi> ttu <hi rend="grantha">mithu</hi>na nāyaṟṟu
<lb n="4"/><hi rend="grantha">Aparapakṣa</hi> ttu <hi rend="grantha">dvi</hi> tīyaiyum tiṅkaḷkiḻamaiyum peṟṟa tiruv<unclear>o</unclear>ṇattu nāḷ Uṭaiyār tiruvaṇṇāmalaiuṭaiya nāyinār koyil
<lb n="5"/>tāṉattāṟku kal veṭṭikkuṭuttapaṭi <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> taṅkaḷ koyilukkum teva<unclear>ma</unclear>ṇṭalattukkum nam <hi rend="grantha">pradhā</hi>ni kaḷ kai(v)vilaiyāka paṇam pokaṭṭuk
<lb n="6" break="no"/>koḷḷum Erutu kiṭā koṇikai virimuṭṭu Arici kāṇam Eṇṇai ney pākku miḷaku Iruppukkaṭṭiṉ kuvaṭṭu paccaivaṭam maṟṟum kiṟaiya
<lb n="7" break="no"/>māka koḷḷum mutalkaḷum Ūḻiyamākak koḷḷum Eṭuttaḷavu vikuti kāppaṭiyum veṭṭi vīṭāram nimantam taccu Āḷamañci
<lb n="8"/>Uluppaiyāka koḷḷum mutalum maṟṟum Eppeṟpaṭṭa pala Ūḻiyaṅkaḷum ko<supplied reason="omitted">ḷ</supplied>ḷātapaṭi vi<hi rend="grantha">bha</hi> vavaru<hi rend="grantha">ṣa</hi>m Āṭimāta
<lb n="9"/>mutalukkuk kaḻittu <hi rend="grantha">sarvvamānnya</hi> Iṟaiyiliyāka <hi rend="grantha">camndrāditya</hi> varaiyum cella kal veṭṭikkuṭuttom <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> Itukku virotam
<lb n="10"/>paṇṇuvāṉ <hi rend="grantha">geṅkai</hi> k karaiyil kurālpacuk koṉṟāṉ pāvaṅ koḷvāṉ <g ref="sym:tam-pillaiyarCuli" type="punctuation"> <gap reason="lost" quantity="1" unit="character"/> </g> Itu paṉ<hi rend="grantha">mā heśvara rakṣaiḥ <g ref="sym:tam-pillaiyarCuli" type="punctuation"> <gap reason="lost" quantity="1" unit="character"/> </g></hi>
</p>

