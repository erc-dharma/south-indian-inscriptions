<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> cakalapuvaṉa<supplied reason="omitted">c</supplied>cakkaravattikaḷ <hi rend="grantha">śrī</hi>kopperuñciṅkatevarkku yā
<lb n="2" break="no"/>ṇṭu 2- ṭāvatu centamaṅkalattu Uṭaiyār vāṇilaikaṇṭīcuramuṭaiya nāya
<lb n="3" break="no"/>ṉārkku <hi rend="grantha">ja</hi>nanā<hi rend="grantha">tha</hi> ccatu<hi rend="grantha">rvvedi</hi> maṅkalattuk kāṇiuṭaiya colaikkoṉ makaṉ Aruḷāḷa
<lb n="4" break="no"/>ṉ Āṉa tiyākaviṉotaṉeṉ Iṉṉāyanārkkut tirununtāviḷakku Oṉṟukku Ivāṇṭaip pu
<lb n="5" break="no"/>raṭṭātimātattu viṭṭa pacu muppattiraṇṭum <hi rend="grantha">ṛṣabha</hi> m Oṉṟum kaikkoṇṭu tiru
<lb n="6" break="no"/>nuntāviḷakku Atikaināyakaṉnāḻiyāle nāḷ Oṉṟukku Uḻakku ney tirumaṭai
<lb n="7" break="no"/>ppaḷḷiyile civappirāmaṇarvacame Aḷakkakkaṭavom <hi rend="grantha">cantra(r)ādi</hi> ttavarai Amā
<lb n="8" break="no"/>ci poṉṉanum Āḷkoṇṭāṉum paṭiyaṉum naṅkaikko ṉuḷ<unclear>ḷi</unclear>ṭṭāro
