<p>
<lb n="1"/> <gap reason="lost" quantity="10" unit="character"/> māṇamenitu <gap reason="lost" quantity="5" unit="character"/> 
<lb n="2"/> <gap reason="lost" quantity="10" unit="character"/> ḷayaṁ mattavondinituṁ <gap reason="lost" quantity="3" unit="character"/> 
<lb n="3"/> <gap reason="lost" quantity="10" unit="character"/> mattaru nālku <g ref="sym:doubleBar" type="punctuation">.</g> kisuvo<unclear>ḷala</unclear> <gap reason="lost" quantity="1" unit="character"/> 
<lb n="4"/> <gap reason="lost" quantity="10" unit="character"/> pūrvvadi naḍeva mattarūriṁ baḍagalu <gap reason="lost" quantity="3" unit="character"/> 
<lb n="5"/> <gap reason="lost" quantity="10" unit="character"/> suvarapēkṣisade naḍeyisidavargge kurukṣētra <gap reason="lost" quantity="2" unit="character"/> 
<lb n="6"/> <gap reason="lost" quantity="10" unit="character"/> re kavileyaṁ kōḍuṁ koḷagumaṁ ponnoḷu paṁcaratna doḷu kaṭṭisi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="7"/> <gap reason="lost" quantity="3" unit="character"/> bhayamukhigoṭṭa phaḷamakkumidanupēkṣisi kiḍisidavargganitu tīrtthaṁgaḷoḷu <gap reason="lost" quantity="10" unit="character"/> 
<lb n="8"/> <gap reason="lost" quantity="2" unit="character"/> brāhmaṇaruṁ sāsirvvarttapōdhanarumanaḷida pātakamakkuṁ <g ref="sym:doubleBar" type="punctuation">.</g> sāmānyōyaṁ dharmma <gap reason="lost" quantity="10" unit="character"/> 
<lb n="9"/>vadbhiḥ sarvvānētānbhāvinaḥ pārtthivēṁdrān bhūyō bhūyō yācatē rāma bhedraḥ <g ref="sym:doubleBar" type="punctuation">.</g> svadattāṁ para <gap reason="lost" quantity="10" unit="character"/> 
<lb n="10"/>rāṁ ṣaṣṭirvvarṣasahasrāṇi viṣṭāyāṁ jāyatē krimi <g ref="sym:doubleBar" type="punctuation">.</g> na viśaṁ viśamityāhurddē vasvaṁ viśamucyatē viśamē <gap reason="lost" quantity="10" unit="character"/> 
<lb n="11"/>kaṁ <g ref="sym:doubleBar" type="punctuation">.</g> bahubhirvvasudhā bhuktā rājabhiḥ sagarādibhiḥ yasya yasya yadā bhūmistasya tasya tadā <gap reason="lost" quantity="10" unit="character"/> 
<lb n="12"/>yarugratapadhiṁdaṁ śrīladiṁ pōlisalke mātā paṟarārumillenisidācāyyaṁrge śiṣyaṁge <gap reason="lost" quantity="10" unit="character"/> 
<lb n="13"/>yuktaneṁbī mātiṁ salisaṁdaniṁtamritarāśijīyarī dhātriyoḷu <g ref="sym:bar" type="punctuation">.</g> brataniyamastaṁ vi <gap reason="lost" quantity="10" unit="character"/> 
