<p>
<lb n="1"/><hi rend="grantha">svastiśrī raṅganāthasya pādapaṅka<unclear>ja</unclear></hi><note n="8-1">The first six lines appear to be a palimpsest.</note>
<lb n="2" break="no"/><hi rend="grantha">[rēṇavaḥ <g ref="sym:bar" type="punctuation">.</g>?] puṣṇantu va<unclear>stri</unclear>lōkasya <gap reason="lost" quantity="2" unit="character"/> </hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ka</seg>
<lb n="3" break="no"/><hi rend="grantha">lyāṇa kāraṇam <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> brahmaśrēṇiśikhāma</hi>
<lb n="4" break="no"/><hi rend="grantha">ṇirgguṇanidhi śśrī sōmadēvō ha</hi>
<lb n="5" break="no"/><hi rend="grantha">rēḥ bhṛtyō nityamakalpayat</hi>
<lb n="6"/><hi rend="grantha"> <gap reason="lost" quantity="3" unit="character"/> rērēkandvijārādhanam <g ref="sym:bar" type="punctuation">.</g> śrīraṅgē</hi>
<lb n="7"/><hi rend="grantha">paramōttamāgravidhinā kalyā</hi>
<lb n="8" break="no"/><hi rend="grantha"><unclear>ṇa</unclear>śīlaḥ satāmmānyō vājasanē</hi>
<lb n="9" break="no"/><hi rend="grantha">yavēda viduṣāmādyaḥ parārtthōdayaḥ <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi>
<lb n="10"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">k<unclear>orā</unclear>jake</seg><hi rend="grantha">sari</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vaṉmaṟku yāṇṭu</seg> <hi rend="grantha"><unclear>4</unclear></hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">āvatu</seg>
<lb n="11"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tiruvaraṅkattup perumāṉaṭika ḷuttamā</seg>
<lb n="12"/><hi rend="grantha">gra</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttil</seg> <hi rend="grantha">vēda</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">m vallāṉoru</seg> <hi rend="grantha">brā</hi>
<lb n="13" break="no"/><hi rend="grantha">hma</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṇaṉ Uṇpataṟku tirumarukalnā</seg>
<lb n="14" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular"><unclear>ṭ</unclear>ṭu kaṇṇamaṅkalattu pāppaṉa</seg>
<lb n="15" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">cceri</seg> <hi rend="grantha">sōmadēvabha</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṭṭaṉ</seg> <hi rend="grantha">vai</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tta p<unclear>o</unclear></seg>
<lb n="16" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular"><unclear>ṉ</unclear></seg> <hi rend="grantha">60�</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">Āṟupatiṉ kaḻañcu I</seg>
<lb n="17" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">taṉ palicaiyāl Irupatiṉ <unclear>n</unclear>āḻi Uḻa</seg>
<lb n="18" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kku nellinā<supplied reason="omitted">l</supplied></seg> <hi rend="grantha">candrāditya</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vaṟ Ūṭṭuvip</seg>
<lb n="19" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">pomāṉom</seg> <hi rend="grantha">śrīraṅga</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttu</seg> <hi rend="grantha">ssabhai</hi>
<lb n="20" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">yo mitu</seg> <hi rend="grantha">śrīvaiṣṇavarirakṣai <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi>
</p>

