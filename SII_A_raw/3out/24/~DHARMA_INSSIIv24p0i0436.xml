<p>
<lb n="1"/><hi rend="grantha">śubhamastu <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> svastiśrī narasimhākhyakṣmāsamkandananādinē</hi><note n="421-1">Read <hi rend="grantha">kṣmāsaṅkrandananandanē</hi></note> <hi rend="grantha"><g ref="sym:bar" type="punctuation">.</g> śrīmatyadvyutarāyē śrīkṛṣṇarāyā</hi><note n="421-2"><hi rend="italic">Dirgha</hi> sign is engraved below the line.</note> <hi rend="grantha">nujēvati <g ref="sym:bar" type="punctuation">.</g> <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> pakṣivandyē śakasyābdē viḷambinakrag<unclear>ē</unclear></hi>
<lb n="2"/><hi rend="grantha">ragē</hi><note n="421-3">Read <hi rend="grantha">ravau</hi></note> <hi rend="grantha">Arkkasaumyadinē pauṣṇē kṛṣṇāyām pañcamītithau <g ref="sym:bar" type="punctuation">.</g> <supplied reason="omitted">2</supplied> raṅgēśa<supplied reason="omitted">ya</supplied> syanavamauka</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tti</seg> <hi rend="grantha">kañcukam śrīdēvyāśca ratnamaukuṭam</hi><note n="421-4">Read <hi rend="grantha">makuṭam</hi></note> <hi rend="grantha">saha tēnaramyam ramyōpayantrapadayōḥ kavacam suratnam kṛptañca raṅgayananaḥ</hi><note n="421-5">Read <hi rend="grantha">śayinaḥ</hi></note> <hi rend="grantha">kavacañca haimam <g ref="sym:bar" type="punctuation">.</g> <supplied reason="omitted">3</supplied></hi>
<lb n="3"/><hi rend="grantha">dharmmēttarājjagati cambakarāmabhūpāllakṣmipatērapi ca sāḷuvatimmabhūpāt <g ref="sym:bar" type="punctuation">.</g> Ānītamātma<unclear>dha</unclear>nataśca kṛtam ya Ētat prādādahōbalapatiḥ</hi>
<lb n="4"/><hi rend="grantha">prathitaḥ ssamastam <g ref="sym:bar" type="punctuation">.</g> <supplied reason="omitted">4</supplied> bhrā</hi><note n="421-2"><hi rend="italic">Dirgha</hi> sign is engraved below the line.</note> <hi rend="grantha">tā</hi><note n="421-2"><hi rend="italic">Dirgha</hi> sign is engraved below the line.</note> <hi rend="grantha">tasya mahīsuparvanivahagrāmapradasyānujaḥ</hi><note n="421-6">The <hi rend="italic">visarga</hi> is redundant.</note> <hi rend="grantha">ścakrādhīśvarapādapaṅkajaratiḥ śrīrāma candrāhvayaḥ <g ref="sym:bar" type="punctuation">.</g> tasyaivānudinam gu</hi>
<lb n="5" break="no"/><hi rend="grantha">ḷānnavidhayē śrīraṅganārāyaṇāt</hi><note n="421-7"><hi rend="grantha">t</hi> is redundant.</note> <hi rend="grantha">l</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">la</seg><hi rend="grantha">bdham saṅgamaval</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">li</seg><hi rend="grantha">kāsthitamadāt kṣētradvayam yōginaḥ <g ref="sym:bar" type="punctuation">.</g> <supplied reason="omitted">5</supplied></hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">Itil <unclear>viṭṭavaṉ</unclear> viḻukkāṭu Irunāḻiyu</seg><hi rend="grantha">m rāmaca<supplied reason="omitted">ndra</supplied>n santāna paramparai</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">peṟavum <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></seg> 
</p>

