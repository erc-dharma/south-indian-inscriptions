<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi> tiripuvaṉaccakkaravattikaḷ <hi rend="grantha">śrī</hi> I<hi rend="grantha">rājarājade</hi>vaṟku yāṇṭu <num value="32">3 <g type="numeral">10</g> 2</num>— Āvatu tulānāyaṟṟu <hi rend="grantha">Aparapa</hi>
<lb n="2" break="no"/><hi rend="grantha">kṣa</hi>ttu <hi rend="grantha">saptami</hi>yum tiṅkaḷkiḻamaiyum peṟṟa pūcattu nāḷ Aḻakiyamaṇavāḷap peru māḷukkuc cāttiya
<lb n="3" break="no"/>ruḷa <hi rend="grantha">de</hi>var vi<hi rend="grantha">rasomiśvara de</hi>var <hi rend="grantha">de</hi>vimāril tikkāṉai nācciyār piḷḷai<unclear>kaḷil</unclear> kāma <hi rend="grantha">de</hi>vaṟku naṉṟāka tirup
<lb n="4" break="no"/>pati <hi rend="grantha">śrī</hi>vaiṣṇavarkaḷil tiruveḷḷaṟai varantarum perumāḷ <hi rend="grantha">dāsa</hi>r nittappaṭiyile nāḷ Oṉṟukku Oru tirumā
<lb n="5" break="no"/>lai Eṭuttuc cātti Aruḷappaṇṇakkaṭavarākavum <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> Itukku <hi rend="grantha">Ubh</hi>aiyamāka Ivarkaḷukku kuṭutta varā<hi rend="grantha">ha</hi>
