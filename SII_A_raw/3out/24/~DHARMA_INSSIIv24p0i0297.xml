<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrīḥ <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> mānaślāghyē śakasyābdē yātē māsē</hi>
<lb n="2" break="no"/><hi rend="grantha">(mā) tha kārttikē <g ref="sym:bar" type="punctuation">.</g> kṛttikāprāptapūrṇēndau bhaumavā</hi>
<lb n="3" break="no"/><hi rend="grantha">rē śivānvitē <g ref="sym:bar" type="punctuation">.</g> prākāravāmanāgārakāvērīpaṅkajāgṛ</hi>
<lb n="4" break="no"/><hi rend="grantha">haiḥ <g ref="sym:bar" type="punctuation">.</g> Uttarādi caturddiśyaiḥ pradakṣi ṇyēna samvṛ</hi>
<lb n="5" break="no"/><hi rend="grantha">tāmḥ maddhyōdyānabhavam kṛtvā mālārtthaīgaśāyinē <g ref="sym:bar" type="punctuation">.</g></hi>
<lb n="6"/><hi rend="grantha">virūp<choice><sic>a</sic><corr>ā</corr></choice>kṣa kṣamēśasya mantrī muddharasō dadau <g ref="sym:doubleBar" type="punctuation">.</g></hi>
</p>

