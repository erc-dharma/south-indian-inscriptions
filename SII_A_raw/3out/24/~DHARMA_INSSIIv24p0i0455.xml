<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">śubhamastu <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> śrīmahāviṣṇavē namaḥ <g ref="sym:bar" type="punctuation">.</g> candravamśasamutpannapinnarājasutasyabhi</hi><note n="437-1">Read <hi rend="grantha">hi •</hi></note> <hi rend="grantha"><g ref="sym:bar" type="punctuation">.</g> Ā</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṟa</seg><hi rend="grantha">vīṭibbu</hi><note n="437-2">Read <hi rend="grantha">āraviṭbukkarājasya •</hi></note> <hi rend="grantha">ka<supplied reason="omitted">r</supplied>ājasya tanayō rāmabhūpatiḥ <g ref="sym:bar" type="punctuation">.</g> tasya putrāstrayō jāt<choice><sic>a</sic><corr>ā</corr></choice>ḥ dharmmakāmārthasannibh[*āḥ] timmarājaḥ kōṇḍarājō raṅgarāja Iti śrutāḥ <g ref="sym:bar" type="punctuation">.</g></hi>
<lb n="2"/><hi rend="grantha">timmarājasya tanayā bahavō dharmmavatsalāḥ <g ref="sym:bar" type="punctuation">.</g> gōp<choice><sic>a</sic><corr>ā</corr></choice>mbāsūnavastatra catvārō lōkarakṣakāḥ <g ref="sym:bar" type="punctuation">.</g> nalatimmmahīpālaḥ śrīviṣṭhaḷamahīpatiḥ <g ref="sym:bar" type="punctuation">.</g> tritīyaścinnatimēmaśaśca<unclear>turtha</unclear>ḥ pāpatimmapaḥ <g ref="sym:bar" type="punctuation">.</g> kōṇḍarājasya tanayāḥ kōnēṭya<unclear>y</unclear>ādaya śca<unclear>ṣka</unclear>m</hi><note n="437-3">Read <hi rend="grantha">kōnēṭyādica</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tu</seg><hi rend="grantha">ṣṭayam |</hi></note><g ref="sym:bar" type="punctuation">.</g>
<lb n="3"/><hi rend="grantha">raṅgarājasya tanayā strayō vikramaśālinaḥ <g ref="sym:bar" type="punctuation">.</g> rāmarājastimmarājō vēṅkaṭādrimahīpatiḥ <g ref="sym:bar" type="punctuation">.</g> tēṣāntu timmarājasya tanayō viṣṭhalēśvaraḥ <g ref="sym:bar" type="punctuation">.</g> pratāpi cinnatimmēna <unclear>sa</unclear>hitassahajanmanā <g ref="sym:bar" type="punctuation">.</g> vidyānagaryyāt Ārabhya rājyamādakṣiṇāmbudhi <g ref="sym:bar" type="punctuation">.</g> kṛtvā</hi>
<lb n="4"/><hi rend="grantha">niṣkaṇṭakam sarvamānyandēvadvijanmanām <g ref="sym:bar" type="punctuation">.</g> tataḥ śrīraṅganāthasya svarṇa puṣpa sahasra<unclear>taḥ</unclear> sahasranāmapūjāntu prativāramakārayat <g ref="sym:bar" type="punctuation">.</g> vārē vārē ca śukrasya karppūrādyanulēpanam <g ref="sym:bar" type="punctuation">.</g> svārāmapuṣpamālyēna pratyaham kēśa</hi>
<lb n="5" break="no"/><hi rend="grantha">vārccanam <g ref="sym:bar" type="punctuation">.</g> nivēdanārttham harayē grāmān prādāt sapuṣkalān <g ref="sym:bar" type="punctuation">.</g> taj<unclear>jyē</unclear>ṣṭō nalatimmēśō raṅgēśasyōtsavēṣu ca <g ref="sym:bar" type="punctuation">.</g> candraprabhākhya <gap reason="lost" quantity="1" unit="character"/> nam tu rājatanniravarttayat <g ref="sym:bar" type="punctuation">.</g> tēṣātmā</hi><note n="437-4">Read <hi rend="grantha">mmā</hi></note> <hi rend="grantha">nyaḥ kṛṣṇapurasthitāhōbala dīkṣitaḥ <g ref="sym:bar" type="punctuation">.</g></hi>
<lb n="6"/><hi rend="grantha">sūryyaprabhākhyam sauvarṇṇam śrīraṅgēśamudē<supplied reason="omitted">ma</supplied>rppayat <g ref="sym:bar" type="punctuation">.</g> tatō jitvā ripūn sarvvān pāṇḍyādīnāśrītānapi <g ref="sym:bar" type="punctuation">.</g> sthāpayitvā samudrasya tīrē viṣṭhaḷabhūpatiḥ <g ref="sym:bar" type="punctuation">.</g> Anantaśayanē kanyākumāryyām rāmasētukē <g ref="sym:bar" type="punctuation">.</g> Āsthāpaya</hi>
<lb n="7" break="no"/><hi rend="grantha">jjyayastambhān Ācandrārkkamacañcalam <g ref="sym:bar" type="punctuation">.</g> Ē<unclear>ta</unclear>ddharmmasya yē drōha ścintayanti narādhamāḥ <g ref="sym:bar" type="punctuation">.</g> kumbhīpākē nimagna syurākalpam putrapau<unclear>tra</unclear>kaiḥ <g ref="sym:bar" type="punctuation">.</g> yē <gap reason="lost" quantity="1" unit="character"/> dharmmam pālayantīmantēbhyō dēvō dayānidhiḥ <g ref="sym:bar" type="punctuation">.</g> maṅgalāni sadā</hi>
<lb n="8" break="no"/><hi rend="grantha">dadyānmaṅgalāyatanam hariḥ <g ref="sym:bar" type="punctuation">.</g></hi>
</p>

