<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrī vijayābhyudaya śālivāhana śa</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ka</seg><hi rend="grantha">varṣambulu 1675 Agunēṇṭi vijayanāma</hi>
<lb n="2"/><hi rend="grantha">samvatsara Āśvija śuddha daśami śu</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">k</seg><hi rend="grantha">ra</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vāra</seg><hi rend="grantha">m śravaṇanakṣatramamdu tirupuguṭi vijayarāghava</hi>
<lb n="3"/><hi rend="grantha">svāmi mahōtsavardhaṅgānu vaiśya</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ku</seg><hi rend="grantha">ladhali śēṭṭi gōtrōdbhava tiruvidhi mutyālu śēṭṭi pautra</hi>
<lb n="4" break="no"/><hi rend="grantha">bāluśēṭṭi putra vēm</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kaṭa</seg><hi rend="grantha">pati śēṭṭi</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">k</seg><hi rend="grantha">aim</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ka</seg><hi rend="grantha">ryam</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ka</seg><hi rend="grantha">lyāṇamamṇṭapamumnnu tiru</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ka</seg><hi rend="grantha">ḷamumnnu catramam</hi>
<lb n="5"/><hi rend="grantha">nu nirmāṇam cēśi samarppimci nāṭhaḍu śvōkam <g ref="sym:doubleBar" type="punctuation">.</g> svamśajāḥ madhvam dhvam</hi>
<lb n="6"/><hi rend="grantha">śajāha bhumipāssata tamurjvala dharmacittāḥ <g ref="sym:bar" type="punctuation">.</g> madhdharma mēkhasa</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttam</seg> <hi rend="grantha">paripā</hi>
<lb n="7"/><hi rend="grantha">layam</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">titatā</seg><hi rend="grantha">ḍu</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kā</seg><hi rend="grantha">dvaya mahamśi rasāvahām kōṭa vēṅ</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kaṭarā</seg><hi rend="grantha">ghavuḍu sadāśēva <g ref="sym:bar" type="punctuation">.</g></hi> 
</p>

