<lb n="1"/><hi rend="grantha">svastiśrī tribhu<supplied reason="omitted">va</supplied>naśca</hi>k<hi rend="grantha">ra</hi>vat
<lb n="2"/>tikaḷ <hi rend="grantha">śrī</hi> kulacekara <hi rend="grantha">de</hi>vaṟ<unclear>ku</unclear>
<lb n="3"/>Oṉpatāvatiṉ ṉetirām
<lb n="4"/>Āṇṭu coḻapāṇṭiya vaḷaṉā
