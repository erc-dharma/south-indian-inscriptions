<lb n="1"/><hi rend="grantha">svastiśrī śa</hi>kānta <hi rend="grantha">1<unclear>4</unclear>4<unclear>7</unclear></hi> mel c<unclear>e</unclear>
<lb n="2"/>llā niṉṟa pāttipa varu<hi rend="grantha">ṣa</hi>m māci mātam 7
<lb n="3"/>puṟamalai nāṭṭu tirukkoḻakuṭi Āṇ
<lb n="4"/>ṭa nāyiṉār koyil <hi rend="grantha">śrī</hi> paṇṭāra kā
