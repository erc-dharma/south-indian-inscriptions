<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tū</seg><hi rend="grantha">ḷabhupānāsnavya <gap reason="lost" quantity="3" unit="character"/> </hi>
<lb n="2"/><hi rend="grantha">hējala<unclear>m</unclear>mahati yasya jagatprathitēnrapapdhavara cōḷana<unclear>rā</unclear>dhipa ma <gap reason="lost" quantity="3" unit="character"/> </hi>
<lb n="3"/><hi rend="grantha">gracimanum<unclear>pa</unclear>ḷa nāṭitiviśru tējanapadēsti</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">naṭā</seg><hi rend="grantha">ritisatpuri <g ref="sym:doubleBar" type="punctuation">.</g><g ref="sym:dash-long" type="punctuation">.</g> yasyāmalā <gap reason="lost" quantity="3" unit="character"/> </hi>
<lb n="4"/><hi rend="grantha">pitā mahēna vitrā ca śāstētyandapanya nāmā śrīcēmpiyananumpaḷa nāṭṭu mū</hi>
<lb n="5" break="no"/><hi rend="grantha">vēntavēḷāniti nāma dubrē <g ref="sym:doubleBar" type="punctuation">.</g><g ref="sym:dash-long" type="punctuation">.</g> <unclear>ya</unclear>syapitrapyōmumuṭi cōḷōm paḷanāṭṭu mū<unclear>vēnta</unclear></hi>
<lb n="6" break="no"/><hi rend="grantha">vēḷāniti ca sadākhyōmala bhatajananāthā dēvanrapātaḥ <g ref="sym:doubleBar" type="punctuation">.</g><g ref="sym:dash-long" type="punctuation">.</g></hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">rājarāja</seg> <hi rend="grantha">ppriyaḥ śrima</hi>
<lb n="7" break="no"/><hi rend="grantha">dēkkāndētiṭu ṅatiśrutaḥ vīraḥ parātta<unclear>m</unclear> ppallavarayō bhunyada grajaḥ <g ref="sym:doubleBar" type="punctuation">.</g><g ref="sym:dash-long" type="punctuation">.</g> tējasyattā mati</hi>
<lb n="8" break="no"/><hi rend="grantha">pamasakrutsanmārgga san</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tū</seg><hi rend="grantha">ritām lōkānāmupakāra hētyu muddiyanaṣṭāyama</hi>
<lb n="9"/><hi rend="grantha">naraḥādityamsasamastabhupa makuṭavyālinthapādadvayahyāsan mumuṭi cōḷadē</hi>
<lb n="10"/><hi rend="grantha">tēḥ sāmantamukhaḥ sva <gap reason="lost" quantity="3" unit="character"/> la vdhōparāntaka ppallavaḥ yāmōmasā va bhu<unclear>ta</unclear></hi>
<lb n="11"/><hi rend="grantha"> <gap reason="lost" quantity="11" unit="character"/> </hi>
</p>

