<p>
<lb n="1"/><hi rend="grantha">svastiśrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> tribhva</hi><note n="4-1">Read <hi rend="grantha">tribhu</hi>va<hi rend="grantha">º</hi></note>ṉaccakkaravattikaḷ <hi rend="grantha">śrī</hi>kulottuṅkacoḻate
<lb n="2" break="no"/>varkku yāṇṭu <num value="18"><g type="numeral">10</g> 8</num><g ref="sym:dash" type="punctuation"/>vatu puṟamalaināṭṭu poṉṉamarāpati tirukk<unclear>o</unclear>
<lb n="3" break="no"/>ṭuṅkuṉṟamuṭaiyāṉ Aḻakiyatevaṉāṉa ni<hi rend="grantha">ṣadharāja</hi>ṉeṉ Irācentiracoḷi<hi rend="grantha">śara</hi>muṭai
<lb n="4" break="no"/>ya nāyanār tirumaṭaiviḷākattil nilaimaiaḻakiyān tirumaṭattukku maṭappuṟamākak kuṭu
<lb n="5" break="no"/>tta kuṭikkāṭu Aḻakiyanāyakappiḷḷaiyār tirumalaikku melaikkaṇṇuṭaipperu
<lb n="6" break="no"/>māḷukkup peru<unclear>nā</unclear>ṉkellai nālellaikkun tiruccūlakkallum nāṭṭi(k) Ikkoyi
<lb n="7" break="no"/>lum maṭamum paricarikkum Āṇṭā<supplied reason="omitted">r</supplied>kku Immaṭattiliṭṭār paricilar pūcikkum Āṇ
<lb n="8" break="no"/>ṭārka<unclear>ḷu</unclear>m Amutu ceyvutāka cantirāttapakaṟ celvatāka niruvārttuk kal
<lb n="9" break="no"/>veṭṭik kuṭutteṉ tirukkoṭuṅkuṉṟamuṭaiyāṉ Aḻakiya tevaṉāṉa
<lb n="10"/>ni<hi rend="grantha">ṣa</hi>tarā<hi rend="grantha">ja</hi>ṉe<supplied reason="omitted">ṉ</supplied> vira <gap reason="lost" quantity="3" unit="character"/> yāṉ Itu paṉmāye<hi rend="grantha">śvira<supplied reason="omitted">ra</supplied>kṣai <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi>
</p>

