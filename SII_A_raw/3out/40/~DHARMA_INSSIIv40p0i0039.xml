<!--<h4>First Face.</h4>-->

<p>
<lb n="1"/>svasti sarvvalōkāśra 
<lb n="2" break="no"/>ya śrīviṣṇuvaddana 
<lb n="3" break="no"/>mahārājula prava 
<lb n="4" break="no"/>ddamāna vijayarā 
<lb n="5" break="no"/>jya saṁvatsaraṁbu 
<lb n="6"/>37 gu śrāhi śrīma 
<lb n="7" break="no"/>nmahāmaṇḍalēśva 
<lb n="8" break="no"/>ra goṁkayamunu gō 
<lb n="9" break="no"/>ḍi śāṁta jinēśvarāla 
<lb n="10" break="no"/>layaṁbbunaku nicci 
<lb n="11"/>nagaḍugamaḍipa 
<lb n="12" break="no"/>ḍi mavu<unclear>pona</unclear>ku 
</p>

<!--<h4>Second Face.</h4>-->

<p>
<lb n="13"/><unclear>mu</unclear>dala vala <gap reason="lost" quantity="1" unit="character"/> 
<lb n="14"/> <gap reason="lost" quantity="2" unit="character"/> kāluvayuka 
<lb n="15" break="no"/> <gap reason="lost" quantity="1" unit="character"/> du polamē 
<lb n="16" break="no"/>rayu Ogoṟu 
<lb n="17"/>makuḍina vro 
<lb n="18" break="no"/><unclear>jā</unclear>gatuga ma 
<lb n="19" break="no"/>ḍiku Uttara 
<lb n="20" break="no"/>mu va<unclear>ra</unclear>nakasu 
<lb n="21" break="no"/> <gap reason="lost" quantity="2" unit="character"/> ḷala polamēra 
<lb n="22"/>yagaru su<unclear>da</unclear> 
<lb n="23" break="no"/>kṣmanamu velana 2 
<lb n="24"/>goṟagarusu 
</p>

<!--<h4>Third Face.</h4>-->

<p>
<lb n="25"/>Imasadi <unclear>pē</unclear>ru priti 
<lb n="26" break="no"/>ri tilakamu Ānuku 
<lb n="27" break="no"/>rajavitti saṁttōsa 
<lb n="28" break="no"/>banu<unclear>va</unclear>siḍi <gap reason="lost" quantity="3" unit="character"/> 
<lb n="29"/> <gap reason="lost" quantity="1" unit="character"/> vvaṇṇanokaṁ <gap reason="lost" quantity="1" unit="character"/> [I]da 
<lb n="30" break="no"/>ṁmu mavigunamu 
<lb n="31"/>sēsi ronipaṁca 
<lb n="32" break="no"/>mahāpatakamu sē 
<lb n="33" break="no"/>sinavāru vānarāsi 
<lb n="34"/>ccinavāru gaṁgaka 
<lb n="35" break="no"/>ṟata<unclear>vo</unclear>minanu<unclear>ṟṟu</unclear> 
<lb n="36"/>kavilala boḍici 
<lb n="37" break="no"/>navāru <g ref="sym:bar" type="punctuation">.</g> 
</p>

