<div type="edition" xml:lang="kan-Latn" rendition="class:kannada maturity:undetermined">

<p>
<lb n="1"/>mu<unclear>ḷuvā</unclear>ya ku
<lb n="2" break="no"/>māra kaṁpaṁṇana<unclear>ma</unclear>
<lb n="3" break="no"/>neya śiṁgajāvada gōpaṁ
<lb n="4" break="no"/>konukadiryya dēvarige māḍisida
<lb n="5"/>pathakakke pradhāna sōvappagaḷu slēṣe
<lb n="6" break="no"/>yāgi hēḷida ślōka <g ref="sym:bar" type="punctuation">.</g>
<lb n="7"/>svastiśrīmatu śakavaru
<lb n="8" break="no"/>ṣa 1275 neya <g ref="sym:bar" type="punctuation">.</g> vijaya
<lb n="9" break="no"/>saṁvatsarada phālguṇa su
<lb n="10" break="no"/>15 Ā <g ref="sym:bar" type="punctuation">.</g> daṁdu <g ref="sym:bar" type="punctuation">.</g> grīṣmē bhānu ma
<lb n="11" break="no"/>hōṣmāṇāṁ vimanasōkaptēdharaṁṇyā
<lb n="12"/>sthalēsthāśuṁkastaśikhāmaṇē<unclear>tri</unclear>kanaya
<lb n="13" break="no"/>lī<unclear>lō</unclear>llaṁghanērājakē <g ref="sym:bar" type="punctuation">.</g> svēkastyeva phaṇā vi
<lb n="14" break="no"/>bhārimaṇibhiḥ sphīkōdakaṁbiṁbikēśyā
<lb n="15" break="no"/>yā yāṁnamiśēśi sōmaśaci vaggrai
<lb n="16" break="no"/>vēyakaṁśāṁrgiṇaḥ <g ref="sym:doubleBar" type="punctuation">.</g> maṁgaḷa
<lb n="17" break="no"/>mahāśrī <g ref="sym:doubleBar" type="punctuation">.</g>
</p>

