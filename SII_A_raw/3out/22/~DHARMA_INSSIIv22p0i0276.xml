<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi> tiruvāykkeḻvi muṉṉāka <hi rend="grantha">tribhu</hi>vaṉacca<hi rend="grantha">kra</hi>vattikaḷ <hi rend="grantha">śrī rāja rājade</hi>varkku yāṇ
<lb n="2" break="no"/>ṭu 8<g ref="sym:dash" type="punctuation"/>vatu mārkaḻi mātattu Uṭaiyār tirumāṟpeṟuṭaiyārkku kuṇṭalūr turai Araicar muta
<lb n="3" break="no"/>likaḷil Uvaṟūrnāṭṭup paṉaippākkattu kūṟṟaṅkuṭaiyāṉ celvap piḷḷai yāṉa ciyakaṅ <gap reason="lost" quantity="4" unit="character"/> 
<lb n="4"/>t tirunantāviḷakku Araikku vi<supplied reason="omitted">ṭṭa</supplied>
<lb n="5"/><unclear>curapi</unclear>āka niṟutta Ikkoyilil <hi rend="grantha">śrī</hi> mā<hi rend="grantha">heśvara</hi>kkaṇkāṇi ceyvārum <hi rend="grantha">śrī</hi> kāriyañ
