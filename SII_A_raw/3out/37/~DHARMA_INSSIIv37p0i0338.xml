<lb n="1"/>śrīrāma jayamū <g ref="sym:doubleBar" type="punctuation">.</g> 
<lb n="2"/>svasti vijayābhyuda 
<lb n="3" break="no"/>ya śālivāhana śakavarsaṁ 
<lb n="4"/>1784 Agunaniyeḍi du 
<lb n="5" break="no"/>rmati saṁ <g ref="sym:doubleBar" type="punctuation">.</g> pālguṇa śudha 1<unclear>2</unclear> 
<lb n="6"/>lu vaiśyakula saṁbhavulayina 
<lb n="7"/>yeliśeṭi gōtrū<unclear>trō</unclear>dbhavula 
<lb n="8" break="no"/>yina kaṁddula guruvappa pautru 
<lb n="9" break="no"/>ḍaina subbiśeṭṭi putruḍaina kri 
<lb n="10" break="no"/>ṣṇamaśeṭṭi kuṭuṁbbā sa 
<lb n="11" break="no"/>mitamuga <g ref="sym:doubleBar" type="punctuation">.</g> śrī lakṣminṛśiṁ 
<lb n="12" break="no"/>hvasvāmivārki kaḷyāṇa 
<lb n="13"/>maṁṭṭapaṁ kaṭṭiṁcina śē 
<lb n="14" break="no"/>vā <g ref="sym:doubleBar" type="punctuation">.</g> 
