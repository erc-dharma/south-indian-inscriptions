<lb n="1"/>śubhamastu <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> namastuṁgasirastuṁbicaṁdracāmaracāra<supplied reason="omitted">vē</supplied> <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> trayilōkyanagarāraṁbhamūlastaṁbhāya śaṁbhavē <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> jayādbhudaya śālivāhana śakava<unclear>ru</unclear>
<lb n="2" break="no"/>ṣaṁbulu 1489 Agunēṭi prabhava saṁva(ṁ)tsara kārtika śu 12 lu śrīmadrājādhirāja paramēśvara śrīvīrapratāpa śrīsadāsivadēva mahārāyalu vidyā
<lb n="3" break="no"/>na<unclear>ga</unclear>ramaṁdu ratnasihvāsanārūḍhulayi pṛdhvīnā<supplied reason="omitted">ṁ</supplied>brājyaṁ cēyucuṁnuṁḍḍagānu Atrēyagōtraṁ Āpastaṁbasūtraṁ yajuśśākhādyāyulayi
<lb n="4" break="no"/>na Āravīṭi rāmarājugāri pavutṛlayina śrī raṁgarājayadēvamahārājulayavāri putṛlayina tirumalarājayadēvamahārājulayavāri
<lb n="5"/>kāryyakarttalayina kuṁccaccaṁnnappanāyanigāru kāviṁci pi<unclear>lla</unclear>kōṭaku vivaraṁ <g ref="sym:bar" type="punctuation">.</g> penugoṁḍadurggaṁ diguvakōṭaku pratigānu pillakōṭa bāṭhalu <g ref="sym:doubleBar" type="punctuation">.</g>
<lb n="6"/>yiṁduku vākiḷlunu <g ref="sym:doubleBar" type="punctuation">.</g> kottaḷālu <g ref="sym:doubleBar" type="punctuation">.</g> <gap reason="lost" quantity="1" unit="character"/> burujulunu <g ref="sym:bar" type="punctuation">.</g> kaṭiṁci kottagā Agaḍata taviṁci tirumalarājayavāri Ānatikramāna vuddhā hanuma
<lb n="7" break="no"/>ṁttuni vākaṭanu kuṁcaccaṁnapanāyanigāru sēyiṁccina śilāśāsanānaku maṁgaḷamahāśrī śrī śrī śrī śrī jēyunū <g ref="sym:doubleBar" type="punctuation">.</g>
