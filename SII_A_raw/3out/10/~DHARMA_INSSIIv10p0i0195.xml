<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>svasti vēlpūrima 
<lb n="2" break="no"/>lenāyaku kūṁttuṟu 
<lb n="3"/>dārāsāniprōlāsā 
<lb n="4" break="no"/>ni dana tallidaṁḍru 
<lb n="5" break="no"/>lakuṁ danakunu dha 
<lb n="6" break="no"/>rmārtthamugā saka 
<lb n="7"/>varṣaṁbulu 109<unclear>8</unclear> 
<lb n="8"/>nēṁṭi Uttarāyana 
<lb n="9" break="no"/>saṁkrāṁttinimitta 
<lb n="10" break="no"/>muna vēlpūriśrī 
<lb n="11"/>rāmīśvaramahādē 
<lb n="12" break="no"/>vara kācaṁdrārkka maka 
<lb n="13" break="no"/>ṁḍavarttidiviya ki 
<lb n="14" break="no"/>ccina goṟiyalu 55 
<lb n="15"/>kukūṁttu <unclear>ṟu</unclear> vālu 
</p>

<!--<h4>Second Face.</h4>-->

<p>
<lb n="16"/>vīniṁ jēkonina 
<lb n="17"/>vāṁḍu bādiya 
<lb n="18"/>bōyini koḍu 
<lb n="19" break="no"/>ku maṭṭe dana 
<lb n="20"/>putrānupavi 
<lb n="21" break="no"/>trikamu nitya 
<lb n="22"/>māneṁḍu ne 
<lb n="23" break="no"/>yi vōyaṁga 
<lb n="24" break="no"/>lavāṁḍu <g ref="sym:doubleBar" type="punctuation">.</g> sva 
<lb n="25" break="no"/>dattaṁ paradattaṁ vā 
<lb n="26"/>yō harēti va 
<lb n="27" break="no"/>suṁdharā ṣaṣṭi 
<lb n="28"/>rvvarṣasaha 
<lb n="29" break="no"/>srāni viṣṭāyā 
<lb n="30" break="no"/>ṁ jāyatē krimi 
<lb n="31"/>Idi Aleṭināya 
<lb n="32" break="no"/>ma peṭṭina divya 
</p>

