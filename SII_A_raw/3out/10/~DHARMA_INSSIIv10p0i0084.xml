<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śrī kaṁdaṁ <g ref="sym:doubleBar" type="punctuation">.</g> bhūviditaśakamahīśābdāvali mu<unclear>ni</unclear>vā 
<lb n="2" break="no"/>rinidhiviyaccaṁdramita śrī vibhrājillaṁga visvāvanu 
<lb n="3"/>saṁvatsaramuna janavinutamu gānu <g ref="sym:doubleBar" type="punctuation">.</g> [1 <g ref="sym:doubleBar" type="punctuation">.</g>*] kara <unclear>mo</unclear>ppu 
<lb n="4"/>ghaṁṭaśālāpurakāmini gāminīvibhūṣaṇamu 
<lb n="5"/>guṇākaruṁ ḍaina pōtināyaku varasuta sukumārarū 
<lb n="6" break="no"/>pavati vasumatilōnu <g ref="sym:doubleBar" type="punctuation">.</g> gīdi <g ref="sym:doubleBar" type="punctuation">.</g> ramaṇitōḍa nuttarāyaṇati 
<lb n="7" break="no"/>dhini<unclear>mi</unclear>ttamu<unclear>na bha</unclear>kti velaya dharmmayukti <gap reason="lost" quantity="1" unit="character"/> rasamūna(na) 
<lb n="8" break="no"/>mitacaraṇuna kakhilalōki <gap reason="lost" quantity="4" unit="character"/> bārvva<unclear>tī</unclear>śvaru 
<lb n="9" break="no"/>naku <g ref="sym:doubleBar" type="punctuation">.</g> [3 <g ref="sym:doubleBar" type="punctuation">.</g>*] kaṁdaṁ <g ref="sym:doubleBar" type="punctuation">.</g> Aṁḍajakuṁḍa<unclear>luna</unclear>ku śaśikhaṁḍasi 
<lb n="10" break="no"/>rōmaṁḍanunakuṁ gāmaharunaku <gap reason="lost" quantity="1" unit="character"/> ṁ <gap reason="lost" quantity="1" unit="character"/> ṁḍēśvarunaku dīpa 
<lb n="11"/>makhaṁḍaṁ bācaṁ<unclear>dra</unclear>tārakamugā nilipenu [<g ref="sym:doubleBar" type="punctuation">.</g>] [4 <g ref="sym:doubleBar" type="punctuation">.</g>*]
<lb n="12"/>ghaṁṭasāla kāmaka tama yayya pōtināyakunaku 
<lb n="13"/>tama yamma prōlamaku dharmmārttamugā nakhaṁḍavartti 
<lb n="14"/>diviyakuṁ beṭṭina <unclear>go</unclear>ṟi 50 vīniṁ jēkoni bēḍuga 
<lb n="15"/>bōyuṁḍu tana putrānupautrikamu Ivani toṁḍīśvaradē 
<lb n="16" break="no"/>varaku nityamāneṁḍu ne<unclear>yi</unclear> vōyaṁgalavāṁḍu Ilupaṭṭu 
<lb n="17"/>mūḷlu 2 bhūmi na 4 yidharmmuvu Evvarainaṁ dappirēni bā 
<lb n="18" break="no"/>narāsi vraccinavāru <g ref="sym:doubleBar" type="punctuation">.</g> Ivanikaraṇa yaytanavrālu <g ref="sym:doubleBar" type="punctuation">.</g> 
</p>

