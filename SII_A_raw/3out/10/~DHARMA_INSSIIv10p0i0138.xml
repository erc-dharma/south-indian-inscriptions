<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śrīramaṇuṁḍu śauryyaguṇōddā 
<lb n="2" break="no"/>ruṁḍu goṁkavibhu māma darppita 
<lb n="3"/>ripusaṁhāruṁḍu dhīruṁ ḍa 
<lb n="4" break="no"/>naṁ dagu mārayapaṁḍaṁḍu gī 
<lb n="5" break="no"/>rttimaṁḍanuṁḍu mahini <g ref="sym:doubleBar" type="punctuation">.</g> [1 <g ref="sym:doubleBar" type="punctuation">.</g>*] Anaṁ dagu 
<lb n="6"/>daṁḍēśu priyāṁgana gommama vibu 
<lb n="7" break="no"/>dhamitragaṇaparivāraṁbuna ke 
<lb n="8" break="no"/>llanu hridayānaṁdanakāri yanaṁga 
<lb n="9"/>negaḍe dhāruṇi miṁdanu <g ref="sym:doubleBar" type="punctuation">.</g> [2 <g ref="sym:doubleBar" type="punctuation">.</g>*] ghanuṁ 
<lb n="10" break="no"/>ḍu niḍumrāni kommayakunu līlāvatiyu 
<lb n="11"/>dhairyyaguṇavati yani pempuna negaḍina mallā 
<lb n="12" break="no"/>ṁbikakunu suta yanaṁ baragi dhairyyaguṇa 
<lb n="13"/>saṁstutitōnu <g ref="sym:doubleBar" type="punctuation">.</g> [3 <g ref="sym:doubleBar" type="punctuation">.</g>*]
<lb n="14"/>vananidhivēṣṭitāvanilōnaṁ gala 
<lb n="15"/>yagrahāraṁbulaku maṇihāralī 
<lb n="16" break="no"/>la <g ref="sym:bar" type="punctuation">.</g> mānaina peruvali mādha 
<lb n="17" break="no"/>vadēvara kettiṁcce guḍi bhakti ye<unclear>saṁ</unclear> 
<lb n="18" break="no"/>gaṁ gommamāṁbika tatpūnuṁ ḍaru<unclear>cōḍa</unclear> 
<lb n="19"/>daṁḍēśuṁ ḍa<unclear>ṭṭe</unclear>vunaku nivēdyamuna kartti 
<lb n="20" break="no"/>tō rājitaṁ bagu nēraḍlaceṟvu nāgnēya <gap reason="lost" quantity="1" unit="character"/> 
<lb n="21"/>kunaṁ gaḍu nāyatamuga <g ref="sym:bar" type="punctuation">.</g> 0 baragaṁ <unclear>bāda</unclear> 
<lb n="22"/> <gap reason="lost" quantity="1" unit="character"/> khya niruvuṭṭi bhūmi ravīṁdutārakamuga ni 
<lb n="23" break="no"/>cceṁ draiśatāgrajanmasamiti yanuma 
<lb n="24" break="no"/>taṁbuna śakābdamu libhādridigmita 
<lb n="25" break="no"/>muna velaya <g ref="sym:doubleBar" type="punctuation">.</g> [4 <g ref="sym:doubleBar" type="punctuation">.</g>*] gaḍvamaḍiprēṁpāva<unclear>da</unclear> 
<lb n="26" break="no"/>kṣiṇaṁbunaṁ buṭṭeṁḍu bhūmi dāniṁ bū 
<lb n="27" break="no"/>jāri mādhavabhaṭlu dēvaraku gosavi ni 
<lb n="28" break="no"/>vēdyaṁbuna kicciri <g ref="sym:doubleBar" type="punctuation">.</g> 
</p>

