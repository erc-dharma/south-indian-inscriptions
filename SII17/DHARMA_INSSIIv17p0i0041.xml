            <div type="edition" xml:lang="kan-Latn" rendition="class:kannada maturity:undetermined">
                
                <p>
                    <lb n="1"/>śrīmatu kogaḷiya
                    <lb n="2"/>vīrabhadradēvaranu Ujiniya nirupaya
                    <lb n="3"/>nu <unclear>mā</unclear>ḍidanu
                    <lb n="4"/><g ref="sym:ddanda" type="punctuation">.</g> <g ref="sym:circle">.</g> <g ref="sym:ddanda" type="punctuation">.</g> śrīgaṇādhipataE namaḥ <g ref="sym:ddanda" type="punctuation">.</g> 
                </p>
                <lg n="1" met="anuṣṭubh" xml:lang="san-Latn" rendition="class:kannada maturity:undetermined">
                    <l n="a" enjamb="yes">nama
                        <lb n="5" break="no"/>stuṁbi ṣirastuṁbi</l>
                    <l n="b">caṁdracā
                        <lb n="6" break="no"/>mara cāravē</l>
                    <l n="c" enjamb="yes">trayilōkya nagarā
                        <lb n="7" break="no"/>ra<choice><sic>bhaṁ</sic><corr>raṁbha</corr></choice></l>
                    <l n="d">mūlastaṁbhāya śaṁbhavē <supplied reason="undefined"><g ref="sym:ddanda" type="punctuation">.</g></supplied></l>
                </lg>
                <p>
                    <lb n="8"/>svastiśrī jayābhyudaya śāli
                    <lb n="9" break="no"/>vāhana śakavaruṣa 1454 ne kha
                    <lb n="10" break="no"/>ra saṁvatsarada<!--<note n="7-1">Engraved vertically to the proper right of the Liṅga at the top.</note>--> jeṣṭa ba 10 lu śrī
                    <lb n="11" break="no"/>matu kōgaḷiya vīrabhadra dēva
                    <lb n="12" break="no"/>rige koṭūra tipisaṭeya
                    <lb n="13" break="no"/>ra makaḷu baseṭiyaru pratiṣṭeya
                    <lb n="14"/>māḍi<unclear>da</unclear> vīrabhadradēvarige baḷā
                    <lb n="15" break="no"/>riya mokeya tippiseṭi base<unclear>ṭi</unclear>
                    <lb n="16"/>mosageya guruvappa vōḍivaliṁ<unclear>gi</unclear>
                    <lb n="17" break="no"/>seṭi caṁdiya liṁgiseṭi muṁttā
                    <lb n="18" break="no"/>da samastahalaru Ubhaya nānā
                    <lb n="19" break="no"/>dēśada seṭi paṭaṇa svāmiga
                    <lb n="20" break="no"/>ḷu biṭu koṭa mūrevīsa
                    <lb n="21"/>hēṟu 1 kaṁ kāsu 1 nu dē
                    <lb n="22" break="no"/>vara naṁdādīpake salu
                    <lb n="23" break="no"/>vadu <g ref="sym:ddanda" type="punctuation">.</g> maṁgaḷa mahā śrī śrī
                    <lb n="24"/>śrī śrī śrī
                    <lb n="25"/>yi kogaḷiya vīrabha
                    <lb n="26" break="no"/>dra
                </p>
                
