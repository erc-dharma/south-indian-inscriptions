                <p>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> cak<hi rend="grantha">kra</hi>vatti <hi rend="grantha">śrī</hi> kulottu
                    <lb n="2" break="no"/>ṅka coḻa<hi rend="grantha">de</hi>vaṟkku yāṇṭu <num value="40">4 <g type="numeral">10</g></num> nālā
                    <lb n="3" break="no"/>vatu kaṅkai koṇṭa<surplus>ku</surplus>coḻavaḷanā
                    <lb n="4" break="no"/>ṭṭu paṭṭāṉ pākkai nāṭṭu coḻakula
                    <lb n="5" break="no"/>vallinallūr tirukkaṇṇī<hi rend="grantha">śvara</hi>muṭaiya <hi rend="grantha">mahāde</hi>vaṟkku I
                    <lb n="6" break="no"/>kkoyil kāṇi Uṭaiya parā <gap reason="lost" quantity="6" unit="character"/> taṉ<unclear>nal</unclear> cuṅka<supplied reason="omitted">n</supplied>tavi<supplied reason="omitted">rt</supplied>ta
                    <lb n="7"/>coḻap pal<supplied reason="omitted">la</supplied>varaiyaṉ pakkal Ikkoyil <hi rend="grantha">śi</hi>va<hi rend="grantha">brāhma</hi>ṇaṉ tiruni
                    <lb n="8" break="no"/>lakaṇṭaṉ tiruvekampa<surplus>m</surplus>muṭaiyāṉ Uḷiṭṭārum
                    <lb n="9" break="no"/>tiruciṟṟampalamuṭaiyā<unclear>ṉ ci</unclear>vattanum tiruvoṟṟikaṇ
                    <lb n="10" break="no"/>ṭa<unclear>ci</unclear>vaṉum Ārur tiruva<supplied reason="omitted">ṇ</supplied>ṇā<unclear>ma</unclear>lai paṭṭanum Ivvaṉai
                    <lb n="11"/>vom <hi rend="grantha">sa</hi>n=tiviḷakku Oṉṟu <hi rend="grantha">candrā</hi>tittava<unclear>rai</unclear> Erikkakkaṭavo
                    <lb n="12" break="no"/>māka koṇṭa kācu <num value="1.5">1 1/2</num> <supplied reason="undefined"><g type="ddanda">.</g></supplied> 
                </p>
                
