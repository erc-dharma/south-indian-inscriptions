<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">śaktērāgnēyadikbhāgē dēvatīrttha</hi>
<lb n="2"/><hi rend="grantha">sya pūrvvataḥ <g ref="sym:danda" type="punctuation">.</g> Ā<unclear>na</unclear>ndēśvaranāmnā tat sarvva pa <gap reason="lost" quantity="2" unit="character"/> </hi><note n="284-2">Built in at the right end.</note>
<lb n="3"/><hi rend="grantha">kanāśanam [<g ref="sym:ddanda" type="punctuation">.</g>1*<g ref="sym:ddanda" type="punctuation">.</g>] <unclear>kri</unclear>yatē brāhmaṇairbhaktyā <gap reason="lost" quantity="4" unit="character"/> </hi>
<lb n="4"/><hi rend="grantha">parāyaṇaiḥ <g ref="sym:danda" type="punctuation">.</g> Adya puṇyatithirnnāma vai <gap reason="lost" quantity="3" unit="character"/> </hi>
<lb n="5" break="no"/><hi rend="grantha">puṇyadā parā <g ref="sym:danda" type="punctuation">.</g> [<g ref="sym:ddanda" type="punctuation">.</g>2<g ref="sym:ddanda" type="punctuation">.</g>*] yōsyāmasyatithau <gap reason="lost" quantity="2" unit="character"/> </hi>
<lb n="6"/><hi rend="grantha">naraḥ kuryyāt prajāgaram [<g ref="sym:danda" type="punctuation">.</g>] Ānandēśva <gap reason="lost" quantity="5" unit="character"/> </hi>
<lb n="7"/><hi rend="grantha">sa mōkṣam labhatē ddhruvam <g ref="sym:danda" type="punctuation">.</g> [<g ref="sym:ddanda" type="punctuation">.</g>3<g ref="sym:ddanda" type="punctuation">.</g>*] U</hi>
</p>

