    <text xml:space="preserve">
        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                
                <p>
                    <lb n="1"/><hi rend="grantha">svastiśrī <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi> pūmātu puṇarap puvimātu vaḷara nām<unclear>ātu</unclear> mak<choice><sic>u</sic><corr>i</corr></choice>ḻa ceyamātu peruka tantiruppat<choice><sic>u</sic><corr>a</corr></choice> malar manna
                    <lb n="2" break="no"/>var cūṭa manniya Urimaiyil maṇimuṭicūṭic ceṅkol ceṉṟu ticaitoṟum vaḷaṟppa veṅkali
                    <lb n="3"/>niṅka meyyaṟan taḻaippak kaliṅka miriyakkaṭa<choice><sic>r</sic><corr>l</corr></choice> malai naṭātti valaṅkoḷḷāḻi varaiyā
                    <lb n="4" break="no"/>tu naṭappa Irucuṭaraḷavu morukuṭainiḻaṟ<choice><sic>kiḻ</sic><corr>ṟa</corr></choice> vira<hi rend="grantha">siṁhāsa</hi>nattu mukkokkiḻānaṭikaḷo
                    <lb n="5" break="no"/>ṭum viṟṟirun=taruḷiya kopparakecari<hi rend="grantha">panma</hi>rāṉa tiripuvaṉaccakkaravattikaḷ <hi rend="grantha">śrī</hi> vikkiramacoḻa<hi rend="grantha">de</hi>vaṟku
                    <lb n="6"/>yāṇṭu Aiñcāvatu <hi rend="grantha">ja</hi>yaṅkoṇṭacoḻamaṇṭalattu maṇavil koṭṭattu maṇavil Arum
                    <lb n="7" break="no"/>pākkiḻān Araiyan <gap reason="lost" quantity="18" unit="character"/> 
                    <lb n="8"/>tu māttu <gap reason="lost" quantity="25" unit="character"/> 
                </p>
                
            </div>
            
            <div type="apparatus">
                <listApp>
                    <app loc="4">
                        <lem>varaiyā
                    <lb n="4" break="no"/>tu naṭappa</lem>
                        <note>Some versions read <foreign>varaiyāḻitiriya</foreign> (of. SII. Vol. VIII-No. 511).</note>
                    </app>
                    <app loc="4">
                        <lem>niḻaṟkiḻ</lem>
