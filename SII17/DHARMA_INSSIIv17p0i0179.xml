                <p>
                    <lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g type="ddanda">.</g></supplied> śrīmaN mahāmaṇḍaleśvaraN harirāja vibhāṭaN bhāṣai</hi>kkut tappuvarāyā kaṇṭaṉ <hi rend="grantha">catuḥ<supplied reason="omitted">samu</supplied></hi>
                    <lb n="2" break="no"/><hi rend="grantha">drādhi</hi>pati <hi rend="grantha">śrī</hi>virapokkaṇa Uṭaiyar kumārar kampaṇa Uṭaiyar <hi rend="grantha">pṛthi</hi>vi<hi rend="grantha">rājyaM</hi> paṇṇi Aruḷāni
                    <lb n="3" break="no"/>ṉṟa <hi rend="grantha">śakābdaM</hi> <num value="1291"><g type="numeral">1000</g> 2 <g type="numeral">100</g> 9 <g type="numeral">10</g> 1</num> ṉ mel cellā niṉṟa <hi rend="grantha">saumya</hi> varu<hi rend="grantha">ṣa</hi>ttu tulānāyaṟṟu <hi rend="grantha">pūrvva</hi>pa<hi rend="grantha">kṣa</hi>ttu
                    <lb n="4"/><hi rend="grantha">tra</hi>yo<hi rend="grantha">daśi</hi>yum nāyaṟṟukkiḻam<unclear>ai</unclear>yum peṟṟa Uttiraṭṭāti nāḷ makatai maṇṭalattu vaṭaka<unclear>r</unclear>ai nāṭṭavar
                    <lb n="5"/>kkaṭava maruttūruṭaiyāṉ mutaliy<choice><sic>a</sic><corr>ā</corr></choice>r nāyaṉār peṇṇorupāka mutaliyāṟku tammuṭaiya kā
                    <lb n="6" break="no"/>ṇi Āṭci yarai varicaippaṟṟu virapālaṉental <hi rend="grantha">candrāditya</hi>varaiyum nāṭṭu viṉiyo<hi rend="grantha">ga</hi>
                    <lb n="7" break="no"/>m kaḻittu viṭṭa Aḷavukku Ippaṭikku tiruppālaippantal Uṭaiyār tirunā<hi rend="grantha">gīśvara</hi> muṭaiya nāya<supplied reason="omitted">ṉār</supplied>
                    <lb n="8"/>koyilil tirukkaṟṟaḷaiyile kalveṭṭikkoḷḷavum meṟpaṭi nāṭṭār paṇiyāl periyanāṭṭu veḷaṉ
                    <lb n="9"/>Eḻuttu <g type="pc">.</g>
