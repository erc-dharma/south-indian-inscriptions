            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                
                <p>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> vikkiramacoḻa<hi rend="grantha">de</hi>vaṟku yāṇṭu <num value="12"><g type="numeral">10</g> 2</num><g ref="sym:dash" type="punctuation">.</g>Āvatu <hi rend="grantha">rājarāja</hi> vaḷanāṭṭup paṭṭān p<choice><sic>a</sic><corr>ā</corr></choice>kkai nāṭṭuc
                    <lb n="2"/>coḻakulavallinallūrt tirukkaṇṇī<hi rend="grantha">śvara</hi>muṭaiya <hi rend="grantha">mahāde</hi>vaṟku Ivvūr Aḻicupākka muṭaiyān Appuli
                    <lb n="3"/>vempaṭikaḷ Āna vikkiramacoḻa muventaveḷḷān vaitta <hi rend="grantha">sa</hi>nti viḷakku 1 Oṉṟum Innāṭṭu vecālippāṭi manṟā
                    <lb n="4" break="no"/>ṭi coṭṭai Eḻunāyaneṉ kaikkoṇṭa Āṭu <num value="12"><g type="numeral">10</g> 2</num> ṭum koṇṭu cantirātittavarai celuttak kaṭaven <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
                </p>
                
