                    <lb n="2"/><num value="1386"><g type="numeral">1000</g> 3 <g type="numeral">100</g> 8 <g type="numeral">10</g> 6</num>ṉ mel cellāniṉṟa <unclear>t</unclear>āraṇa varu<hi rend="grantha">ṣa</hi>m tai <g ref="sym:tam-matam" type="symbol">@</g> <num value="12"><g type="numeral">10</g> 2</num> vetam Otiṉār puliyūr nāṭṭu veḷāṟku tirumaṟaikkāṭukoyil
                    <lb n="3"/>Āticaṇṭecura tevarkaṉmikaḷom nilavilai piṟamāṇam paṇṇik kuṭuttapaṭi tirumaṟaikkāṭuṭaiya tampirāṉāṟku civarā
                    <lb n="4" break="no"/>ttiṟit tipatam tammuṭai<unclear>ya</unclear> <gap reason="lost" quantity="6" unit="character"/> ka naṭantu potukaiyil Intat tipatattukkum <gap reason="lost" quantity="6" unit="character"/> meṉac ce <gap reason="lost" quantity="10" unit="character"/> <unclear>Amutu</unclear>paṭi kaṟi
                    <lb n="5" break="no"/>yamutukkum maṟṟum Uṇṭāṉatukkum Uṭalākakkoṇṭu cantirātittavaraiyum naṭatta <gap reason="lost" quantity="10" unit="character"/> kāṇiyāṉa
                    <lb n="6"/><surplus>ṉa</surplus> paṅkum <choice><sic>v</sic><corr>n</corr></choice>ilavilai ni<choice><sic>ṟ</sic><corr>r</corr></choice><unclear>ṇayam</unclear> paṇṇiṉa nilam Āvatu nattattukkum Āṟṟukkum naṭuppaṭṭa kaṭṭaḷai Oṉṟil <g ref="sym:tam-matam" type="symbol">@</g> 5-li nilam Ayvelik
                    <lb n="7" break="no"/>kum vilai ni<choice><sic>ṉṟ</sic><corr>rṇ</corr></choice>ayam paṇṇiṉa <g ref="sym:tam-panam" type="symbol">@</g> <num value="200"><unclear>2 <g type="numeral">100</g></unclear></num> Ippaṇam Irunūṟum paṟṟikkoṇṭamaikku Inta nilattil mutalāka mutal koṇṭu canti
                    <lb n="8" break="no"/>rātittavaraiyum tammuṭaiya Upayam Āka naṭattip potakkaṭavom Ākavum <g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g> Ippaṭikku Ivai vetavaṉappir<choice><sic>ā</sic><corr>a</corr></choice>mārāyaṉ Eḻuttu Ivai
                    <lb n="9"/>tirumaṟaikkāṭupaṭṭaṉ Eḻuttu Ivai koyil nāyakam vetavaṉanampi Eḻuttu māṭāpattiyam takaṭṭūr kiḻavar veṇāvuṭaiyār Eḻuttu
                    <lb n="10"/>Ivai māṭāpattiyam takaṭṭūr kiḻavar vaḷavataraiyaṉ Eḻuttu Ivai tirumāḷikaikkūṟu takaṭṭūr kiḻavar villavataraiyaṉ Eḻuttu <supplied reason="undefined"><g ref="sym:ddanda" type="punctuation">.</g></supplied>
