            <div type="edition" xml:lang="san-Latn" rendition="class:kannada maturity:undetermined">
                
                <div type="textpart" n="A"><head>First Face</head>
                    <p>
                        <lb n="A1"/><gap reason="lost" quantity="5" unit="character"/> 
                        <lb n="A2"/>khaṇḍita pratāpāva <gap reason="lost" quantity="3" unit="character"/> 
                        <lb n="A3"/>kakkaladēva pracaṇḍa siṁ<unclear>hā</unclear>
                        <lb n="A4" break="no"/>sanastha bhūmaṇḍaḷa maṇḍanībhū
                        <lb n="A5" break="no"/>ta veṁgimaṇḍaḷāntappāti
                        <lb n="A6"/>gudravāṭa dēśāntarggata
                        <lb n="A7"/><unclear>pā</unclear>kalāgrahārē taitirīya
                        <lb n="A8"/>śākhāḷaṁkṛtaḥ Ā<unclear>trē</unclear>ya <unclear>gō</unclear>
                        <lb n="A9" break="no"/>trē dvijakuḷacūḍāmaṇiḥ <unclear>pa</unclear>
                        <lb n="A10" break="no"/>llavatātābhidhānōbhavat <g ref="sym:ddanda" type="punctuation">.</g>
                        <lb n="A11"/>tatputra ssakaḷabhūmaṇḍaḷa
                        <lb n="A12"/><unclear>rvvi</unclear>khyātō jakkitākhyōbhū
                        <lb n="A13" break="no"/>t tasmād brahmakaḷpaḥ kaḷpa<unclear>pā</unclear>
                        <lb n="A14" break="no"/>dapādiva pallavaḥ pallavānāṁ 
                    </p>
                    
                </div>
                
                <div type="textpart" n="B"><head>Second Face</head>
                    
                    <p>
                        <lb n="B1"/><gap reason="lost" quantity="5" unit="character"/> ta vasudhāta
                        <lb n="B2"/>prādāddēvakatrāya <gap reason="lost" quantity="4" unit="character"/> 
                        <lb n="B3"/>nnadānaphaḷaṁ labdharā <gap reason="lost" quantity="3" unit="character"/> 
                        <lb n="B4"/>pavāsōpyamuktatritīya <gap reason="lost" quantity="2" unit="character"/> 
                        <lb n="B5"/>taḥ tatrātmīya parābhaki ni
                        <lb n="B6" break="no"/>mityaṁ nirmaḷādri<unclear>dō</unclear> <g ref="sym:danda">.</g> tasmi
                        <lb n="B7"/><unclear>n</unclear> kāḷē mayūramudrāhasta
                        <lb n="B8"/>śrī sōmēśvarāsthānē <g ref="sym:danda">.</g> pramā
                        <lb n="B9" break="no"/>ṇyaṁ yadi vēdēṣu brahma viṣṇu
                        <lb n="B10"/>mahēśvarē <unclear>dē</unclear>vakāgratrayasyāpi
                        <lb n="B11"/>labdhasyāsti pramāṇatā <g ref="sym:danda">.</g> śrīka
                        <lb n="B12" break="no"/>rmmāra kuḷāhvaya dvijava <gap reason="lost" quantity="1" unit="character"/> grāma
                        <lb n="B13"/>sya <gap reason="lost" quantity="3" unit="character"/> tō niṣkramya krama
                    </p>
                </div>
                
            </div>
            
