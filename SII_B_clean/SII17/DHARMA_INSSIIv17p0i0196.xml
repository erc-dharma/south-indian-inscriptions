            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
                
                <p>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> pukaḻmātu viḷaṅka <hi rend="grantha">ja</hi>yamātu virumpa nilamakaḷ nilava malarmakaḷ puṇara Urimai
                    <lb n="2" break="no"/>yiṟ ciṟan=ta maṇimuṭicūṭi miṉavar nilaikeṭa villavar kulaitara Eṉai maṉṉava ririyaḷuṟṟuḻi
                    <lb n="3" break="no"/>tarat tikkaṉaittun=tan cakkara naṭātti vira<hi rend="grantha">siṁhāsa</hi>ṉattuUlakuṭaiyaḷoṭum viṟṟiruntaruḷiya
                    <lb n="4"/><hi rend="grantha">korāja</hi>kecaripa<hi rend="grantha">nma</hi>rāṉa <hi rend="grantha">cakra</hi>vattikaḷ <hi rend="grantha">śrī</hi>kulottuṅkacoḻa<hi rend="grantha">de</hi>vaṟku yāṇṭu <num value="45">4 <g type="numeral">10</g> 5</num> Āvatu <g ref="sym:bullet-double" type="punctuation">.</g><g ref="sym:dash-long" type="punctuation">.</g> coḻamaṇṭa
                    <lb n="5" break="no"/>lattuk keyamāṇikka vaḷanāṭṭu Aḷanāṭṭuk kiḻveḷur veḷur kiḻavaṉ nātan tulaiyātacelva nāṉa
                    <lb n="6"/><hi rend="grantha">rājarāja</hi>p pallavar<hi rend="grantha">ai</hi>yaneṉ Eṅkaḷ <unclear>pi</unclear>tākkaḷ peruntirukkoyil nātanārkku nanṟāka <hi rend="grantha">ja</hi>yaṅkoṇṭaco
                    <lb n="7" break="no"/>ḻamaṇṭalattu māttūr nāṭṭut tiruvakkarait tirukkaṟṟaḷi <hi rend="grantha">śrī</hi> mula<hi rend="grantha">stā</hi>ṉamuṭaiya <hi rend="grantha">mahāde</hi>vaṟku O
                    <lb n="8" break="no"/>ru tirunun=tāviḷakkuk=ku nāṉ viṭṭa nilamāvatu Innāṭṭu Oḻukaṟaiyāṉa kulottuṅkacoḻa nal<unclear>lū</unclear>
                    <lb n="9" break="no"/>r melpiṭākaiyil Eṉ kāṇiyāṉa neṉmaliyil tenpāṟkellai veḷurkkiḻavaṉ nātan=tulaiyā
                    <lb n="10" break="no"/>ta celvanāṉa <hi rend="grantha">rājarāja</hi>ppallavaraiya nilattukku vaṭakkum melpāṟkellai meṟpaṭiyā<unclear>r</unclear> nilattuk=ku
                </p>
                
