	<text xml:space="preserve">
		<body>
			
			<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
				
				<p>
					<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> Uṭaiyār tiruviraṭṭāṉamuṭaiya nā yaṉārk
					<lb n="2" break="no"/>kut tirunāmattukkāṇiyāka Aṉumaṉuḻāṉ cūriyatevarā
					<lb n="3" break="no"/>ṉa koṅkarāyar pullāliyil viṭṭa toppukku tāṉa
					<lb n="4" break="no"/>ttārkku Eḻutiṉa cātaṉappaṭi coḻakulavallinallūr pul
					<lb n="5" break="no"/>lāliveḷāṉ maṉattukkiṉiyāṉāṉa kaṉakarāyaṉ muṉṉāḷ perumā
					<lb n="6" break="no"/>ḷ cuntarapāṇṭiyatevar nāḷil naṭuvilmaṇṭalattukku A
					<lb n="7" break="no"/>tikārañceytu Ivarperāl Iṭ<unclear>ṭa</unclear> <unclear>ki</unclear>kkinilai Eṉakkup paramā<unclear>y</unclear>
					<lb n="8"/>nāṉ celavaṟukkaiyil Ivarkku naṭuvilmaṇṭalattilum
					<lb n="9"/>coḻamaṇṭattilum Ivar kāṇi maṉai Aṭimai Uḷḷa⌈
					<lb n="10" break="no"/>vai Eṉ ṉaṉutāramāy nāṉ veṇṭuvārkku <unclear>ku</unclear>ṭuttum Aṉupavi
					<lb n="11" break="no"/>ttumpotukaiyil coḻakulavallinallūr kiḻpiṭā⌈
					<lb n="12" break="no"/>kai pullālinattattil Ivvūr pullāliveḷāṉ Aruḷāḷaṉ
					<lb n="13"/>cetirāyaṉpakkal Intak kaṉakarāyaṉ vilaikoṇṭu Ivar
					<lb n="14"/>Aṉupavittuppontu Eṉṉutāṉa Inta nat<surplus>na</surplus>tattil to
					<lb n="15" break="no"/>ppu nāṉkellaikkuḷḷu<unclear>n</unclear> tirunāmattukkāṇiyākat tanta
					<lb n="16"/>Ittoppu perumāḷ virapāṇṭiyatevarkku <unclear>E</unclear>ṭṭāvatu taimāta
					<lb n="17" break="no"/>mutal kaikkoṇṭu nāṉkellaiyilum tiruccūlattā<surplus>Ā</surplus>paṉa
					<lb n="18" break="no"/>mum paṇṇi Uṭaiyār tiruviraṭṭāṉamuṭaiya nāyaṉār koyili⌈
					<lb n="19" break="no"/>le kallum veṭ<unclear>ṭi</unclear>kkoḷḷavum pār<supplied reason="omitted">p</supplied>patu <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> Ivai Aṉumaṉuḻāṉ ko
					<lb n="20" break="no"/>⌉ṅkarāyaṉ Eḻu<unclear>ttu</unclear> <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> 
				</p>
				
