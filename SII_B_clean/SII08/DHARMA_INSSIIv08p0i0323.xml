			<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
				
				<p>
					<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> pukaḻmātu viḷaṅka <hi rend="grantha">ja</hi>yamātu virumpa nilamakaḷ nilava malarmakaḷ puṇara Urimaiyiṟ ciṟanta ma<unclear>ṇi</unclear>
					<lb n="2" break="no"/>muṭi cūṭi minavar nilaikeṭa villa<unclear>var</unclear> kulaitara E<unclear>ṉai</unclear>mannavar riḻiyaluṟ ṟuḻitara tikkan<hi rend="grantha">ai</hi>ttu n=tan cak<hi rend="grantha">ra</hi><surplus>ra</surplus> naṭātti vira<hi rend="grantha">siṅāsa</hi>na
					<lb n="3" break="no"/>ttu Avanimuḻutuṭaiyāḷoṭu viṟṟirun=taruḷiya ko<hi rend="grantha">rā</hi>cakecaripa<hi rend="grantha">nma</hi>rāna cakkaravattikaḷ <hi rend="grantha">śrī</hi>kulottuṅkacoḻa<hi rend="grantha">de</hi>vaṟku yāṇṭu <num value="44">4 <g type="numeral">10</g> 4</num><g ref="sym:dash" type="punctuation">.</g>
					<lb n="4" break="no"/>Āvatu kaṅkaikoṇṭacoḻavaḷanāṭṭu tirumun<hi rend="grantha">ai</hi>ppāṭi Ānmurnāṭṭu Āti<hi rend="grantha">rāja</hi>maṅka<hi rend="grantha">lya</hi>purattu Uṭaiyār <gap reason="lost" quantity="7" unit="character"/> 
					<lb n="5"/>namuṭaiyārk=ku <hi rend="grantha">ja</hi>yaṅkoṇṭacoḻamaṇṭalat=tuk kaḷattūrkkoṭṭattu kaḷattūr<unclear>ki</unclear>ḻavan piccan tiruveṇkā<unclear>ṭuṭai</unclear>
					<lb n="6" break="no"/>yān vaitta tirunan=tāviḷa<supplied reason="omitted">k</supplied>ku 1<g ref="sym:dash" type="punctuation">.</g>Onṟukkum viṭṭa cāvā muvāp perāṭu <num value="96">9 <g type="numeral">10</g> 6</num> <supplied reason="subaudible"><g ref="sym:bar" type="punctuation">.</g></supplied> Ivvāṭu toṇṇūṟṟāṟum kaikkoṇṭu tirunan=tā
					<lb n="7" break="no"/>viḷakku Erikkakkaṭavom Ikkoyilil tiruuḷnāḻikai<hi rend="grantha">sabhai</hi>yom <supplied reason="subaudible"><g ref="sym:bar" type="punctuation">.</g></supplied> Itu <hi rend="grantha">pa<unclear>nma</unclear>hā</hi>ye<hi rend="grantha">śvara rakṣai</hi> <unclear><g ref="sym:doubleBar" type="punctuation">.</g></unclear>
				</p>
				
