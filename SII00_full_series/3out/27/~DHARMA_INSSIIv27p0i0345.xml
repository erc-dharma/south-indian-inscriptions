<!--<h4>Third piece.</h4>-->

<p>
<lb n="1"/> <gap reason="lost" quantity="10" unit="character"/> lu maḍida <gap reason="lost" quantity="5" unit="character"/> 
<lb n="2"/> <gap reason="lost" quantity="5" unit="character"/> Aṟuvattu muḍe Akkigade <gap reason="lost" quantity="5" unit="character"/> 
<lb n="3"/> <gap reason="lost" quantity="5" unit="character"/> ṁ paḍuvalu teṁkalu bāvisaha vi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="4"/><unclear>ya</unclear> keṟeya gaḍiyiṁdaṁ teṁkalu <gap reason="lost" quantity="5" unit="character"/> 
<lb n="5"/>ḍu bāvi voḷagāgi yi makki <gap reason="lost" quantity="5" unit="character"/> 
<lb n="6"/>ya gaḍi hosakeṟiyagaḍi <unclear>dē</unclear> <gap reason="lost" quantity="5" unit="character"/> 
<lb n="7"/> <gap reason="lost" quantity="5" unit="character"/> maṇigāṟagēryya semaidēvara <gap reason="lost" quantity="5" unit="character"/> 
<lb n="8"/> <gap reason="lost" quantity="5" unit="character"/> ṁ mūḍalu baḍagalu siddē <gap reason="lost" quantity="5" unit="character"/> 
