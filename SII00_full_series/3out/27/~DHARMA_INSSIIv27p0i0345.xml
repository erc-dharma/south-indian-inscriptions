<lb n="6"/> <gap reason="lost" quantity="5" unit="character"/> 1 hāne 10 huḍubana gade 1kkaṁ
<lb n="7"/> <gap reason="lost" quantity="10" unit="character"/> yikkuvagēṇi hāne 40 lke Akki <unclear>mu</unclear> <gap reason="lost" quantity="3" unit="character"/> 
<lb n="8"/> <gap reason="lost" quantity="5" unit="character"/> yikkuvagēṇi pratimūḍe <gap reason="lost" quantity="5" unit="character"/> 
<lb n="9"/> <gap reason="lost" quantity="10" unit="character"/> sva teṟuva dēvasva Akara Aṁ <gap reason="lost" quantity="5" unit="character"/> 
