<p>
<lb n="1"/> <gap reason="lost" quantity="5" unit="character"/> daṁ mūḍalu baḍagalu <gap reason="lost" quantity="10" unit="character"/> 
<lb n="2"/> <gap reason="lost" quantity="5" unit="character"/> ya voḷage Uḷa gade 5 kaṁ bittuva bede hāne 40 ṟama <gap reason="lost" quantity="6" unit="character"/> 
<lb n="3"/> <gap reason="lost" quantity="5" unit="character"/> hosavoḷala voḷage mārkkaṁḍēśvara dēvara dēvasvada <gap reason="lost" quantity="8" unit="character"/> 
<lb n="4"/>sahā hoḷara sāvaṁtara gade 4 kkaṁ bittuva bede hāne 40 <gap reason="lost" quantity="5" unit="character"/> 
