<lb n="7"/> <gap reason="lost" quantity="5" unit="character"/> mūlaparicchēdavāgi koṭṭu hāge <gap reason="lost" quantity="5" unit="character"/> 
<lb n="8"/> <gap reason="lost" quantity="5" unit="character"/> sarada mū<unclear>ḍalu</unclear> magilu bāvi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="9"/> <gap reason="lost" quantity="5" unit="character"/> hariva vōṇiyiṁdaṁ mūḍalu baḍa <gap reason="lost" quantity="5" unit="character"/> 
<lb n="10"/> <gap reason="lost" quantity="5" unit="character"/> halasu māvu teṁginamara <gap reason="lost" quantity="10" unit="character"/> 
<lb n="11"/>mūḍalu Ayyabaḷiya narasiṁgaseṭṭi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="12"/>varagaḍiyiṁda paḍuvalu teṁkalu <gap reason="lost" quantity="5" unit="character"/> 
<lb n="13"/> <gap reason="lost" quantity="1" unit="character"/> gō <gap reason="lost" quantity="1" unit="character"/> makkiya heddāriya gaḍiyiṁ
<lb n="14"/> <gap reason="lost" quantity="1" unit="character"/> ṁtu catussīmeya voḷage Uḷa <gap reason="lost" quantity="2" unit="character"/> 
