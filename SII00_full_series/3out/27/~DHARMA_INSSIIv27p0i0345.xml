<lb n="11"/> <gap reason="lost" quantity="10" unit="character"/> mūḍalu gade 6 hā <gap reason="lost" quantity="5" unit="character"/> 
<lb n="12"/> <gap reason="lost" quantity="10" unit="character"/> ḍe gadeya voḷage <gap reason="lost" quantity="5" unit="character"/> 
<lb n="13"/> <gap reason="lost" quantity="10" unit="character"/> mā<unclear>vu</unclear> <gap reason="lost" quantity="10" unit="character"/> 
<lb n="14"/> <gap reason="lost" quantity="10" unit="character"/> rada śaṁkaradē <gap reason="lost" quantity="10" unit="character"/> 
<lb n="15"/> <gap reason="lost" quantity="10" unit="character"/> gaḍi hoṟa <gap reason="lost" quantity="10" unit="character"/> 
<lb n="16"/> <gap reason="lost" quantity="10" unit="character"/> hatta <gap reason="lost" quantity="10" unit="character"/> 
<lb n="17"/> <gap reason="lost" quantity="10" unit="character"/> 
