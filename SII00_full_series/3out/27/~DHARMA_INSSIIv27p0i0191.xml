<!--<h4>First piece.</h4>-->

<p>
<lb n="1"/> <gap reason="lost" quantity="5" unit="character"/> svastiśrī jayābhyu <gap reason="lost" quantity="5" unit="character"/> ruṣaṁgaḷū
<lb n="2"/>neya <hi rend="bold">krōdhi</hi> saṁvatsarada <hi rend="bold">kārttika</hi> <gap reason="lost" quantity="5" unit="character"/> śrīmanṁ mahārā<unclear>jā</unclear>
<lb n="3" break="no"/>dhi rāja rājaparamē <gap reason="lost" quantity="5" unit="character"/> <unclear>śi</unclear>va mahārāya <gap reason="lost" quantity="1" unit="character"/> 
<lb n="4"/> <gap reason="lost" quantity="1" unit="character"/> sadindalū śrī maṁnmahā<unclear>maṁḍalēśvara</unclear> <hi rend="bold">rā<unclear>marājaya</unclear></hi> mahā Arasugaḷu <gap reason="lost" quantity="2" unit="character"/> 
<lb n="5"/> <gap reason="lost" quantity="1" unit="character"/> darige ko<unclear>ṭṭaśāsa</unclear>na pūrvadalli <unclear>ni</unclear>mage <gap reason="lost" quantity="5" unit="character"/> <unclear>ci</unclear>kayanu Uṁ <gap reason="lost" quantity="1" unit="character"/> 
<lb n="6"/> <gap reason="lost" quantity="1" unit="character"/> kuṁ mā <gap reason="lost" quantity="3" unit="character"/> yeḷugare <gap reason="lost" quantity="10" unit="character"/> 
</p>

<!--<h4>Second piece.</h4>-->

<p>
<lb n="1"/>ṁda pāpake hōharu nāyamāṁsa
<lb n="2"/>tiṁda pāpake hōharu narakapāladalli
<lb n="3"/>sureya kasida pāpadali hōharu Ā
<lb n="4" break="no"/>va nānobbanu Āḷupikoṁḍavaru Ā nā <unclear>Iṁ</unclear>
<lb n="5" break="no"/>daranu <gap reason="lost" quantity="3" unit="character"/> ru Āvanānobbanu nā Iṁ
<lb n="6" break="no"/>dara sa<unclear>rva</unclear>māṁnyavāgi naḍasi koṁbaru Eṁdu<note n="314-1">The continuation is damaged.</note> 
</p>

