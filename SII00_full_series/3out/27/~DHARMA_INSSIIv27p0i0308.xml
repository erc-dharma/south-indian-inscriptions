<lb n="1"/><hi rend="bold">sakavarṣa 9<unclear>6</unclear>7</hi>
<lb n="2" break="no"/>neya <hi rend="bold">pārtthiva</hi>
<lb n="3"/><hi rend="bold">saṁvatsarada vaiśā</hi>
<lb n="4" break="no"/><hi rend="bold">kha suddha<unclear>ṣa</unclear>ṭṭi braha</hi>
</p>

<!--<h4>Second side.</h4>-->

<p>
<lb n="5" break="no"/><hi rend="bold">spativāradaṁdu Orvva</hi>
<lb n="6" break="no"/>ya hampācāri
<lb n="7" break="no"/>ya magaṁ Akkasāle
<lb n="8"/>candācāri cāgaramaru
</p>

<!--<h4>Third side.</h4>-->

<p>
<lb n="9"/>dharmmāṁbudhi
<lb n="10"/>navilaṁ pratiṣṭe
<lb n="11"/>geydaṁ maṁgaḷa <g type="ddanda">.</g>
</p>

<!--<h4>Fourth side.</h4>-->

<p>
<lb n="12"/>baynakula
<lb n="13" break="no"/>tilaka
