<lb n="1"/><hi rend="grantha">svastiśrī</hi> <supplied reason="undefined"><g type="danda">.</g></supplied> matirai koṇṭa kopparake<hi rend="grantha">sa</hi>ri<hi rend="grantha">panma</hi>rkku
<lb n="2"/>yāṇṭu Irupatāvatu vaṭakarai nalvayalūrkkūṟṟattu
<lb n="3"/>ttevatāṉa muṟṟumurc ciṟuttirukkoyil <hi rend="grantha">mahāde</hi>varkku
<lb n="4"/>Ivvūr vaṭaceri Uṭaiyā ṉilakaṇṭaṉ cāttaṉ kuṭut
<lb n="5" break="no"/>ta Āṭu toṇṇūṟu Ivaṉ kuṭutta ta<unclear>rā</unclear> nilai viḷakku
<lb n="6"/>niṟai Irunūṟṟuppala mivvāṭu koṇṭu nicatam Uḻakku <unclear>ney</unclear>
<lb n="7" break="no"/>yāl Oru nantāviḷakku <hi rend="grantha">cantrāditya</hi>vaṟ Erippomāṉom
<lb n="8"/>Uṟumur <hi rend="grantha">sabhai</hi>yom Itu <hi rend="grantha">panmāheśvara</hi>rira<hi rend="grantha">kṣai <g type="ddanda">.</g> §</hi>
