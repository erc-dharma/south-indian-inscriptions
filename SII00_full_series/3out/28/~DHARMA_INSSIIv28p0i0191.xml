<p>
<lb n="1"/><hi rend="grantha">§śubhamastu <supplied reason="undefined"><g type="danda">.</g></supplied> svasti <supplied reason="undefined"><g type="danda">.</g></supplied> śrī</hi>veṅkaṭateva<hi rend="grantha">mahā</hi>rāyar <hi rend="grantha">prithi</hi>vi<hi rend="grantha"> rājyam</hi> paṇṇi Aru
<lb n="2" break="no"/>ḷā niṉṟa cakāttam <num value="1510"><g type="numeral">1000</g> 5 <g type="numeral">100</g> <g type="numeral">10</g></num>ṉ mel cellā niṉṟa caṟuvatāri varu<hi rend="grantha">ṣa</hi>m mārkaḻi mātam
<lb n="3"/><hi rend="grantha"><num value="22">2 <g type="numeral">10</g> 2</num> nāḷ</hi> vai<unclear>yappa</unclear> <hi rend="grantha">kiṣṇa</hi>ppakkoṇṭama nāyakkar cuvāmi citampare<hi rend="grantha">śvara</hi>ṉukku Iru
<lb n="4" break="no"/>patu taḷikai naiyvettiyak kaṭṭaḷaiyiṭṭu Intap piṟacātam tiruvoṭṭu nāyamāṟ
<lb n="5" break="no"/>ku pikṣ<hi rend="grantha">ai</hi>yiṭak kaṭṭaḷaiyiṭṭapaṭikku kumutappaṭaiyil cilā<hi rend="grantha">sā</hi>taṉam paṇṇiṉa
<lb n="6" break="no"/>paṭi muṉṉāḷ tirukkoyilil Irācakarattu<hi rend="grantha">kk</hi>u patinta koṟṟu Ilakkai muṉṉūṟu
<lb n="7"/>poṉṉum citampa<hi rend="grantha">reśvara</hi>ṉu<hi rend="grantha">kk</hi>u caṟuvamāṉiyamāka tāraivāttuk kuṭuttu Intap poṉ
<lb n="8" break="no"/>ṉukku tiṉam Oṉṟu<hi rend="grantha">kku</hi> cuvāmiyāṟku Irupatu taḷikai koyil paṇṭārattile naiy
<lb n="9" break="no"/>vettiyam paṇṇi Iṉta Irupatu taḷikaiyu<hi rend="grantha">m</hi> tiruvoṭṭu nāyamāṟ<unclear>ku</unclear> tiṉam pi<hi rend="grantha">kṣai</hi>
<lb n="10"/>yiṭak kaṭṭaḷaiyiṭṭa paṭiyāle Intappaṭi Irupatu taḷikaiyu<hi rend="grantha">m</hi> naivettiyam paṇṇi
<lb n="11"/>pi<hi rend="grantha">kṣai</hi> naṭattivarakkaṭavarākavu<hi rend="grantha">m</hi> Intap puṇṇiyam yātoruvar paripālam paṇṇi
<lb n="12" break="no"/>ṉa per <hi rend="grantha">sahastra</hi>iliṅkappiṟatiṭṭai paṇṇiṉa puṇṇiyam Aṉupavikkakkaṭavarā 
<lb n="13" break="no"/>kavu<hi rend="grantha">m</hi> Inta taṉmattu<hi rend="grantha">kku</hi> yātāmoruvaṉ Akitam paṇṇiṉavaṉ keṅkaik ka
<lb n="14" break="no"/>raiyil kārām pacuvai koṉṟu mātoru kevaṉam paṇṇi
<lb n="15"/>ṉa to<hi rend="grantha">ṣa</hi>ttile pokakkaṭavaṉṉākavum §
</p>

