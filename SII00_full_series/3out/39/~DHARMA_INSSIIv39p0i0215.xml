<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrī mahāmaṇḍaleśva</hi>ra<hi rend="grantha">n ha</hi>rirāyavi<hi rend="grantha">bhā</hi>ṭa<hi rend="grantha">n ca</hi>
<lb n="2"/>tu<hi rend="grantha">ssamudrādhipa</hi>ti<hi rend="grantha"> pradhi</hi>vi<hi rend="grantha">rājyam pa</hi>ṇṇā ṉiṉṟa
<lb n="3"/>yuva<hi rend="grantha">sam</hi>varattu makaraṉāyaṟṟu pū<hi rend="grantha">rva</hi>pa<hi rend="grantha">kṣa</hi>ttu <hi rend="grantha">Aṣṭhami</hi>
<lb n="4"/>yum <hi rend="grantha">Aśva</hi>tiyum peṟṟa tiṅkaḷkiḻamai nāḷ <hi rend="grantha">ja</hi>
<lb n="5"/>yaṅkoṇṭa coḻamaṇṭalattu tāmalkoṭṭat
<lb n="6"/>tu tāmarṉāṭṭut tiruppati tiruppuḷkuḻiyil perumāḷ
<lb n="7"/>poreṟṟu nāyiṉāṟku tiruviḷakkut tiruppariva
<lb n="8"/>ṭṭam cāttuppaṭikkumāka Ivvūr <hi rend="grantha">sa</hi>tā <gap reason="lost" quantity="5" unit="character"/> kkuṭi
<lb n="9"/>yeṟaṉ kuṭiyeṟuṅkuṭi ce<unclear>ta</unclear>kuctaiyuḷpaṭa
<lb n="10"/>Āyamuḷḷatu Utaka<hi rend="grantha">pūrva</hi>kamāka Ellamaraca
<lb n="11"/>ṉiyorāl ca<hi rend="grantha">ndrāditya</hi>varaiyum cellum
<lb n="12"/>paṭi kuṭutteṉ kāñcikkuṟi vara<hi rend="grantha">da</hi>rā<hi rend="grantha">ja</hi>ṉeṉ Itu
<lb n="13"/>va<hi rend="grantha">radarājan dhammam</hi> I<hi rend="grantha">dhamma</hi>ttakku <hi rend="grantha">Ahi</hi>ta<hi rend="grantha">m</hi> ṉiṉai
<lb n="14"/>ttavaṉ <hi rend="grantha">ga</hi>ṅkaikkaraiyil kapilaiyai vayitta
<lb n="15"/>pāpaṅkoḷḷak kaṭavāṉākavum <hi rend="grantha">śubhamastu</hi>
</p>

