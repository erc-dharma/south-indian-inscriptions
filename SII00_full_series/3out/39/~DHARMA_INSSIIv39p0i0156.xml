<p>
<lb n="1"/>yāṇṭu Irupattāṟāvatu <hi rend="grantha">ja</hi>yaṅkoṇṭa coḻamaṇṭalattu tāmaṟko 
<lb n="2"/>ṭṭattu tāmaṟnāṭṭu vikkaramaciṅka <hi rend="grantha">śa</hi>tu<hi rend="grantha">rvve</hi>ti maṅkalattu <hi rend="grantha">sabhai</hi>kku camain=ta <gap reason="lost" quantity="3" unit="character"/> canṉayak k<hi rend="grantha">rama</hi>vittaṉu puta <gap reason="lost" quantity="5" unit="character"/> 
<lb n="3"/>kicca <hi rend="grantha">krama</hi>vittanum kuṇṭūr Appiyalaṭi tiruvottūr <hi rend="grantha">krama</hi>vittanu <hi rend="grantha">Uru</hi>ttirak <hi rend="grantha">krama</hi>vittanu puca <gap reason="lost" quantity="1" unit="character"/> nampirāṉ k<hi rend="grantha">rama</hi>vittanu kārampic
<lb n="4"/>ceṭṭu cannaya k<hi rend="grantha">rama</hi>vittaṉum <gap reason="lost" quantity="2" unit="character"/> ṅkaṉūrkkāmak koṭa <gap reason="lost" quantity="5" unit="character"/> k<hi rend="grantha">rama</hi>vittaṉum kārāmpicceṭṭu colaippirāṉ <hi rend="grantha">krama</hi>vittaṉum
<lb n="5"/>pippiri <hi rend="grantha">Uru</hi>tt<hi rend="grantha">ra</hi>naṉti <hi rend="grantha">krama</hi>vittaṉum vaṅkippuṟattu veṇṇaiyak <hi rend="grantha">krama</hi>vit
<lb n="6"/>taṉum putalikovi <gap reason="lost" quantity="2" unit="character"/> k<hi rend="grantha">krama</hi>vittaṉum Uḷḷiṭṭa <hi rend="grantha">sabhai</hi>yo<hi rend="grantha"> <gap reason="lost" quantity="10" unit="character"/> śvara <gap reason="lost" quantity="1" unit="character"/> </hi>mu <gap reason="lost" quantity="5" unit="character"/> <hi rend="grantha">dhama</hi>
