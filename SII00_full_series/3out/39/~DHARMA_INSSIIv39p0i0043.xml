<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrī tri</hi>puvaṉac cakkaravattikaḷ [<hi rend="grantha">śrī</hi>] Irācā<hi rend="grantha">dhi</hi>rā<hi rend="grantha">ja de</hi>vaṟku
<lb n="2"/>yāṇṭu Eḻāvatu rā<hi rend="grantha">ja</hi>rā<hi rend="grantha">ja</hi>pāṇṭi nāṭṭu rā<hi rend="grantha">je</hi>ntira coḻa
<lb n="3"/>vaḷanāṭṭu puṟamalaināṭṭu po<hi rend="grantha">nna</hi>marāpatiyil koḷaṉ
<lb n="4"/><unclear>tiru</unclear>koṭuṅkuṉṟa muṭaiyānāna ni<hi rend="grantha">ṣa</hi>yarā<hi rend="grantha">ja</hi>neñ Iṉāya
<lb n="5"/> <gap reason="lost" quantity="5" unit="character"/> tiru koḷakuṭi <hi rend="grantha">śi</hi>va<hi rend="grantha">dharmmiśva</hi>ra Uṭaiya <hi rend="grantha">mahāde</hi>vaṟ
<lb n="6"/>tirukoḷakuṭi vayalil paḻaiyatevatānam muṉṟa<supplied reason="omitted">ta</supplied> toṉṟu
<lb n="7"/>nikki niṉṟa nilam Aṭaṅka cūḻnta perunānkellaiuḷ A<unclear>ka</unclear>
<lb n="8"/><unclear>p</unclear>paṭṭa viḷainilam Oḻiviṉṟiye nirvāttu kallu veṭṭi ku
<lb n="9"/>ṭutteṉ Iṟaiyili tevatāṉamāka tirukkoṭuṅ kuṉṟamuṭai<unclear>y</unclear>ā
<lb n="10"/>nāna ni<hi rend="grantha">ṣa</hi>yarā<hi rend="grantha">ja</hi>nen tirukkoḷakuṭi nāyanāṟku paṉmā<hi rend="grantha">he</hi>
<lb n="11"/><hi rend="grantha">śva</hi>ra ra<hi rend="grantha">kṣai</hi>
</p>

