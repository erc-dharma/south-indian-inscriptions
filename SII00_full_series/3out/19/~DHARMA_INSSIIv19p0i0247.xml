<p>
<lb n="1"/><hi rend="grantha">svastiśrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> kopparakecaripa<hi rend="grantha">nma</hi>ṟkku yāṇṭu <num value="10"><g type="numeral">10</g></num>
<lb n="2" break="no"/>āvatu vaṭakarai tevatāṉa <hi rend="grantha">brahma</hi>teyam Ama
<lb n="3" break="no"/>ṉinā<hi rend="grantha">rā</hi>yaṇa<hi rend="grantha">cca</hi>tuṟ<hi rend="grantha">vve</hi>timaṅkalattu tiruvica
<lb n="4" break="no"/>lūrp perumāṉaṭikaḷukku <hi rend="grantha">ccantrā</hi>tittaval muṟaimai
<lb n="5" break="no"/>yāl Oru nontāviḷakku Erippataṟkku nicati Uḻakku
<lb n="6"/><unclear>n</unclear>eyyāl muṭṭāme Oru nilaiviḷakku Erippataṟkku
<lb n="7"/>caṅkarappāṭiyāṉ Iñcaṉ tiruvicallūraṉ vai
<lb n="8" break="no"/>tta Āṭu toṇṇūṟṟu muṉṟu Ivviḷakku paṉmā
<lb n="9" break="no"/><hi rend="grantha">heśvararakṣai <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied></hi> Ivaṉe vaitta ceppuviḷa<hi rend="grantha">kk</hi>u Oṉṟu <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
