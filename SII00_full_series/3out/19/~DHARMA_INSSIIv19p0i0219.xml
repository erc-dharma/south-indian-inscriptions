<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi> kopparakecarivarma<supplied reason="omitted">ṟ</supplied>ku yāṇṭu 9 Āva
<lb n="2" break="no"/>tu tirucceṅkoṭu tiruvoṇa<hi rend="grantha">kka</hi>ṇap peru ma<hi rend="grantha">kka</hi>ḷ
<lb n="3"/>kaiyil tiṅkaḷtoṟum Oḻu<hi rend="grantha">kka</hi>māka Irupatu <hi rend="grantha">brā</hi>
<lb n="4" break="no"/><hi rend="grantha">hma</hi>ṇarai ca<hi rend="grantha">ntrā</hi>tittaval niṉ<unclear>ṟa</unclear>tu cāṉṟāka Ūṭṭu
<lb n="5" break="no"/>vatāka Īroṭṭiru<hi rend="grantha">kk</hi>u maṇikaṇṭi Oṭaiyamantā 
<lb n="6" break="no"/>ḷu<hi rend="grantha">kkā</hi>ka Araṭṭaṉa<hi rend="grantha">kka</hi> makaṉ tiruvoṇa<hi rend="grantha">kka</hi>ṇapperuma<hi rend="grantha">kka</hi>ḷ
<lb n="7" break="no"/>vacam vaitta poṉ Irupatiṉ kaḻañcu poṉṉu
<lb n="8" break="no"/>ṅ koṇṭu Iruvatu <hi rend="grantha">brāhma</hi>ṇarai Ip poṉṉiṉ pa
<lb n="9" break="no"/>licai koṇṭu Ūṭṭuvatāka Eṉṟom tiruvoṇak<unclear>ka</unclear>
<lb n="10" break="no"/>ṇapperuma<unclear>kkaḷom</unclear> Itu Iṟakkuvā <gap reason="lost" quantity="4" unit="character"/> ttāṉa ma
<lb n="11" break="no"/>ṟuvāṉ kāttā<unclear>ṉaṭi</unclear> Eṉ talaimeliṉa <g ref="sym:doubleBar" type="punctuation">.</g><g ref="sym:dash-long" type="punctuation">.</g>
