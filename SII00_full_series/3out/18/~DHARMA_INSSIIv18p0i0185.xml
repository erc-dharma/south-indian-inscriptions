<p>
<lb n="1"/>svasti śrīmatu kaḷa
<lb n="2" break="no"/><unclear>ccu</unclear>ryyabhujabaḻaca
<lb n="3" break="no"/>kravartti rāyamurāri
<lb n="4"/>sōmēsvaradēvavarṣada <unclear>7</unclear> ne
<lb n="5" break="no"/>ya vijayasavvatsara puṣya
<lb n="6"/>ba cauti maṁgaḷavāramutta
<lb n="7" break="no"/>rāyaṇasaṁkrāntiyaṁdu
<lb n="8"/>śrīmatu ghaṭeya<unclear>masā</unclear>haṇi
<lb n="9"/>śrīmūlasthānadēvara brahma
<lb n="10" break="no"/>puriyāgi śrīdharabhaṭṭa<unclear>rggaṁ</unclear> 
<lb n="11"/>sivadēvabhaṭṭarggaṁ māṇi
<lb n="12" break="no"/>kēsvarada <unclear>kō</unclear>la mattaru 12
<lb n="13"/>haṁneraḍu 12 kayya nivēṣa<unclear>ṇa</unclear>
<lb n="14"/>ravidēvabhaṭṭarggaṁ mattaru 6 Ā
<lb n="15" break="no"/>ṟu 6 kayya nīvēṣaṇa yinti
<lb n="16" break="no"/>nitumaṁ dhārāpūrvvakaṁ
<lb n="17"/>māḍi sarvvanamasyavāgi <unclear>bi</unclear>
<lb n="18" break="no"/>ṭṭa dattiyiṁtī dharmmamaṁ <gap reason="lost" quantity="3" unit="character"/> 
<lb n="19"/>mukhyavāgi yeṁ<unclear>ṭu hi</unclear>
<lb n="20" break="no"/>ṭṭugaḷuṁ pratipāḷisu <gap reason="lost" quantity="2" unit="character"/> 
<lb n="21"/>teṁkaṇaholada <unclear>bo</unclear> <gap reason="lost" quantity="3" unit="character"/> 
<lb n="22"/>keyyiṁ baḍagaṇa sthaḷa <g ref="sym:doubleBar" type="punctuation">.</g> <gap reason="lost" quantity="3" unit="character"/> 
<lb n="23"/>viṣaṁ viṣamityāhu <gap reason="lost" quantity="3" unit="character"/> 
<lb n="24"/>ṁ viṣamucyatē viṣa <gap reason="lost" quantity="2" unit="character"/> 
<lb n="25"/>kinaṁ haṁti brahma <gap reason="lost" quantity="2" unit="character"/> 
<lb n="26"/><unclear>pu</unclear>trapautrakaṁ <g ref="sym:doubleBar" type="punctuation">.</g>
