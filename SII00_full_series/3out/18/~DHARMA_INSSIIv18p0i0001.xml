<!--<h4>First piece.</h4>-->

<p>
<lb n="1"/>jayatyāviṣkṛtaṁ vi <gap reason="lost" quantity="10" unit="character"/> 
<lb n="2"/>dakṣiṇōnnatadaṁ <gap reason="lost" quantity="10" unit="character"/> 
<lb n="3"/>svasti śrīmatāṁ saka <gap reason="lost" quantity="10" unit="character"/> 
<lb n="4"/>sagōtrāṇāṁ calukyānāṁ kula <gap reason="lost" quantity="10" unit="character"/> <note n="1-1">The syllable ṇāṁ is written below the line.</note>
<lb n="5"/>nuśāsati prajāḥ vikramākrā <gap reason="lost" quantity="10" unit="character"/> 
<lb n="6"/>thadigvijayasamanantaraṁ nānā <gap reason="lost" quantity="10" unit="character"/> 
<lb n="7"/>lē<unclear>bhyaḥ</unclear> kalisindavijñāpana <gap reason="lost" quantity="10" unit="character"/> 
<lb n="8"/>vantaṁ sarvvadikcakrēśva<unclear>ra</unclear>rama <gap reason="lost" quantity="5" unit="character"/> 
<lb n="9"/>bhṛtiṣvadhyakṣībhūtēṣu <gap reason="lost" quantity="10" unit="character"/> 
<lb n="10"/>bhidāyā<unclear>yāṁ</unclear> daṇḍa <gap reason="lost" quantity="10" unit="character"/> 
<lb n="11"/>rvvabādhaparihāra <gap reason="lost" quantity="10" unit="character"/> 
<lb n="12"/><unclear>triṁ</unclear>śaddēvagaṇikā <gap reason="lost" quantity="5" unit="character"/> 
<lb n="13"/><unclear>nnā</unclear>rāyaṇaprasā <gap reason="lost" quantity="10" unit="character"/> 
<lb n="14"/>raṁ vi <gap reason="lost" quantity="2" unit="character"/> ṇa <gap reason="lost" quantity="10" unit="character"/> 
<lb n="15"/><unclear>ta</unclear>sya kulōlla <gap reason="lost" quantity="10" unit="character"/> 
<lb n="16"/><unclear>yaḥ</unclear> yō rājanyaḥ <gap reason="lost" quantity="10" unit="character"/> 
<lb n="17"/>hārapūrvvaka <gap reason="lost" quantity="10" unit="character"/> 
<lb n="18"/><unclear>viṁ</unclear>ndantu <gap reason="lost" quantity="10" unit="character"/> 
</p>

<!--<h4>Second piece.</h4>-->

<p>
<lb n="1"/><unclear>mā</unclear>ditya satyā <gap reason="lost" quantity="10" unit="character"/> 
<lb n="2"/>mahārājādhi <gap reason="lost" quantity="10" unit="character"/> 
<lb n="3"/>rarā rājyaṁge <gap reason="lost" quantity="10" unit="character"/> 
<lb n="4"/>śrīma <gap reason="lost" quantity="10" unit="character"/> 
<lb n="5"/>mattamā <gap reason="lost" quantity="10" unit="character"/> 
<lb n="6"/>niḷipi <gap reason="lost" quantity="10" unit="character"/> 
</p>

