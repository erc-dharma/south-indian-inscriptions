<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śrī jayādbhudaya śālivā 
<lb n="2" break="no"/>hana śakavarṣaṁbulu 1474 Agu 
<lb n="3" break="no"/>nēṭi paridhāvi saṁvatsara kārttika śu 12 śannū 
<lb n="4"/>śrīmadrājādhirāja rājaparamēśvara śrīvīrapratā 
<lb n="5" break="no"/>pa śrīsadāśivadēvamahārāyalu pṛthvirājyaṁ 
<lb n="6"/>cēyucuṁḍagānu pinavaḍukūriki pratināmamai 
<lb n="7" break="no"/>na tiṁmasamudraṁ Agrahāraṁ lōpali hanumaṁtta 
<lb n="8" break="no"/>dēvara rāmēśvaruniki kāsyapagōtraṁ Āpastaṁ 
<lb n="9" break="no"/>ba sūtraṁ yajuśākhādhyāyulaina vipra 
<lb n="10" break="no"/>vinōdi pedakēśavayyagāri kumāruḍu kēśa 
<lb n="11" break="no"/>vayyanū Ā vallabhayyagāri kumāruḍu <unclear>ha</unclear> 
<lb n="12" break="no"/> <gap reason="lost" quantity="1" unit="character"/> vayyānū vuthānadvādaśi puṁṇyakāla <gap reason="lost" quantity="2" unit="character"/> 
<lb n="13"/> <gap reason="lost" quantity="1" unit="character"/> dēvuḷālu reṁṭikini kārtika śēva <gap reason="lost" quantity="3" unit="character"/> 
<lb n="14"/> <gap reason="lost" quantity="1" unit="character"/> <unclear>lu</unclear>gānu samasta vipravinōdula <gap reason="lost" quantity="5" unit="character"/> 
<lb n="15"/> <gap reason="lost" quantity="1" unit="character"/> ṁ pinavaḍugūri Agrahārā 
<lb n="16"/> <gap reason="lost" quantity="1" unit="character"/> rokhaṁ dhāravōsi yistiṁ <unclear>sa</unclear> <gap reason="lost" quantity="3" unit="character"/> 
<lb n="17"/> <gap reason="lost" quantity="1" unit="character"/> pūrvakaṁgānu trivācākṛ <gap reason="lost" quantity="5" unit="character"/> 
<lb n="18"/> <gap reason="lost" quantity="1" unit="character"/> ka vipravinōdivāramellā <gap reason="lost" quantity="5" unit="character"/> 
<lb n="19"/> <gap reason="lost" quantity="1" unit="character"/> patyaṁgānu Ācaṁdrārka <gap reason="lost" quantity="5" unit="character"/> 
<lb n="20"/> <gap reason="lost" quantity="1" unit="character"/> gānunu naḍapuka rāga <gap reason="lost" quantity="10" unit="character"/> 
<lb n="21"/> <gap reason="lost" quantity="1" unit="character"/> nyaṁgānu naḍavuka rāga <gap reason="lost" quantity="5" unit="character"/> 
<lb n="22"/> <gap reason="lost" quantity="1" unit="character"/> naku yavvaru tappinānu tappinā <gap reason="lost" quantity="10" unit="character"/> 
<lb n="23"/> <gap reason="lost" quantity="1" unit="character"/> ṇāsilōnu vadhiyiṁcina pāpā <gap reason="lost" quantity="5" unit="character"/> 
<lb n="24"/>śunakamāṁsaṁ surāpānaṁ sēviṁ <gap reason="lost" quantity="5" unit="character"/> 
<lb n="25"/> <gap reason="lost" quantity="1" unit="character"/> na bōduru mātrugamanaṁ cēsina <gap reason="lost" quantity="5" unit="character"/> 
<lb n="26"/> <gap reason="lost" quantity="1" unit="character"/> dharmmānaku tapinavāni Ālikini <gap reason="lost" quantity="5" unit="character"/> 
<lb n="27"/> <gap reason="lost" quantity="1" unit="character"/> nu goḍugubaṭevāḍe magaḍu yi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="28"/> <gap reason="lost" quantity="1" unit="character"/> vinōdi dharmmaśāsanaṁ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> dānapā <gap reason="lost" quantity="5" unit="character"/> 
<lb n="29"/> <gap reason="lost" quantity="1" unit="character"/> dānācchrēyōnṛpālanaṁ dānā <gap reason="lost" quantity="2" unit="character"/> 
<lb n="30"/> <gap reason="lost" quantity="1" unit="character"/> pālanādacyutaṁ padaṁ [<g ref="sym:bar" type="punctuation">.</g>] svadattāṁ <gap reason="lost" quantity="5" unit="character"/> 
<lb n="31"/> <gap reason="lost" quantity="1" unit="character"/> yō harēti vasuṁdharāṁ ṣaṣṭhi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="32"/>ṣṭhāyāṁ jāyatē krimi <g ref="sym:doubleBar" type="punctuation">.</g> 
</p>

