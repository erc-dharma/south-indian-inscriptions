<p>
<lb n="1"/><hi rend="grantha">śubhama</hi>[ <hi rend="grantha">s</hi>tu*] <hi rend="grantha">E</hi>ta<hi rend="grantha">t śāsa</hi>na<hi rend="grantha">mā<unclear>d</unclear>dyasya Ira</hi>vi<hi rend="grantha">mvammaśvarasya ca Ādi caṇḍeśvarākje</hi>ya<hi rend="grantha">m</hi>
<lb n="2"/><hi rend="grantha">svastiśrīman mahāmaṇḍaleśvaran</hi> Arikararāyavipāṭaṉ pā<hi rend="grantha">ṣai</hi>kkuttappuvarāyar kaṇṭa<supplied reason="omitted">ṉ</supplied>
<lb n="3"/>kaṇṭaṉāṭukoṇṭu koṇṭaṉāṭu koṭātāṉ pūṟuva<hi rend="grantha">dakṣi</hi>ṇapaccima Uttaracamutiṟātipati Emmaṇṭalamum tiṟaikoṇṭa
<lb n="4"/>Irācātirācaṉ Irācaparame<hi rend="grantha">śva</hi>ra<hi rend="grantha">n</hi> Īḻam tiṟaikoṇṭu kecaveṭṭaikaṇṭaruḷiya ciṟivirappiratāpa
<lb n="5"/><hi rend="grantha">bhujabā</hi><note n="536-2">Unfinished.</note> 
