<lb n="3"/><seg rendition="class:nāgarī maturity:undetermined"> <gap reason="lost" quantity="5" unit="character"/> līga lī pānīyārthaṁ </seg>
<lb n="4"/><seg rendition="class:nāgarī maturity:undetermined"> <gap reason="lost" quantity="3" unit="character"/> kīrti <gap reason="lost" quantity="5" unit="character"/> śathā </seg>
<lb n="5"/><seg rendition="class:nāgarī maturity:undetermined">kala <gap reason="lost" quantity="5" unit="character"/> śālo hi kī </seg>
<lb n="6"/><seg rendition="class:nāgarī maturity:undetermined">hā <gap reason="lost" quantity="2" unit="character"/> ṣa <gap reason="lost" quantity="5" unit="character"/> yīśa </seg>
<lb n="7"/><seg rendition="class:nāgarī maturity:undetermined">pāti <gap reason="lost" quantity="3" unit="character"/> bho<unclear>ga</unclear> <gap reason="lost" quantity="3" unit="character"/> </seg>
