<lb n="1"/><hi rend="grantha">svastiśrī <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi> matiraikoṇṭa kopparake<hi rend="grantha">sa</hi>ri varmaṟku yāṇṭu <num value="39">3 <g type="numeral">10</g> 9</num> Āvatu tiruveḷḷaṟai tiruvāṉai
<lb n="2" break="no"/>kkallil <hi rend="grantha">bha</hi>ṭṭārakar Uccampotu Amutu ceyumpotu ve<hi rend="grantha">da</hi>m vallāriruvar
<lb n="3"/><hi rend="grantha">brāhma</hi><unclear>ṇa</unclear>rai Ūṭṭuvataṟku Ivūr
<lb n="4"/>kāccuvaṉ kecuvaṉ turkkaṉeṉ Ivūrk kallāl kaḻañcu perttatu <num value="140"><g type="numeral">100</g> 4 <g type="numeral">10</g></num>m nūṟṟuṉāṟpatiṉ kaḻañcu poṉṉilāl
<lb n="5"/>palicai <unclear>kāl</unclear> kāṇattāl muṉṉāḻi paḻavariciyu muḻakkup paruppum kāykkaṟiyum puḷiṅkaṟiyum poṟikkaṟiyum Iviraṇṭu vāḻai
<lb n="6" break="no"/>ppaḻamum tayir Irunāḻiyum neyyāḻākkumāka Ippaṭi yūṭṭuvomāṉo<hi rend="grantha">m de</hi>varkanmikaḷōm mulapariṭaiyār <supplied reason="undefined"><g type="ddanda">.</g></supplied>
