<!--<h4>First fragment.</h4>-->

<p>
<lb n="1"/><unclear>Ōdu</unclear> <gap reason="lost" quantity="2" unit="character"/> lliyavārisatrakkaṁ Ōduva vidyārtthimāṇigaḷiga<unclear>veṁdu</unclear> <gap reason="lost" quantity="5" unit="character"/> 
<lb n="2"/>duva paṟekāṟargge biṭṭanintī dharmmaṁ saluttamiraleḍeya <unclear>Anta</unclear>rāya <gap reason="lost" quantity="3" unit="character"/> 
<lb n="3"/>palakālaṁ keṭṭirddudaṁ Ade<unclear>ntene</unclear> samadhigatapaṁcamahāśabdamahāma <gap reason="lost" quantity="2" unit="character"/> 
<lb n="4"/>śvaraṁ kaliyammarasar cāḷukyavikramavarṣada 10 neya krōdhana saṁ <gap reason="lost" quantity="2" unit="character"/> 
<lb n="5"/>rada pauśya suddha paṁcami sōmavāra Uttarāyaṇa saṁkramaṇadaṁdu rāja <gap reason="lost" quantity="1" unit="character"/> 
<lb n="6"/>ni kalyāṇada nelevīḍinoḷu sukhasaṁkathāvinōdadiṁ rājyaṁgeytuttirddu <gap reason="lost" quantity="3" unit="character"/> 
<lb n="7"/> <gap reason="lost" quantity="5" unit="character"/> kravartti tribhuvanamalladēvargge binnapaṁgeydu paṁcapra <gap reason="lost" quantity="5" unit="character"/> <note n="72-1">Continuation is lost.</note>
</p>

<!--<h4>Second fragment.</h4>-->

<p>
<lb n="1"/> <gap reason="lost" quantity="5" unit="character"/> prayāgeyoḷu sāsirakavileyaṁ <gap reason="lost" quantity="5" unit="character"/> 
<lb n="2"/> <gap reason="lost" quantity="10" unit="character"/> raciyisi sāsirvvarvvēdapāragarappa brā <gap reason="lost" quantity="5" unit="character"/> 
<lb n="3"/> <gap reason="lost" quantity="5" unit="character"/> puṇyamakkumidanaḷidavaninitumanaḷida mahāpā <gap reason="lost" quantity="2" unit="character"/> 
<lb n="4"/> <gap reason="lost" quantity="5" unit="character"/> <g type="ddanda">.</g> ślōka <g type="ddanda">.</g> svadattaṁ paradattaṁ vā yō harēti vasunddharā śaṣṭhi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="5"/> <gap reason="lost" quantity="1" unit="character"/> haśrāṇi viṣṭhāyāṁ jāyatē kṛmiḥ <g type="ddanda">.</g> © <g type="ddanda">.</g>
</p>

