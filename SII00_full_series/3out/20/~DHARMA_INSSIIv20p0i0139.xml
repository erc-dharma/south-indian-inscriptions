<lb n="6" break="no"/> <gap reason="lost" quantity="1" unit="character"/> nimittavāgi śrīmattarddavāḍisā
<lb n="7" break="no"/> <gap reason="lost" quantity="1" unit="character"/> sirada sādaverggaḍe Ayitara
<lb n="8" break="no"/> <gap reason="lost" quantity="1" unit="character"/> sa sōvarasanuṁ kaḍalevāḍada
<lb n="9"/> <gap reason="lost" quantity="1" unit="character"/> śrī svayaṁbhu sōmanāthadēvara pura
<lb n="10" break="no"/> <gap reason="lost" quantity="1" unit="character"/> <unclear>da</unclear> Āḍu kuṟeyokkalasādamaṁ dēvara ha
