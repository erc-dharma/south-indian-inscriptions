<lb n="13" break="no"/> <gap reason="lost" quantity="1" unit="character"/> <unclear>ga</unclear>kkaṁ dhūpadīpa nivēdyakkaṁ dhārā
<lb n="14" break="no"/> <gap reason="lost" quantity="1" unit="character"/> pūrvvakaṁ māḍi koṭṭaru
<lb n="15"/> <gap reason="lost" quantity="1" unit="character"/> sōmēśvarapaṁḍitargge
<lb n="16"/> <gap reason="lost" quantity="1" unit="character"/> maṁgaḷa mahā śrī
<lb n="17"/> <gap reason="lost" quantity="1" unit="character"/> I dhammakkārānuṁ Aḍḍaṁ baṁdavaru Aynū
<lb n="18" break="no"/> <gap reason="lost" quantity="1" unit="character"/> rvva svāmigaḷgidirādavaru <g ref="sym:doubleBar" type="punctuation">.</g>
