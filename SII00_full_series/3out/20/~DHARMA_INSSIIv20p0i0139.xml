<lb n="2"/> <gap reason="lost" quantity="1" unit="character"/> hārājādhirāja śrīmatribhuvanaikanijabhu
<lb n="3" break="no"/> <gap reason="lost" quantity="1" unit="character"/> <unclear>ja</unclear> vīramalladēva varṣada citrabhānu saṁvatsara
