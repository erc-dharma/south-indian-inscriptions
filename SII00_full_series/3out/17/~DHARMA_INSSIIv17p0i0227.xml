<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g type="ddanda">.</g></supplied> śrīcakrēśa paramēṣṭivimānakalgham śrīman parā</hi>
<lb n="2" break="no"/><hi rend="grantha">śarasunirmmitamaṇḍapasya <supplied reason="undefined"><g type="danda">.</g></supplied> kō<unclear>ta</unclear>cōḷakēṣṭaka vimā</hi>
<lb n="3" break="no"/><hi rend="grantha">na vidhikramēṇa śēntana pōyakāpati śilāmaya <unclear>kṛ</unclear></hi>
<lb n="4"/><hi rend="grantha">ta vimānam <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">Uṭaiyār śrī Ati</seg><hi rend="grantha">rājēntra dē</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">varkku yā</seg>
<lb n="5" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṇṭu</seg> <hi rend="grantha">2</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">Āvatu</seg> <hi rend="grantha">rājēṅtra</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">coḻavaḷanāṭṭup paṉaiyūr nāṭṭu poyyā</seg>
<lb n="6" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kkatt</seg><hi rend="grantha">u</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kkuṭippaḷḷi kumārice</seg><hi rend="grantha">nta</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṉāna jayaṅkoṇṭa coḻa viḻuppa</seg>
<lb n="7" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">raiya nāṭāḻavāṉa</seg><note n="83-1">Incomplete.</note> 
</p>

