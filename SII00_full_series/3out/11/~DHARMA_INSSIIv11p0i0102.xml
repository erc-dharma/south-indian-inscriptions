<div type="edition" xml:lang="kan-Latn" rendition="class:kannada maturity:undetermined">

<!--<h4>First Face.</h4>-->

<p>
<lb n="1"/>© namastasmaivarāhāya līḷāyā caratē mahīṁ
<lb n="2"/>khurā(ṁ)ntaragatō yasya mērōḥ khaṇakaṇā
<lb n="3" break="no"/>yatē © svastisamastabhuvanāśraya śrī pri
<lb n="4" break="no"/>thvīvallabha mahārājādhirāja paramēśvara para
<lb n="5" break="no"/>mabhaṭṭārakaṁ satyāśrayakuḷatiḷakaṁ
<lb n="6"/>cāḷukyābharaṇaṁ śrīmattraiḷōkyama
</p>

<!--<h4>Second Face.</h4>-->

<p>
<lb n="7" break="no"/>lladēvara vijayarājyamuttarōttarābhivri<unclear>ddhi</unclear>
<lb n="8"/>varddhamānamācaṁdrārkkatāraṁbaraṁ saluttu<unclear>mi</unclear>
<lb n="9" break="no"/>re tattaneyaṁ svasti samadhigatapañcamahā <gap reason="lost" quantity="2" unit="character"/> 
<lb n="10"/>mahāmaṇḍaḷēśvaraṁ veṁgīpuravarēśvaraṁ samara <gap reason="lost" quantity="1" unit="character"/> 
<lb n="11"/>caṇḍa kumaramārttaṇḍa parakarimadani <gap reason="lost" quantity="1" unit="character"/> 
<lb n="12"/>raṇa(ṁ) nammanagandhavāraṇaṁ parivāranidhā <gap reason="lost" quantity="3" unit="character"/> 
</p>

<!--<h4>Third Face.</h4>-->

<p>
<lb n="13"/>kānīnaṁ hayavatsarājaṁ rūpamanōja <gap reason="lost" quantity="1" unit="character"/> 
<lb n="14"/>punṛpatihṛdayasellaṁ bhuvanaikamallaṁ <gap reason="lost" quantity="1" unit="character"/> 
<lb n="15"/> <gap reason="lost" quantity="1" unit="character"/> ḷi<note n="99-2">The inscription stops here</note>
</p>

