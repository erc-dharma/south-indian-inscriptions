<lb n="1"/><hi rend="grantha">svastiśrī <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi> kopparakecari<hi rend="grantha">panma</hi>rāṉa <hi rend="grantha">śrī</hi> Uttamacoḻatevaṟku yāṇṭu patiṉaiñ <gap reason="lost" quantity="8" unit="character"/> 
<lb n="2"/>koṭṭattu tirumayāṉappuṟattu kaṭavuḷ <hi rend="grantha">sabhai</hi>yom k<hi rend="grantha">ai</hi>yeḻuttu nam pirāṭṭiyār <gap reason="lost" quantity="8" unit="character"/> 
<lb n="3"/><unclear>nā</unclear>makaḷ nāṭṭaṭi<unclear>kaḷ</unclear> kaiyā<unclear>le</unclear> yāṅkaḷ koṇṭu kaṭava poṉ <hi rend="grantha">dharmma</hi>kaṭṭaḷai <gap reason="lost" quantity="8" unit="character"/> 
<lb n="4"/>ṟai muppatiṉ kaḻañcu poṉ koṇṭu kaṭavom Ippoṉṉukku palicai <gap reason="lost" quantity="8" unit="character"/> 
<lb n="5"/>tirumayāṉattu <hi rend="grantha">brahmiśvara</hi>ttāḻvāṟku Oru nan=tāviḷakkiṉukku nicatam <gap reason="lost" quantity="8" unit="character"/> 
<lb n="6"/>ṇ pākkattuḷ niṉṟār nāḻiyāl Aṭṭuvomāṉom kaṭavuḷ <hi rend="grantha">sabhai</hi>yom <gap reason="lost" quantity="8" unit="character"/> 
<lb n="7"/><hi rend="grantha">dhanmāsa</hi>ṉa muḷḷiṭṭa tāṉ veṇṭu kovukku nicatam nālekāle kāṇam taṇ <gap reason="lost" quantity="8" unit="character"/> 
<lb n="8"/>ttom Ittaṇṭa miṟuttum Iveṇṇai ca<hi rend="grantha">ntrā</hi>titavaṟ Aṭṭuvomāṉom <hi rend="grantha">sabh<unclear>ai</unclear> <gap reason="lost" quantity="8" unit="character"/> </hi>
<lb n="9"/>tukku virotam coṉṉom keṅkaiyiṭai kumariyiṭai ceytār ceyta pāvattu <gap reason="lost" quantity="8" unit="character"/> 
<lb n="10"/>ṭavuḷ <hi rend="grantha">sabhai</hi>yom <hi rend="grantha">sabhai</hi> paṇikka paṇi keṭṭu Eḻutiṉeṉ Ivūr ma<hi rend="grantha">dhyasta</hi>ṉ poccakkuṟi <gap reason="lost" quantity="8" unit="character"/> 
