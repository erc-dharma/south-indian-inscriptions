<lb n="1"/>U cālivākaṉa cakā(pi)ttam <hi rend="grantha">1</hi>
<lb n="2" break="no"/><num value="775">7 <g type="numeral">100</g> 7 <g type="numeral">10</g> 5</num> kaliyukā(pi)ttam <hi rend="grantha"><num value="48">4 <g type="numeral">10</g> 8</num></hi>
