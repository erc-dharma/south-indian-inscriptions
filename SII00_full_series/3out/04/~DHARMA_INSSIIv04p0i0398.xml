<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">U svasti śrīḥ <supplied reason="undefined"><g type="ddanda">.</g></supplied> śamkhatīrttha</hi>
<lb n="2" break="no"/><hi rend="grantha">miti khyātaṁ kamalālaya</hi>
<lb n="3" break="no"/><hi rend="grantha">maddhyagam <g type="danda">.</g> vanmīkasaṁbhavasyā</hi>
<lb n="4" break="no"/><hi rend="grantha">gre sarvarogakṣayāpa</hi>
<lb n="5" break="no"/><hi rend="grantha">ham <g type="danda">.</g> [<g type="danda">.</g>1*]sarvavyādhiharañcai</hi>
<lb n="6" break="no"/><hi rend="grantha">va kṣīrakuṇḍamidam śubham <g type="danda">.</g> hī</hi>
<lb n="7" break="no"/><hi rend="grantha">nāṁgo vyādhitāmgo vā yo</hi>
<lb n="8" break="no"/><hi rend="grantha">trasnānam kariṣyati <g type="danda">.</g> [<g type="danda">.</g> 2*] caitraśu</hi>
<lb n="9" break="no"/><hi rend="grantha">ddhe nirāhāraḥ citrasaṁsthe</hi>
<lb n="10"/><hi rend="grantha">niśākare <g type="danda">.</g> sampūrṇāmgassa</hi>
<lb n="11"/><hi rend="grantha">tejasvī bhaviṣyati na saṁśayaḥ [<g type="ddanda">.</g> 3*]</hi>
</p>

