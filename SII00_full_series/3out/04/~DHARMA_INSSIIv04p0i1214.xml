<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/> <gap reason="lost" quantity="10" unit="character"/> kṣiptapadāraviṁdaḥ <g ref="sym:bar" type="punctuation">.</g> Ā<unclear>sī</unclear> <gap reason="lost" quantity="5" unit="character"/> 
<lb n="2"/>kulāvataṁsaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 1*] gajarāmaviyaccaṁdragaṇitē śakavatsarē <g ref="sym:bar" type="punctuation">.</g> nṛtyatpratipa <gap reason="lost" quantity="2" unit="character"/> drūpaṁ bhīmaṁ śrīmatparāṁtakaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 2*] tā 
<lb n="3" break="no"/>ṇḍavalīlāratayē haviṣē balyarcanāvidhānāya <g ref="sym:bar" type="punctuation">.</g> sīlābhidhānamasmai grāmaṁ prādātsasarvvakaraparihāraṁ [<g ref="sym:doubleBar" type="punctuation">.</g> 3*] nṛttakrīḍāvi
<lb n="4" break="no"/>ratavavuṣō dēvadēvasya pārśvēḥ kṛtvā dēvyākṣitidharagurōḥ putrikāyāḥ pratiṣṭhāṁ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> tatpūjārtthaṁ tvaparamadiśatpaṇḍru<unclear>vā</unclear>
<lb n="5" break="no"/>ḍābhidhānaṁ grāmaṁ grāsīkṛtaripukulassōyamācaṁdratāraṁ [<g ref="sym:bar" type="punctuation">.</g> 4*] tasyaiva mārggaśīrṣē dēvasyārdrōtsavasya <unclear>vi</unclear>dhēḥ <g ref="sym:bar" type="punctuation">.</g> Ōracivāḍābhi
<lb n="6" break="no"/>hitaṁ grāmaṁ prādātsa Ēva nṛpaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 5*] dēvyāptvāśvayujē māsi pūrvvaphalgunarikṣakē <g ref="sym:bar" type="punctuation">.</g> yatkāryyamutsavavaraṁ tadhartthaṁ śrīpa
<lb n="7" break="no"/>rāṁtakaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 6*] bhīmēśakramukavanālipālikai<supplied reason="omitted">r</supplied>yō dēya<supplied reason="omitted">ḥ</supplied> syātpratisamamaṁtarāyasaṁjñaḥ <g ref="sym:bar" type="punctuation">.</g> taṁ kāraṁ samadiśadārkkacaṁdra
<lb n="8" break="no"/>tāraṁ lakṣmīvānakhilajagatprasiddhakīrttiḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 7*] likhitaṁ ḍākarēmi surācari Ayina vīrarājēṁdracōḍa Ācāryyaḥ <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
</p>

