<p>
<lb n="1"/><note n="423-1">Some lines at the beginning of the inscription are lost.</note> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ppattarāttaṭṭam cantirātittavaṟ ce <gap reason="lost" quantity="1" unit="character"/> vum Uṇṇavu</seg>
<lb n="2" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">m maṭamaḻivu ceyyum <unclear>ti</unclear>rukkāḷatti Uṭaiyāṉāna palaviḷakku p</seg>
<lb n="3" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">paricārarvacam Iṭṭoma cā <gap reason="lost" quantity="1" unit="character"/> Ā</seg><hi rend="grantha">sam</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ñai</seg><hi rend="grantha">ḥ bahubhirvasu</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tā</seg> <hi rend="grantha">da</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tt<choice><sic>a</sic><corr>ā</corr></choice></seg> <hi rend="grantha">ba</hi>
<lb n="4" break="no"/><hi rend="grantha">hubhiścānupālitā <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> yasya yasya yadā bhūmi<supplied reason="omitted">ḥ</supplied> tasya tasya tadā palam [*] svada</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">t</seg> 
<lb n="5" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tā</seg><hi rend="grantha">m paradattām vā yo hareta vasu[(m)ndharām <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> ṣa*]ṣṭivaruṣasaha</hi>
<lb n="6" break="no"/><hi rend="grantha">srāṇi viṣṭāyām jāyate kyami<supplied reason="omitted">ḥ</supplied> <g ref="sym:doubleBar" type="punctuation">.</g></hi> <tlka/>
