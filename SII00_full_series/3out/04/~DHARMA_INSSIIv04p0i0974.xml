<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/> <gap reason="lost" quantity="5" unit="character"/> madastaṁbha caturttakulavanajavanamārttaṁḍa vēṁgīviṣayaṣōḍaśasahasrāvanīvallabha sahakāravallabha Āhavarakkasa vikramakarkaśa <gap reason="lost" quantity="5" unit="character"/> 
<lb n="2"/>paraśu<unclear>rā</unclear>ma bhaṁḍanabhīma daḷadaṁkarāmi kāmijanakusumabāṇa śaraṇāgata prāṇatrāṇa pekkaṁḍranokkettugaṁḍa vihitāhitānē<unclear>ka</unclear> <gap reason="lost" quantity="5" unit="character"/> 
<lb n="3"/> <gap reason="lost" quantity="5" unit="character"/> kamahārājula talli śrīguṁḍamāṁbikāmahādēvi danaku dhammārtthamugānu śrī śakavarṣamulu 1054 gu nēṁṭi Uttarāyanasaṁkrāṁti <gap reason="lost" quantity="10" unit="character"/> 
<lb n="4"/> <gap reason="lost" quantity="5" unit="character"/> na Ī Akhaṁḍadīpamulu reṁṭikini nitya Aḍḍeṁḍu neyi vōyaṁgalavāṁḍu Ī kommanabōyuni bautrulu gōmmanabōyu <gap reason="lost" quantity="5" unit="character"/> 
<lb n="5"/> <gap reason="lost" quantity="5" unit="character"/> danapāliki Ēṁṭāpa<unclear>dē</unclear>ṁdumu pōyu<unclear>vāṁ</unclear>ḍu vīralu Evvarūnu <unclear>ka</unclear>dupuṁ <unclear>baṁ</unclear>cikonaṁbaḍayaru pottuna nā<unclear>ca</unclear> <gap reason="lost" quantity="5" unit="character"/> <note n="318-2">To the proper left of this inscription is found the fragment— 

<l n="4:318:974:1"> <gap reason="lost" quantity="5" unit="character"/> tanmukhātsaṁbabhūvuḥ</l>

<l n="4:318:974:2"> <gap reason="lost" quantity="5" unit="character"/> tatsaṁtatau janitō jaga</l>

<l n="4:318:974:3"> <gap reason="lost" quantity="3" unit="character"/> tā śrīvallabhaprasādaṁ naya</l>

<l n="4:318:974:4"> <gap reason="lost" quantity="5" unit="character"/> ṁAkhaṁḍāya nṛsiṁhākhya-</l></note>
</p>

