<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> kopparakecaripa<hi rend="grantha">nmarā</hi> ṉa <hi rend="grantha">śrīrājendra</hi> coḷa<hi rend="grantha">de</hi> varkku yāṇṭu 3<g type="dash"/>Āvatu Uṭaiyār <hi rend="grantha">śrīrājarājade</hi> varkku yāṇṭu <num value="29">2 <g type="numeral">10</g> 9</num>- patā<unclear>mā</unclear>ṇṭu <hi rend="grantha">śrī</hi>i<hi rend="grantha">rājarājade</hi>va<hi rend="grantha">-</hi> nampirāṭṭiyār tan=ti cattiviṭaṅkiyārāṉa Olokama<hi rend="grantha">hāde</hi> viyār rā<hi rend="grantha">jendrasiṁ ha</hi>vaḷanāṭṭu maṇṇi <gap reason="lost" quantity="3" unit="character"/> 
<lb n="2"/><hi rend="grantha">hmade</hi> yam vempaṟṟūrākiya Avaṉinārāyaṇaccatu<hi rend="grantha">rvvedi</hi> maṅkalattut tiruvicalūruṭaiya ma<hi rend="grantha">hāde</hi> var koyilil Innampirāṭṭi<unclear>yār</unclear> Olokama<hi rend="grantha">hāde</hi> viyār <hi rend="grantha">hraṇyagerbha</hi> m pukkaruḷiṉa poṉṉil Uyyakkoṇṭārvaḷanāṭṭup pāmpūrnāṭṭut tirukkuṭamukkil <gap reason="lost" quantity="3" unit="character"/> 
<lb n="3"/>lañcuḻi Inṉampirāṭṭiyār Eṭuppi<supplied reason="omitted">t</supplied>taruḷiṉa tirukkaṟṟaḷik <hi rend="grantha">kṣetra</hi> pāla<hi rend="grantha">de</hi> varkku cārttiyaruḷak kuṭutta poṟpū Iraṇṭil poṟpū Oṉṟināl kuṭiñaikkallāl niṟai poṉ Irukaḻañce mukkāle mañcāṭiyum Aṟumāvum poṟpū Oṉṟiṉāl meṟpaṭi kallāl ni<note n="130-2">The inscription is built in below and at the right end.</note> <gap reason="lost" quantity="3" unit="character"/> 
