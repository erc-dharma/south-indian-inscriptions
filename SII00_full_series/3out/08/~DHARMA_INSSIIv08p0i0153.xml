<lb n="2"/><hi rend="grantha">śrī</hi>ariyaṇṇauṭaiyār <hi rend="grantha">pṛthi</hi>vi<hi rend="grantha">rājyam</hi> paṇṇiaruḷāniṉṟa <hi rend="grantha">śakā<unclear>bda</unclear>m <num value="12"><g type="numeral">10</g> 2</num><unclear>9</unclear>9</hi>- l mel cellā
