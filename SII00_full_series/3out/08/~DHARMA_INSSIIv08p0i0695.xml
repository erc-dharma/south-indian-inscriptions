<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> maturaikoṇṭa koppara<hi rend="grantha">keśa<unclear>ri</unclear></hi>
<lb n="2" break="no"/>va<hi rend="grantha">nma</hi> ṟ kiyāṇṭu <num value="17"><g type="numeral">10</g> 7</num><g type="dash"/>Āvatu Ivvāṇṭu Uṟaiyūrkkūṟṟa
<lb n="3" break="no"/>ttu Allūr Ūrom Eṅkaḷur Allūrnakkar koyil <hi rend="grantha">mahād<unclear>e</unclear></hi>
<lb n="4" break="no"/>varkku Eṅkaḷūrc ciṟukkaḷañceri paṇṭu viḷaintaṟiyāk kaḷar kaṟaiya
<lb n="5" break="no"/><unclear>ṉ</unclear>koḷḷi nilattai tevarkku Ūrom tevatāṉamāka <hi rend="grantha">Udakapūrvva ñce</hi>
<lb n="6" break="no"/>ytukuṭutta nilam Āna nilat<unclear>ti</unclear>ṉ kiḻakkellai Eṟuka
<lb n="7" break="no"/>lmukattukkup poṉa vaḻikku mekkum teṟkiṉukku Ellai puḷi
<lb n="8" break="no"/>yaṉ pa<unclear>racu</unclear>rāmaṉ vaṭavaikkum ciṟiyāṉ kuṇamanta<unclear>ra</unclear>ṉ vaṭavai
<lb n="9" break="no"/><unclear>k</unclear>ku maṟṟum Oḻinta nilattukku vaṭakku mekkiṉuk kellai ve
<lb n="10" break="no"/>ṭṭaṅ kaṇṭaṉuñ ciṅka ṉīlaṉum nāṭṭiyattār nilattukkuk <unclear>ki</unclear>ḻak
<lb n="11" break="no"/>kum vaṭakkiṉuk kellai vaṭakaḷark ko<unclear>nila</unclear>t torumā varaikkum
<lb n="12"/>kāḷiyār tuṭavaikku maṟṟu moḻinta nilattukkum Eṭṭa<unclear>ṉ ṉi</unclear>lattu
<lb n="13" break="no"/>kkut teṟku mivvicaitta perunāṉkellaiuḷ ḷakappaṭṭa Uṇṇila
<lb n="14" break="no"/>moḻiviṉṟi Ikkaḷarai Allūrnakkar koyil <hi rend="grantha">mahāde</hi> varkku k<unclear>e</unclear>nna
<lb n="15" break="no"/>ṭaippuṟamāka <hi rend="grantha">de</hi> vatāṉañ ceytukuṭuttom Allūrūrā yi<unclear>c</unclear>ain<unclear>ta</unclear> Ū
<lb n="16" break="no"/>rom<supplied reason="undefined"><g type="danda">.</g></supplied>ūreva Eḻutiṉeṉum Ippaṭi Oṭṭi Iṭṭukkuṭutteṉu
<lb n="17" break="no"/>m puḷiyam paracirāmaṉe ṉivai Eṉ ṉeḻuttu <g type="ddanda">.</g><g type="dashLong">.</g>i<unclear>v</unclear>yāṇṭu parake
<lb n="18" break="no"/>carikkup patiṉeḻil Īṇṭupuka ḻallūrā rīcaṉukku veṇṭi
<lb n="19" break="no"/>ya vāriñilamā vayakkik koḷḷac ciṟukkaḷañceri ñilañ ceytār ti
<lb n="20" break="no"/>raṇṭu <g type="ddanda">.</g> <hi rend="grantha">I</hi>tu<hi rend="grantha"> panmā heśvara rirakṣai <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi>
