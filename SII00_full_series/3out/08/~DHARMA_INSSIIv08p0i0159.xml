<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti [śrī <g type="ddanda">.</g>*] śrīmanmahāmaṇḍaliśvaran ha<unclear>ri</unclear>rāyavibhāṭan bhāṣai</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kku tappuvairāya<unclear>raka</unclear>ṇṭaṉ muvarāyarakaṇṭaṉ</seg> <hi rend="grantha">pūrvvadakṣiṇapaścima<unclear>samudrādhipa</unclear></hi>
<lb n="2" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ti I</seg><hi rend="grantha">rājādhirāja paramēśvara</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">śrīvīratevarāyamakār<unclear>ā</unclear>yaṉ kumārar vīravijaya</seg><hi rend="grantha">bhūpati-</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">rāyauṭaiyar</seg> <hi rend="grantha">pṛthi</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vīrā</seg><hi rend="grantha">jyam</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">paṇṇiaruḷāniṉṟa</seg> <hi rend="grantha">śakābdam 1<unclear>33</unclear>5</hi>
<lb n="3"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṉmel cellāniṉṟa</seg> <hi rend="grantha">vijayasamvatsara</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttu makaranāyaṟṟu</seg> <hi rend="grantha">pūrvvapakṣa</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttu</seg> <hi rend="grantha">paurṇai</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">yum veḷḷikkiḻamaiyum peṟṟa puṇarpūcattu nāḷ</seg>
<lb n="4"/><hi rend="grantha"><unclear>śrī</unclear>vasiṣṭhagōtra</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttu</seg> <hi rend="grantha">bhūpati</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">rāyauṭaiyar</seg> <hi rend="grantha">ma</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">hā</seg><hi rend="grantha">pra</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tāṉar cavuṇṭappuṭaiyar kumārar Aṉṉatātauṭaiyar Uṭaiyār tiruvaṇṇāmalaiuṭaiya <unclear>n</unclear>āyanāṟku I</seg>
<lb n="5" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṭṭa tirununtāviḷakku Oṉṟukku viṭṭa kaṉṟuttāy pacu muppattiraṇṭum Iṣapam Oṉṟum cantiṟātittavaraiyum naṭakka<supplied reason="omitted">k</supplied>kaṭavatu Ākavum <supplied reason="undefined"><g type="danda">.</g></supplied> Itu paṉ</seg><hi rend="grantha">mā</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">he</seg><hi rend="grantha">śvara ra</hi>
<lb n="6" break="no"/><hi rend="grantha">kṣai <g type="pc"/> mauliś</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">lā</seg><hi rend="grantha">ghyē śakābdē vijayasamabhidhē vatsarē vāsarē<unclear>śē</unclear> nakrasthē paurṇamāsyāmaditibhasahitē kāvyavārē sa</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ho</seg><hi rend="grantha">kṣṇā <supplied reason="undefined"><g type="ddanda">.</g></supplied> dvātrimśat samkhya dhēnūraruṇagiriśi<unclear>v</unclear>ā</hi>
<lb n="7" break="no"/><hi rend="grantha">yānnadātā guṇāḍhyō vāsiṣṭhō nityadīpaṁ viracayi<unclear>tu</unclear>madāccauṇḍapāmbhōdhicandraḥ <g type="pc"/></hi>
