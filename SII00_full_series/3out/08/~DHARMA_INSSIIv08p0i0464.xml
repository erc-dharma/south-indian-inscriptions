<p>
<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> tribhu</hi>vana ccakkaravattikaḷ <hi rend="grantha">śrīrājarājade</hi> vaṟku yāṇṭu patiṉoṉṟāva<unclear>tu</unclear>
<lb n="2"/><hi rend="grantha">ja</hi>yaṅkoṇṭacoḻama<hi rend="grantha">ṇḍa</hi> lattut tiruveṅkaṭakkoṭṭattu <unclear>Ā</unclear>ṟṟūrnā
<lb n="3" break="no"/>ṭṭut tirukkāḷattiyāṉa mummuṭicoḻapurattu nāyaṉār tirukkāḷattiuṭaiya nāya
<lb n="4" break="no"/>ṉāṟku Ikkoṭṭattu kuṭavūrnāṭṭil peruril Irukkum puliyaṉ makaṉ pūva
<lb n="5" break="no"/>neṉ vaitta cantiviḷakku Oṉṟukku nāyanār tiruviḷakku<supplied reason="omitted">k</supplied>kuṭikaḷi<unclear>l ma</unclear>
<lb n="6" break="no"/>ṉṟāṭi k<unclear>āri</unclear> cāttaṉ tirukkāḷattikkoṉum citti<unclear>ra</unclear>meḻikkoṉār ma <gap reason="lost" quantity="2" unit="character"/> 
<lb n="7"/>yaṇakkoṉum kaiy<unclear>k</unclear>koṇṭa paḻaṅkācu <hi rend="grantha">[<num value="12"><g type="numeral">10</g> 2</num>]</hi> Ippaḻaṅkācu <unclear>paṉ</unclear> <gap reason="lost" quantity="1" unit="character"/> 
<lb n="8"/>ttil Irukkum mākalaikkoṉ kaiyyile kācu Ai<supplied reason="omitted">ñ</supplied>cum kuṭuttu veṇṭu <gap reason="lost" quantity="2" unit="character"/> 
<lb n="9"/>cantirātittavarai ney Aḷakka<supplied reason="omitted">k</supplied>kaṭavutāka cammatittu kaiy<supplied reason="omitted">k</supplied>koṇṭom <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
