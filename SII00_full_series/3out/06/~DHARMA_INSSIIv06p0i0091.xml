<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śākābdē yugabāṇakhēṁdugaṇi
<lb n="2" break="no"/>tē caitrē śubhē vaiṣuvē kālē bo
<lb n="3" break="no"/>ddanamaṇḍalēśvarasutōmalyēśvarā
<lb n="4" break="no"/>yādarāt <g ref="sym:bar" type="punctuation">.</g> khēḍaṁ prādiśadiddhakīrtti 
<lb n="5" break="no"/>subhagō lōkāṁbakānaṁdanō bhī
<lb n="6" break="no"/>maśśatrubhayaṁkarō vijayavāṭākhya
<lb n="7" break="no"/>ṁ puraṁ siddhayē <g ref="sym:doubleBar" type="punctuation">.</g> śrīcōḍavaṁśābdhi
<lb n="8" break="no"/>sudhākarōbhūdvēṁggīpati<supplied reason="omitted">ḥ</supplied> śrītri
<lb n="9" break="no"/>purāṁtakākhyaḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> tasmācca karnnāṭaka
<lb n="10" break="no"/>bhūbhujāccha labdhaṁ puraṁ bōddananā
<lb n="11" break="no"/>yakēna <g ref="sym:doubleBar" type="punctuation">.</g>
<lb n="12"/>taṁ bhīmadēvō viditaprabhāvassa
<lb n="13" break="no"/>mādiśaddēvavarāya bhuktyai Āca
<lb n="14" break="no"/>ṁdratārārkkamaniṁdyakīrtirmmallēśva
<lb n="15" break="no"/>rāyākhilavairimallaḥ <g ref="sym:doubleBar" type="punctuation">.</g>
<lb n="16"/>svadattāṁ paradattāṁ vā yō harēta
<lb n="17"/>vasuṁ<unclear>dha</unclear>rāṁ <g ref="sym:bar" type="punctuation">.</g> ṣaṣṭiṁ varṣasaha
<lb n="18" break="no"/>srāṇi viṣṭhāyāṁ jāyatē
<lb n="19"/>krimiḥ <g ref="sym:doubleBar" type="punctuation">.</g>
</p>

