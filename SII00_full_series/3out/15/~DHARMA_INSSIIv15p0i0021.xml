<lb n="1"/>svasti śrīmaccāḷukya jagadēka <unclear>malladēvavarṣada</unclear> 3 ne
<lb n="2" break="no"/>ya raudri saṁvatsarada Uttarāyaṇa śaṁ
<lb n="3" break="no"/>kramāṇadaṁdu śrī telli<unclear>gēśvaradēva</unclear>ra
<lb n="4"/>śrīgaṁdhakke Ūra harggaḍe <gap reason="lost" quantity="5" unit="character"/> 
<lb n="5"/>daṇḍanāyakaru biṭṭa <gap reason="lost" quantity="5" unit="character"/> 
<lb n="6"/>Īnti pindu honnappu <gap reason="lost" quantity="5" unit="character"/> 
<lb n="7"/>radhikārigaḷirddalli śrī <gap reason="lost" quantity="10" unit="character"/> 
<lb n="8"/>sāsirvvaruṁ priya <gap reason="lost" quantity="5" unit="character"/> 
<lb n="9"/>saru tamma dharmmavāgi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="10"/>varu Īntī dharmmavaṁ prati <gap reason="lost" quantity="5" unit="character"/> 
<lb n="11"/>ge gaṁge vāraṇāsi kuru <gap reason="lost" quantity="10" unit="character"/> 
<lb n="12"/>ge Arghyatīrtthaṁgaḷeṁba puṇyatīrttha <gap reason="lost" quantity="5" unit="character"/> 
<lb n="13"/>kavileya suvarṇnadalu <gap reason="lost" quantity="10" unit="character"/> 
<lb n="14"/>ra vēdapāragarappa brāhmaṇarige koṭṭa <gap reason="lost" quantity="5" unit="character"/> 
<lb n="15"/>vanaḷidavargge mahāpuṇya tīrtthada <gap reason="lost" quantity="5" unit="character"/> 
<lb n="16"/>ra kavileyuṁ sāsira vēdapāra <gap reason="lost" quantity="10" unit="character"/> 
<lb n="17"/>da paṁcamahāpātakanakku <g ref="sym:doubleBar" type="punctuation">.</g>
