<lb n="14" break="no"/> <gap reason="lost" quantity="10" unit="character"/> roḷu sukasaṁkathā vinōdadiṁ vijaya
<lb n="15" break="no"/> <gap reason="lost" quantity="10" unit="character"/> ya saṁvatsaraṁ 1045 neya śōbhakri
<lb n="16" break="no"/> <gap reason="lost" quantity="10" unit="character"/> tatpuṇyadinadoḷu pradhānara pra
