<lb n="18" break="no"/> <gap reason="lost" quantity="10" unit="character"/> ri bhaṭṭa grāmada bhāradvāja
<lb n="19"/> <gap reason="lost" quantity="10" unit="character"/> lāḷa sandhivigrahi
<lb n="20"/> <gap reason="lost" quantity="10" unit="character"/> pāḷayya nāya
<lb n="21" break="no"/> <gap reason="lost" quantity="10" unit="character"/> vantāgi ca
