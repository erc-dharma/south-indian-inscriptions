<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">śrī</hi>cōḻaṉṟalai koṇṭa kōvīrapāṇṭiyaṟku yāṇṭu nāṉku Itaṉe<supplied reason="omitted">ti</supplied> rañcu <gap reason="lost" quantity="3" unit="character"/> 
<lb n="2"/>vāṇṭu paruttikkuṭi nāṭṭu tēvatāṉamn tiruccuḻiyal pa<unclear>ḷḷi</unclear>
<lb n="3" break="no"/>paṭaic cuntarapāṇṭiya Ī<hi rend="grantha">śva</hi>varattu tēvaraṭiyāḷ tē<unclear>va</unclear>ṉ karutāccilaikka <gap reason="lost" quantity="3" unit="character"/> 
<lb n="4"/>ti makaḷ kāviti kaṇaipeṟṟāḷ makaḷ nanti caṭaiyam paṭāri
<lb n="5"/>mēṟpaṭiyūr niti peṟṟāḷ Ivaḷ makaḷ kāviti tāṅki <gap reason="lost" quantity="3" unit="character"/> 
<lb n="6"/>makkaḷum mēṟpaṭi tēvaraṭiyār nakkañ caṭaiyam kulu <gap reason="lost" quantity="3" unit="character"/> 
<lb n="7"/>Āccaṉ <gap reason="lost" quantity="3" unit="character"/> kuluṅkāvilai nakkaṉ kuluṅkāvilai taṉṉiccai <gap reason="lost" quantity="3" unit="character"/> 
<lb n="8"/>mēṟpaṭi kuluṅkāvilai kuṇacīlaṉ kaṇṭaṉ vi <gap reason="lost" quantity="4" unit="character"/> 
</p>

