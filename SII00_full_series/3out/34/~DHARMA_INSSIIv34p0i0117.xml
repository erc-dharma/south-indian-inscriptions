<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/>kōvirā<hi rend="grantha">ja</hi>kēcari paṉmaṟkku yāṇṭu 5
<lb n="2"/>Āvatu teṉkaraiy <hi rend="grantha">brahmade</hi>yam <hi rend="grantha">śrī</hi>kaṇṭa <hi rend="grantha">śca</hi>tu<hi rend="grantha">rvve</hi>ti maṅkalattu tirumalai mēl <hi rend="grantha">mahāde</hi>
<lb n="3" break="no"/>varkku Ivvūrt tāyaṉ kaṇamuṭaiyāṉ Oru nontā viḷakku Erippataṟkku nicati Uḻakku neykku
<lb n="4"/>vaitta nilam Ivvūrakavāy vaṉṉiccuṟṟil mūṉṟu māvum Itiṉ mēlai yiraṇṭumāvum
<lb n="5"/>Ar<hi rend="grantha">ai</hi>caṅkaḷattuk kīḻaiyar<hi rend="grantha">ai</hi>māvum Ikkaḷattukku teṉ mēlai yarai<unclear>māvum</unclear>
<lb n="6"/>Āka Ivvaṟumāc ceyyum no<hi rend="grantha">ndā</hi>viḷakkerippataṟkku vaittu Iṉṉilattu <unclear>Iṟai</unclear>
<lb n="7"/>kāval <hi rend="grantha">sabhai</hi>yāṟkkup poṉ kuṭuttu Itiṉ palicaiyā liṟaiyum <hi rend="grantha">sāma <gap reason="lost" quantity="3" unit="character"/> </hi>kā
<lb n="8" break="no"/>ttuk kuṭuppārāka vaittēṉ tāyaṅkaṇamuṭaiyānēṉ Itu pa<hi rend="grantha">nmāheśva</hi>
<lb n="9" break="no"/><hi rend="grantha">ra rakṣai <g type="ddanda">.</g><g type="dashLong">.</g></hi>
</p>

