<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/>kōvirā<hi rend="grantha">ja</hi>kēcaripaṉmakkuyāṇṭu <num value="19"><g type="numeral">10</g> 9</num> Āvatu teṉkarai
<lb n="2"/><hi rend="grantha">brahmade</hi>yam <hi rend="grantha">śrī</hi>kaṇṭa <hi rend="grantha">śca</hi>tu<hi rend="grantha">rvvedi</hi> maṅkalam yāḷuṅkaṇattāruḷ timmikuṭi
<lb n="3" break="no"/>ttimmikuṭikiḻāṉ Ākā<hi rend="grantha">tya</hi>ṉ nārāyaṇaṉakkaṉ <hi rend="grantha">brāhma</hi>ṇi tattan cēntiyēṉ I
<lb n="4" break="no"/>vvūr tirumalaimēl <hi rend="grantha">Ādi</hi>tta<hi rend="grantha">bhaṭṭāra</hi>karkku nān Eṭuppitta tirukkōyil <hi rend="grantha">de</hi>varkku tiru 
<lb n="5" break="no"/>vamutukku tiruviḷakkukkum neyamutukkumāka vaitta nilamāvatu Ivvūrakavā
<lb n="6" break="no"/>yiṉ veṅkūr nālāṅkaṇṇāṟṟuk kīḻ catirattu ppattām pāṭakam vaṉpā
<lb n="7"/>kkattu tiruva<supplied reason="omitted">ra</supplied>ṅka cōmāciyār Uḷḷiṭṭa <hi rend="grantha">dvādaśa</hi>kka maṟumāc ceyyum <hi rend="grantha">sabhai</hi>
<lb n="8" break="no"/>yāṟkku Iṉṉilattukku Iṟaikāval patiṉ kaḻaiñcu poṉṉum kuṭuttu
<lb n="9"/>Ivvaṟumāc ceyyum Iṟaikāttuk kuṭuppōmāṉōm peruṅkuṟi <hi rend="grantha">sabhai</hi>
<lb n="10" break="no"/>yō<unclear>m</unclear> nārāyaṇaṉakkaṉ <hi rend="grantha">brāhma</hi>ṇi tattañ cēntikku Itu <hi rend="grantha">panmāheśvara rakṣai <g type="ddanda">.</g><g type="dashLong">.</g></hi>
</p>

