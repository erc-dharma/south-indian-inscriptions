<p>
<lb n="1"/><hi rend="grantha">Uttavēdinamīśānannirggamēśañca sundaram <g type="danda">.</g></hi>
<lb n="2"/><hi rend="grantha">kṣēkupālam rathēśānama kriṣṇagōpālamachyutam <g type="danda">.</g></hi>
<lb n="3"/><hi rend="grantha">śivalōkēśvaram kāmayōgēśvaramataḥ param <g type="danda">.</g></hi>
<lb n="4"/><hi rend="grantha">gōpuramgōvimuktiśam śitkōṭīśvaram param <g type="danda">.</g></hi>
<lb n="5"/><hi rend="grantha">durgāmṛṛdvāhanāthañca tataḥ pratyurgamēśvarama <g type="danda">.</g></hi>
<lb n="6"/><hi rend="grantha">kautukēśam samāsādhya punarjjamannavidyatē <g type="ddanda">.</g></hi>
<lb n="7"/><hi rend="grantha">Ityāgnēya purāṇē <gap reason="lost" quantity="6" unit="character"/> </hi>
<lb n="8"/><hi rend="grantha"> <gap reason="lost" quantity="6" unit="character"/> bikāpa <gap reason="lost" quantity="6" unit="character"/> </hi>
<lb n="9"/><hi rend="grantha"> <gap reason="lost" quantity="6" unit="character"/> ṇayanē <g type="ddanda">.</g></hi> 
