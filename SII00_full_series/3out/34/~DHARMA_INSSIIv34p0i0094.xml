<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti <supplied reason="undefined"><g type="ddanda">.</g></supplied> samasta bhuvanāśraya śrīpṛthvī vallabha ma</hi>
<lb n="2" break="no"/><hi rend="grantha">hārājādhīrāja paramēśvara dvāravati puravarā</hi>
<lb n="3" break="no"/><hi rend="grantha">dhīśvara yādava kulāmbaradyumaṇi sarvvajña cūḍāma</hi>
<lb n="4" break="no"/><hi rend="grantha">ṇī malarājarāja malaparuḷara gaṇḍara dana pracaṇḍa</hi>
<lb n="5" break="no"/><hi rend="grantha">gaṇḍa bhērunēkāṅga vīra nṛsahāya śraraśanivā</hi>
<lb n="6" break="no"/><hi rend="grantha">ra siddhigiri durga malla ca<unclear>lē</unclear>daṅgarāma vairibhakaṇṭhi</hi>
<lb n="7" break="no"/><hi rend="grantha">ravamagadharājya nirmmūlana pāṇḍya kula samuddhara</hi>
<lb n="8" break="no"/><hi rend="grantha">ṇacōḷarājya pratiṣṭhācārdhya nissaṅgapratāpa</hi>
<lb n="9"/><hi rend="grantha">ccakra</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vartti</seg> <hi rend="grantha">pōśaḷa śrīvīrasōmīśvara dēvarasa</hi>
<lb n="10" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">r</seg> <hi rend="grantha">kāmadavalli</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">yil tirukkāṟkōṭī</seg><hi rend="grantha">śva</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ra muṭaiyār</seg>
<lb n="11"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kōyil tāṉattārku vaṇṇa<unclear>mā</unclear>ṉa maturāntaka</seg>
<lb n="12"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">nallūr kākavākaivāyiluṭai yāṇṭāṉum</seg>
<lb n="13"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tāṅkaḷum coṉṉa <unclear>kā</unclear>vaḻakku nam muṉṉāka kē</seg>
<lb n="14" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṭṭa Iṭattu Ivaṉukkup pirāttiyillātapa</seg>
<lb n="15"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṭiyālē nālāvatu varaiyum Aṉupavittu</seg> 
<lb n="16"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vantapaṭiyē Aiñcāvatu mutal tirunāmat</seg>
<lb n="17" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tukkāṇi Āka Aṉusarippārākac coṉō</seg>
<lb n="18" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">m I<supplied reason="omitted">p</supplied>paṭi ceyka kūcaril Ariyaṇṇaṉaiyum ci</seg>
<lb n="19" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṅkaṇṇaṉaiyum pērākak kāṭṭiṉōm Ivai</seg>
<lb n="20" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ca</seg><hi rend="grantha">kra</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vartti Eḻuttu vallāḷap perumāḷ Eḻu</seg>
<lb n="21" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttu Ivai perumāḷ tēvar tampi Āṇ</seg>
<lb n="22" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṭar Eḻuttu <supplied reason="undefined"><g type="ddanda">.</g></supplied></seg>
</p>

