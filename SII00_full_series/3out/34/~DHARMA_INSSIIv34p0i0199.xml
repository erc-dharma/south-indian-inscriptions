<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrī<unclear>siddhārthi</unclear></hi>varu<hi rend="grantha">ṣam</hi> puraṭṭāci
<lb n="2"/>nāḷ <hi rend="grantha">ja</hi>ciṅka kulakāla vaḷanāṭṭu teṉpa
<lb n="3" break="no"/>ṉaṅkāṭṭu nāṭṭup peruṅkaḷūr Iraṇṭu
<lb n="4"/>pakuti Ūrāka Icainta Ūṟkaṇmāḷaṟku
<lb n="5"/> <gap reason="lost" quantity="11" unit="character"/> 
<lb n="6"/>ṇmāḷaril kaliyārāyattaṭṭā<unclear>ṉ makaṉ cā</unclear> <gap reason="lost" quantity="9" unit="character"/> 
<lb n="7"/>Uḷḷiṭṭārōm Āciriya <hi rend="grantha">bramā</hi><unclear>ṇam</unclear> <gap reason="lost" quantity="10" unit="character"/> 
<lb n="8"/> <gap reason="lost" quantity="2" unit="character"/> paricāvatu Iṉṉāḷ mutal <gap reason="lost" quantity="6" unit="character"/> Eṅkaḷai [kā
<lb n="9" break="no"/>ttu] nōkkippōtak kaṭava <gap reason="lost" quantity="3" unit="character"/> ṭattu
<lb n="10"/>nōkkum Iṭattu <gap reason="lost" quantity="3" unit="character"/> riyārku tiru <gap reason="lost" quantity="4" unit="character"/> 
<lb n="11"/> <gap reason="lost" quantity="11" unit="character"/> 
<lb n="12"/>vāṅkikoṇṭu Itu tāḻvu <gap reason="lost" quantity="10" unit="character"/> vārkaḷākavum Ippaṭi cammatittu
<lb n="13"/>Āciriyappiramāṇam paṇṇikkuṭuttōm peruṅkaḷūr Iraṇṭu
<lb n="14"/>pakuti Ūṟku camainta Ūr kaṇmāḷarku kalirāyattaṭṭāṉ
<lb n="15"/>makaṉ cāttaṉ Uḷḷiṭṭārrōm Ippaṭi cāttaṉ Uḷḷiṭṭār coṟpaṭi
<lb n="16"/> <gap reason="lost" quantity="11" unit="character"/> 
</p>

