<lb n="1"/><hi rend="grantha">svastiśrī</hi> nanti<hi rend="grantha">pa<supplied reason="omitted">nma</supplied></hi>rā<hi rend="grantha">ja</hi>ṟku yāṇṭu Irupattiraṇṭāvatu tiruvaiykāvu
<lb n="2"/>ṭaiya <hi rend="grantha">mahāde</hi>vaṟku tirunon=tāviḷakkum Amutupaṭikkum U<unclear>paiya</unclear>m vai
<lb n="3" break="no"/>ykka cantippeliyār tiripuvaṉamātēvic caruppētimaṅkalat
<lb n="4"/>tu <hi rend="grantha">sabh</hi>aiyārpakkal poṉ kuṭuttup polik kūlikkuc cela
<lb n="5" break="no"/>vākak kācu koḷḷā Ūṟkiḻ Iṟaiyiliyāka maṇalīṭil <gap reason="lost" quantity="6" unit="character"/> vēliyākak koṇṭu viṭṭa vaṇṇakka viḷākam nilam <hi rend="grantha">1(1/2)</hi> Iṉṉilam Oṉṟa
<lb n="6" break="no"/>raiyum Iṟakkātān tiruvaṭi Iraṇṭu mentalaimēlaṉa Itu Iṟakkuvān taṅka
<lb n="7"/>ḷammaikkut tānēy miṇāḷaṉ <g type="danda">.</g><g type="danda">.</g><g type="danda">.</g><g type="dashLong">.</g> Itu kalveṭṭuppaṭi <g type="danda">.</g><g type="danda">.</g><g type="danda">.</g><g type="dashLong">.</g> 
