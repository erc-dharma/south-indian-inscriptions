<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrī tribhu</hi>vana<unclear>ca</unclear> <hi rend="grantha">kra</hi>vattikaḷ maturaiyum Īḻamum pāṇṭiyan muṭittalaiyuṅ karuvūrum koṇṭu vīra Api<hi rend="grantha">ṣE</hi>kamum vi<hi rend="grantha">ja</hi>ya <gap reason="lost" quantity="3" unit="character"/> 
<lb n="2"/>mpirāṉ talaikkāvuṭaiyāṉ tirucciṟṟampala nampiyum kā<hi rend="grantha">śya</hi>paṉ tiruvaraṅka nārāyaṇaṉ ciri <hi rend="grantha">kṛṣṇa</hi>ṉāṉa vikkirama cōḻappirammārāyaṉum vācciyaṉ tiru <gap reason="lost" quantity="6" unit="character"/> 
<lb n="3"/>tirattu nilam <gap reason="lost" quantity="5" unit="character"/> Ivvūr kā<hi rend="grantha">śyapan</hi> ca<hi rend="grantha">ntra</hi>cēkaraṉ tiru nīla kaṇ<hi rend="grantha">ṭha</hi>rṟāṉa cī kurukūr nampi pakkal koṇṭa cūriya tēva vatikkuk kiḻakku kaṟṟaḷi <gap reason="lost" quantity="3" unit="character"/> 
<lb n="4"/>ṟku nālāṅ kaṇṇāṟṟu nālāñ catirattu nilam <hi rend="grantha">pa</hi> Āka nilam mukkālē Iraṇṭu mākkāṇik kīḻ mukkālē mummāvaraiyum Iṉ <gap reason="lost" quantity="9" unit="character"/> 
<lb n="5"/>ṭuttōm Itta <gap reason="lost" quantity="2" unit="character"/> ttu ta<hi rend="grantha">pasya</hi>kuṉikkum pirāṉ tōḻaṉāṉa Āṭaviṭaṅkappirāṉum tillai nāyakaṉ mātēvaṉum Ivvi <gap reason="lost" quantity="10" unit="character"/> 
</p>

