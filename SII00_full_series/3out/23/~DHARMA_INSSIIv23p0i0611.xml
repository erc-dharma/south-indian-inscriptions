<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">Utbhrāmyadraṇaraṅga raṅgada suhṛt sāmanta simantinī simanta gṛṛhacitra citralatikā tāḍaṅga pu <gap reason="lost" quantity="3" unit="character"/> </hi>
<lb n="2"/><hi rend="grantha">vyāptavyōma digantakānti pimalādityāvanīśātmaja śśrīmaa gōpuramēta dūrjita guṇa</hi>
<lb n="3" break="no"/><hi rend="grantha">ssōmiśvarō cakravat <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi>
<lb n="4"/><hi rend="grantha">trailōkyōdara pirabhūpa pimukhasvairābhidhārā <gap reason="lost" quantity="2" unit="character"/> dvāraśrīgaṇakābhujāṅga nijadōrdaṇḍārjitākhaṇḍabhūḥ</hi>
<lb n="5"/><hi rend="grantha">śrīmatpōttapicōḷa vamśatilaka ssōmiśvara śśāśvatam prōḍām vyūḍadayāgu ṇaśśataguṇām puṣṇā</hi>
<lb n="6" break="no"/><hi rend="grantha">ti viṣṇō śriyam <g type="ddanda">.</g></hi>
</p>

