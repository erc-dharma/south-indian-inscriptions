<lb n="2" break="no"/>rā<hi rend="grantha">ja</hi>rā<hi rend="grantha">jade</hi>vaṟku yāṇṭu <num value="26">2 <g type="numeral">10</g> 6</num> vatu Uṭaiyār mayintī<hi rend="grantha">śvaram</hi> Uṭaiyār
<lb n="3"/>kku vāṇiyaṉ Arumpāk kiḻā<unclear>n</unclear> nāyaṉen En makan cāmāḻvān pammāḻvāṉuk
<lb n="4" break="no"/>ku meṉikkum naṉṟāka Innāyaṉāṟku vaicca tirunantāviḷakku 1kku nāṉ kuṭutta pon
<lb n="5"/> <gap reason="lost" quantity="10" unit="character"/> kaṭaveṉ Ippaṭi ya<unclear>ṟi</unclear>ve<unclear>ṉ</unclear> tillaimūvvāyiranam<unclear>pi</unclear> pon<unclear>ṉā</unclear>ḻvāṉukku 
<lb n="6" break="no"/>m Aṇukka nampi periyanāyaṉ ciṟunāyan poṉṉāḻvā <gap reason="lost" quantity="2" unit="character"/> 
<lb n="7" break="no"/>kkum Upayamāka <unclear>I</unclear>veri kīḻ caṇṭecurap peruvilai
<lb n="8" break="no"/>yāka Uttamamāka cetuviṭa ponṉaṟa Iṭṭu maṇṇaṟak
<lb n="9"/>koṇṭu viṭṭen Itu māṟṟuvāṉ <hi rend="grantha">gaṅ</hi>kaik karaiyil kurāṟ
<lb n="10"/>pacu koṉṟa pāvaṅ koḷvān <hi rend="grantha">śrīmāheśvara rakṣai</hi>
