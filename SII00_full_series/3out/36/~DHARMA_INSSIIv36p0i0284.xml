<lb n="3" break="no"/>ṉmarāṉa tiripuvaṉac cakkarava
<lb n="4" break="no"/>ttikaḷ Emmaṇṭalamum koṇṭa 
<lb n="5" break="no"/>ruḷiya <hi rend="grantha">śrī</hi> cuntarapāṇṭiyate
<lb n="6" break="no"/>vaṟku yāṇṭu <hi rend="grantha"><num value="14"><g type="numeral">10</g> 4</num> ma</hi>ka<hi rend="grantha">ra</hi> nāyaṟ
