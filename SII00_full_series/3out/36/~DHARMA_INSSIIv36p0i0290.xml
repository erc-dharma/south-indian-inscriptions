<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrī</hi> tiruvāykkeḻvi muṉṉā
<lb n="2" break="no"/>ka <hi rend="grantha">śrī</hi> koṟcaṭapaṉmarāna tiripuvaṉac cakkaravat
<lb n="3" break="no"/>tikaḷ <hi rend="grantha">śrī</hi> cuntarapāṇṭiyatevaṟku yāṇṭu
<lb n="4"/><num value="14"><g type="numeral">10</g> 4</num> kaṟkaṭaka nāyaṟṟu pū<hi rend="grantha">rvva</hi>pa<hi rend="grantha">kṣa</hi>ttu pañcami
<lb n="5" break="no"/>yum tiṅkaṭ kiḻamaiyum peṟṟa tiruv<unclear>o</unclear>ṇattu
<lb n="6"/>nāḷ <hi rend="grantha">śrī</hi>maturāntakac caruppetimaṅkalattu
<lb n="7"/>vaṭapiṭākaiyil vittūr Uṭaiyār tiruvālak
<lb n="8" break="no"/>koyiluṭaiya nāyaṉāṟku pu<hi rend="grantha">ṣpagi</hi>ricīyareṉ
<lb n="9"/>vaitta cantiviḷakku Iraṇṭukku viṭṭa
<lb n="10"/>pacu Āṟum Ikkoyiluṭaiya civappirā
<lb n="11" break="no"/>mmaṇarom kaikkoṇṭu cantiviḷak
<lb n="12" break="no"/>ku Iraṇṭum cantirātittavarai Erippatā
<lb n="13" break="no"/>ka cilālekai paṇṇik kuṭuttom Ik
<lb n="14" break="no"/>koyil nāṟpatu vaṭṭattuk kāṇi Uṭai
<lb n="15" break="no"/>ya civappirāmmaṇarom Itu <hi rend="grantha">śrī</hi>mā<hi rend="grantha">he</hi>
<lb n="16" break="no"/><hi rend="grantha">śvara rakṣai §</hi> 
</p>

