<lb n="1"/><hi rend="grantha">svastiśrī</hi> vikkiramacoḻatevarkku yāṇṭu 5 Āvatu kaḷattūrk koṭṭattu <hi rend="grantha">brahma <gap reason="lost" quantity="2" unit="character"/> </hi>
<lb n="2"/>cattiyā<hi rend="grantha">śra</hi><unclear>ya</unclear>kulakāla <hi rend="grantha">śa</hi>tu<hi rend="grantha">rvve</hi>ti maṅkalattu mayintakkuṟicolai ma <gap reason="lost" quantity="2" unit="character"/> 
<lb n="3"/>ṭṭi koṟṟiyammai Āmūr koṭṭattu paṭuvūr nāṭṭu tevatānam tiruviṭava <gap reason="lost" quantity="3" unit="character"/> 
<lb n="4"/>Āḻvārkku perumāḷ tirumuṉ Eriya <hi rend="grantha">sa</hi>n=tiviḷakku tiruvaṭippiṭikku nampim<unclear>ār</unclear> <gap reason="lost" quantity="3" unit="character"/> 
<lb n="5"/>poliyūṭṭāl <hi rend="grantha">sa</hi>n=tiviḷakku 1 m celuttak kaṭavarāka <hi rend="grantha">sagai</hi>yār Eṉpakkal ko <gap reason="lost" quantity="3" unit="character"/> 
<lb n="6"/>tiramam 9 Oṉpatuṅ kaikkoṇṭom <hi rend="grantha">śrī</hi> vayiṣṇava <hi rend="grantha">rakṣai <gap reason="lost" quantity="1" unit="character"/> </hi>
