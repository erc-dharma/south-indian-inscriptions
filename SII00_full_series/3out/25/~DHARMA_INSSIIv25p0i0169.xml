<lb n="2"/>ka coḻavaḷanāṭṭu paṉaiyūr nāṭṭu panaṅkuṭaiyān cūriya<hi rend="grantha">de</hi>
<lb n="3" break="no"/>van Ittevaṟku vaitta <hi rend="grantha">sandhi</hi>viḷakku Onṟu Ittevar paṇ
<lb n="4" break="no"/>ṭārattu Oṭukkiṉa kācu Onṟu Ikkācāl vanta <hi rend="grantha">vriddhi</hi> koṇṭu
<lb n="5"/><hi rend="grantha">śandrādi</hi>ttaval cella kaṭavatāka <g ref="sym:bar" type="punctuation">.</g><g ref="sym:bar" type="punctuation">.</g><g ref="sym:bar" type="punctuation">.</g>
