<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">gaurīśō girijāpurē kratayugē gaurīsa mārādhitastētāyāma</hi>
<lb n="2" break="no"/><hi rend="grantha">pi rāmanāmanagarē rāmēśvara stannataḥ skandaśō guha pūjitō guha</hi>
<lb n="3" break="no"/><hi rend="grantha">purē pādhāt sa vōñcaparē nīlagrīva <unclear>mu</unclear>ni<unclear>ṣṭu</unclear>tō viṣapurē śrī nīla</hi>
<lb n="4" break="no"/><hi rend="grantha">kaṇṭhaḥ kalau <g ref="sym:bar" type="punctuation">.</g> <supplied reason="omitted">1</supplied> Ādāvēva sadāśivam phaṇipati śrīkaṇṭhagauri</hi>
<lb n="5" break="no"/><hi rend="grantha">guhā dhātā viṣṇura vīśvaraḥ viṣupurē cakram</hi><note n="95-1">May be read as <hi rend="grantha">cakra</hi></note> <hi rend="grantha">ssa mārādhanam <g ref="sym:bar" type="punctuation">.</g></hi>
<lb n="6"/><hi rend="grantha">tēṣānnāmahirēva sapta mahitā śśailāstadaivābhavan</hi>
<lb n="7"/><hi rend="grantha">yē kurvvanti ca tān pradakṣiṇammī mucyanta Ēvaina sā <g ref="sym:bar" type="punctuation">.</g> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi>
</p>

