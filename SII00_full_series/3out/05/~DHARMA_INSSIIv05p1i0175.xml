<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śaśvallōkavilōkanāmṛtayutē tārāpatistvartthināṁ dāridrāṁddhavidāraṇē grahapatiśśītādrisētōḥ pa<unclear>ra</unclear>ṁ jī
<lb n="2" break="no"/>vānāmaniśāvanē gṛhapatiḥ paṁkkējinīhṛtpatiḥ sthātkēśavabhūpatirvvijayatē vidvanmukhaśrīpatiḥ [<g ref="sym:bar" type="punctuation">.</g>1*] bhā
<lb n="3" break="no"/>ṣāmaṁbujapaṁbhavassarasijāṁ śārjgīva śailē <gap reason="lost" quantity="3" unit="character"/> tmasutāmiva priyaguṇāśayam <gap reason="lost" quantity="2" unit="character"/> mahēṁdrō yathā <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> caṁdrāṇimiva caṁ
<lb n="4" break="no"/>dramā dinamaṇistaddharmmapatnīmiva śrīmatkēśavabhūpatirvvara <gap reason="lost" quantity="2" unit="character"/> dēvīmumāṁ saṁvṛtaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 2*] <gap reason="lost" quantity="5" unit="character"/> <unclear>varē</unclear>ṇyassiṁhyassiṁhasya tatsu
<lb n="5" break="no"/>taḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> karīpōtaharīpōtaḥ pōtabhūpakumārakaḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 3*] patati surapaghaṭṭa<unclear>śvē</unclear>tabhūpālapuṣpaḥ sa <gap reason="lost" quantity="5" unit="character"/> śavātkalpavṛkṣāt <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> vina
<lb n="6" break="no"/>taphalakumārātsōmagoṁkkātmaputrātkimapi maruti vātādityadēvī latābhiḥ [<g ref="sym:doubleBar" type="punctuation">.</g> 4*] svasti <gap reason="lost" quantity="5" unit="character"/> ma<unclear>dhu</unclear>ravacanaracanābhiratu
<lb n="7" break="no"/>ṁḍunu <g ref="sym:bar" type="punctuation">.</g> vistāritasukavikavitānipuṇaguṇasammatuṁḍunu <g ref="sym:bar" type="punctuation">.</g> dinarājavirājitakarasu <gap reason="lost" quantity="7" unit="character"/> kulikaruṁḍḍunu <g ref="sym:bar" type="punctuation">.</g> sura
<lb n="8" break="no"/>maṇisurabhisurabhūruhavitaraṇaguṇagaṇābhimāna<unclear>ka</unclear>ruṁḍunu <g ref="sym:bar" type="punctuation">.</g> niratiśaya <gap reason="lost" quantity="5" unit="character"/> litārtthasadyōnigrahuṁḍunu
<lb n="9"/>natāvanīpālapālitēlātalānugrahuṁḍunu <g ref="sym:bar" type="punctuation">.</g> vārijākarapurādhipāluṁḍunu vīravāri <gap reason="lost" quantity="3" unit="character"/> manōlōluṁḍunu <g ref="sym:bar" type="punctuation">.</g> nanninārāya
<lb n="10" break="no"/>ṇuṁḍunu manniyadēvēṁdruṁḍununaina śrīmanmahāmaṁḍalēśvara kolani maṁḍalika kēśavadēvaraju 1134 gunēṁṭi
<lb n="11"/>Uttarāyanasaṁkrāṁtinimittamunaṁ danakoḍku pōtayakumāruniki dharmmārtthamugāṁ golanilōpali śrīsōmēśvara
<lb n="12" break="no"/>mahādēvaraku Akhaṁḍamunakuṁ beṭṭina InpaEḍlu 50 <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> vī<unclear>niṁ</unclear> jēkoni kaḍki meḍyebōyuṁḍunu mallāpuṁ gāma
<lb n="13" break="no"/>nabōyuṁḍunu vīri putrapautrikamuṁgā sāniyaṁbāṭinitya māneṁḍu neyi Ācaṁdrārkkasthāyigā naḍapaṁgalavāru <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied>
<lb n="14"/>yatō dharmmastatō jayaḥ <g ref="sym:doubleBar" type="punctuation">.</g>
