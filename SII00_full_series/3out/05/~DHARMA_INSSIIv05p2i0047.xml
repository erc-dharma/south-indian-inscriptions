<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">śubhamastu svasti <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> śrīma</hi> ṉ<hi rend="grantha">mahārājā</hi>ti<hi rend="grantha">rāja</hi> n <hi rend="grantha">śrī</hi>vī<hi rend="grantha">rapra</hi> tāpa <unclear>Accutateva</unclear>
<lb n="2" break="no"/><hi rend="grantha">mahārā</hi> yar <hi rend="grantha">pṛthi</hi>vi<hi rend="grantha">rājyam</hi> paṇṇiaruḷāniṉṟa <hi rend="grantha">śakāptam</hi>
<lb n="3"/><num value="1463"><g type="numeral">1000</g> 4 <g type="numeral">100</g> 6 <g type="numeral">10</g> 3</num>- ṉmel cellāniṉṟa <hi rend="grantha">b</hi> lavaru<hi rend="grantha">ṣa</hi>m taimātam <hi rend="grantha">3<g ref="sym:tam-pillaiyarCuli" type="punctuation"> <gap reason="lost" quantity="1" unit="character"/> </g></hi>
<lb n="4"/><hi rend="grantha">śrīma</hi>tu<hi rend="grantha"> kiṣṇama</hi> nāyakkar kāriyattukku kaṭavar naracappaya
<lb n="5" break="no"/>ṉā<supplied reason="omitted">yakkar</supplied> tiruviriñcipuram Uṭaiyār vaḻittuṇainayi
<lb n="6" break="no"/>ṉār koyil <hi rend="grantha">śrī</hi><unclear>paṇṭ</unclear>ārattārum kopā <gap reason="lost" quantity="2" unit="character"/> 
<lb n="7"/>kaḷil poṉṉakkoṉār Uḷḷiṭṭāṟku Aṭaio
<lb n="8" break="no"/>lai kuṭuttapaṭi nāḷatumutal malaiyāṅ kaṭṭukku talai <gap reason="lost" quantity="1" unit="character"/> 
<lb n="9"/>kaiyāka mātam Oṉṟukku muḻukkuṭikku paṇam kālum
<lb n="10"/>paṟṟākkuṭikkup paṇam Araikkālum Inta viḻu
<lb n="11" break="no"/>kkāṭu koḷḷakkaṭavom Ākavum Inta viḻukkāṭu
<lb n="12"/><hi rend="grantha">svā</hi> mi māṟka<hi rend="grantha">sahā</hi>yar tiruvāṇaiye Irāyar pāta<supplied reason="omitted">t</supplied>tāṇaiye tappa
<lb n="13" break="no"/>kkaṭavomalla Ākavum Irācakaram Iyātoruvar Aṭante
<lb n="14" break="no"/>ṟṟam paṇṇinatu Uṇṭāṉāl kaṭaikkūṭṭuttāṉattār māyecurar
<lb n="15"/>koyil kaṇakkappiḷḷaikaḷ kiḻaitteruvār melaitteruvār
<lb n="16"/>maṉṟāṭikaḷ viyāpārikaḷ tiruviḷakku nakarattār maṟṟum
<lb n="17"/>Uṇṭāṉa palapaṭṭaṭaiyārum kūṭip piṟappaṭṭu Iruntu
<lb n="18"/>Inta piṟakāṟattukku naṭattikkuṭuttuvarak kaṭavomākavum
<lb n="19"/>Itukkut tappiṉavarkaḷ keṅkaikkaraiyile kārāmpacu
<lb n="20" break="no"/>vaik koṉṟa pāpattile pokakkaṭavarākavum taṉṉiṭaya
<lb n="21"/>kuru mātāpitāvait taṉ kaiyāle koṉṟa pāpattile
<lb n="22"/>pokakkaṭavarākavum taṉ piḷḷai taṉakkutavāmal
<lb n="23"/>pokakkaṭava<unclear>r</unclear>ākavum <tlka/> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> 
</p>

