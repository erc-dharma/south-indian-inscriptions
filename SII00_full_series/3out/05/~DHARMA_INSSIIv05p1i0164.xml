<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1-6"/> <gap reason="lost" quantity="10" unit="character"/> 
<lb n="7"/> <gap reason="lost" quantity="5" unit="character"/> śatapatrapatranētraḥ <gap reason="lost" quantity="5" unit="character"/> 
<lb n="8"/> <gap reason="lost" quantity="3" unit="character"/> samānavaktraḥ <g ref="sym:doubleBar" type="punctuation">.</g> <gap reason="lost" quantity="2" unit="character"/> yuttamōttuṁgga <gap reason="lost" quantity="3" unit="character"/> 
<lb n="9-10"/> <gap reason="lost" quantity="10" unit="character"/> 
<lb n="11"/>mānaḥ <g ref="sym:bar" type="punctuation">.</g> dānaṁ yasya samagra <gap reason="lost" quantity="10" unit="character"/> 
<lb n="12"/> <gap reason="lost" quantity="5" unit="character"/> śauryyaṁ yasya virōdhirājavanitāvaidhavya
<lb n="13" break="no"/>dīkṣāguruḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> kīrttirddivyanadīva yasya vimalā vyāpya trilō
<lb n="14" break="no"/>kīṁ vṛtā pridhvī yasya catu<supplied reason="omitted">ḥ</supplied> samudravalayā sōtyuṁnna<unclear>tō</unclear>
<lb n="15"/>varttatē <g ref="sym:bar" type="punctuation">.</g> śrīśākēśvaravatsarē vidhunidhivyōmēṁdusaṁkhyā
<lb n="16" break="no"/>nvitē kārttikyāṁ ripurājabhīkaraśarassōyannarēṁdrāgraṇīḥ <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied>
<lb n="17"/>kṣīrārāmanivāsinē bhagavatē śervvāya sarvvātmanē prādādā
<lb n="18" break="no"/>śaśitārakaṁ guṇanidhirddīpāvakhaṁḍḍau mudā <g ref="sym:doubleBar" type="punctuation">.</g>
<lb n="19"/>śrīyutavakṣu śrīvarakavigāyakanidhi suṁddarāṁbikasutuṁḍu<unclear>nu</unclear>
<lb n="20"/>śrīyuktuṁḍanaṁga negaḍina rāyapanāyakuni kānta rājāsya mahini <g ref="sym:doubleBar" type="punctuation">.</g>
<lb n="21"/>guṇanidhiviyadiṁddugaṇanaśakābdaṁbu lamaraṁgga nuttarāyaṇani
<lb n="22" break="no"/>mitta magupuṇyadinamuna nabjāsya nācināyakunaku
<lb n="23" break="no"/>ṁ cinnamāṁbakuṁ danūja trōlama gaṇikāvibhūṣaṇi bha
<lb n="24" break="no"/>ktiṁ dannēlina haruna kaḍḍeṁḍumānikahibhūṣaṇunaku kṣī
<lb n="25" break="no"/>rārāmavarapurapatiki nakhaṁḍadīpaṁbu nilipe <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> dīni jēkoni
<lb n="26"/>naḍapaṁggaṁbūne niṁduvelasi yeppuḍuṁ dama sāni vṛttiṁgā
<lb n="27"/>jē<unclear>nu</unclear> kaṁṭanaku nagrajuḍu jakkanaghanuṁḍu darata
<lb n="28" break="no"/>raṁbulu nācaṁdratārakamugā <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> 
</p>

