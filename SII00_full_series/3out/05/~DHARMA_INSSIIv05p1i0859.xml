<lb n="1"/>nilakaṅkaraiyaṉ <unclear>Olai</unclear>
<lb n="2"/>Arumpaṟṟivā <gap reason="lost" quantity="1" unit="character"/> kaṇṭu
<lb n="3"/> <gap reason="lost" quantity="4" unit="character"/> kaḷūr kāṇi
<lb n="4" break="no"/>nilattevatāṉam timuṟai <gap reason="lost" quantity="1" unit="character"/> 
