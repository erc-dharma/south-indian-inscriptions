<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> tirumakaḷ polap pe
<lb n="2" break="no"/>runilac celviyum taṉakke yuri
<lb n="3" break="no"/>mai pūṇṭamai maṉakkoḷak kān=ta<hi rend="grantha"/>
<lb n="4" break="no"/>ḷūrccālai kala maṟuttaruḷi veṅkai
<lb n="5" break="no"/>ñāṭuṅ kaṅkapāṭiyuṅ taṭikaipāṭiyuṅ nu
<lb n="6" break="no"/>ḷampapāṭiyuṅ kuṭamalaiñāṭuṅ kollamum
<lb n="7"/>kaliṅkamum Eṇṭicai pukaḻtara Īḻamaṇṭalamum
<lb n="8"/>tiṇṭiṟal veṉṟit taṇṭāṟ koṇṭa taṉṉeḻil
<lb n="9"/>vaḷaruḻiyuḷ <unclear>ḷ</unclear>ellā yāṇṭum toḻutakai vi
<lb n="10" break="no"/>ḷaṅkum yāṇṭe ceḻiyarait tecukoḷ <hi rend="grantha">śrī</hi>
<lb n="11" break="no"/>koi<hi rend="grantha">rāja</hi> I<hi rend="grantha">rājakesa<unclear>ri</unclear>varmma</hi> rāṉa <hi rend="grantha">śrī</hi>i<hi rend="grantha">rāja</hi> I<hi rend="grantha">rājad<unclear>e</unclear></hi>
<lb n="12" break="no"/>varkku yāṇṭu <num value="21">2 <g type="numeral">10</g> 1</num> Irupattoṉṟāvatu vaṭakarai <unclear>Irā</unclear>
<lb n="13" break="no"/><hi rend="grantha">jendrasiṁ ha</hi>vaḷanāṭṭup poykaiñāṭṭu teva<unclear>tā</unclear>
<lb n="14" break="no"/>ṉam tiruvaiyāṟṟu Oloka<hi rend="grantha">ma hāde</hi>vi<hi rend="grantha">śva</hi> ramuṭaiyā<unclear>r</unclear>
<lb n="15"/><hi rend="grantha">tribhu</hi> vaṉacaṇṭe<hi rend="grantha">śva</hi> rar ka<hi rend="grantha">nmi</hi> kaḷiṭai Innāṭṭu <hi rend="grantha">brahma</hi>
<lb n="16" break="no"/>teyam perumpuliyūrkkuṭi maṉṟāṭi Aiyyāṟaṉ<unclear>va</unclear>
<lb n="17" break="no"/>ḷava(ṉ)ṉeṉa koṇṭa viḷakku Iraṇṭiṉukku
<lb n="18"/>Āṭu <num value="192"><g type="numeral">100</g> 9 <g type="numeral">10</g> 2</num> Ivvāṭu nūṟṟut toṇṇū<unclear>ṟ</unclear>
<lb n="19" break="no"/>ṟu Iraṇṭuṅ kuṭinikkāc cāvā muvāp perāṭu Ākak <unclear>ko</unclear>
<lb n="20" break="no"/>ṇṭu nicatam <num value="27">2 <g type="numeral">10</g> 7</num> Uriy [neyyāka non=tā<hi rend="grantha">]</hi> vi<unclear>ḷak</unclear>
<lb n="21" break="no"/>ku Iraṇṭiṉukku ca<hi rend="grantha">ntrādi</hi> ttaval A<unclear>ṭṭu</unclear>vatākak ko
<lb n="22" break="no"/><unclear>ṇṭu</unclear> kuṭiyeṉṟu Ivvāṭu nūṟṟut toṇṇūṟṟu
<lb n="23" break="no"/>iraṇṭu[ ṅ cāvā muvā perāṭuāka<supplied reason="omitted">k</supplied> kaikkoṇṭu ca<hi rend="grantha">ntrā]</hi><note n="205-2">This inscription is left unfinished.</note>
