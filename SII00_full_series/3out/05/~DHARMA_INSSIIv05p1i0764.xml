<lb n="2"/><hi rend="grantha">śakābdam</hi> Āyirattu nānūṟṟu Aṉpattu Oṉpatil meṟ cellāniṉṟa na<hi rend="grantha">m ku</hi> <unclear>m</unclear>ā<hi rend="grantha">ran svasti śrī bhu</hi>vane<hi rend="grantha">ka</hi>
<lb n="3" break="no"/>vira <hi rend="grantha">candrakulapradipa madhurāmahendra ja</hi>yan=ta<hi rend="grantha">maṅgaḷapura</hi>va<hi rend="grantha">rādhīśvara kṣemāsura</hi>nā<hi rend="grantha">rasiṁha keraḷa</hi>ta<hi rend="grantha">modi</hi>vā<hi rend="grantha">kara coḷasindhu<unclear>ba</unclear>ṭabā</hi>
