<lb n="5"/>perumāḷ <hi rend="grantha">śrī</hi>va<hi rend="grantha">llabhade</hi> var<supplied reason="omitted">k</supplied>ku yāṇṭu mūṉṟāvatu Eviḷampi va<hi rend="grantha">rṣam vṛścikara</hi>vi Irupattu Oṉpatān tiyatiyum <hi rend="grantha">Aparapakṣa</hi> ttu <hi rend="grantha"><unclear>E</unclear>kā<unclear>da</unclear>śi</hi> yu
<lb n="6" break="no"/>m <hi rend="grantha">budha</hi>vā<hi rend="grantha">ramum</hi> peṟṟa coti nāḷ <hi rend="grantha">Ātra</hi>ya<hi rend="grantha">gotra</hi> ttu <hi rend="grantha">jā</hi>na<hi rend="grantha">ka</hi> kku <hi rend="grantha">dā</hi>na<hi rend="grantha">mā</hi> kak kuṭuk
<lb n="7" break="no"/>kak kaṟpittu maṉai Oṉṟukkum nilam Orumāvukkum nam <hi rend="grantha">kumāran śrī</hi>va<hi rend="grantha">llabhade</hi> var <unclear>Olai</unclear> varukaiyil na<unclear>m v</unclear>ācalkāri<unclear>ya</unclear>m <hi rend="grantha">parāṅku</hi>
