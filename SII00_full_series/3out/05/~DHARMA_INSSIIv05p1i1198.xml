<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śākābdē guṇaśailavahnivasudhā
<lb n="2" break="no"/>śaṁkhyāyutē vatsarē (<g ref="sym:bar" type="punctuation">.</g>) māghē mā
<lb n="3" break="no"/>si ca paṁcamīguruyutē kuṁbhē sthitē bhā
<lb n="4" break="no"/>skarē <g ref="sym:bar" type="punctuation">.</g> vīraśrīkapiḷēṁdrarājatilakābhī(ṁ)ṣṭā
<lb n="5" break="no"/>rtthasiddhyai sadā(<g ref="sym:bar" type="punctuation">.</g>)tailādānakaraprasaṁ
<lb n="6" break="no"/>ggaśamanaṁ tvācaṁdramātārakaṁ 1 <g ref="sym:bar" type="punctuation">.</g>
<lb n="7"/>kapiḷēṁdramahārājyē vatsarē ca
<lb n="8"/>prajāvatau <g ref="sym:bar" type="punctuation">.</g> kaḷiṁganagarādhyakṣau hē
<lb n="9" break="no"/>mahastharavī śubhau <g ref="sym:bar" type="punctuation">.</g> 2 śrīkūrmanā
<lb n="10" break="no"/>thaparicārakarakṣaṇāya lōkōpakāra
<lb n="11" break="no"/>kamidaṁ paralōkasādhyaṁ <g ref="sym:bar" type="punctuation">.</g> tailābhidhānamatiduṣka
<lb n="12" break="no"/>rakarma tābhyāṁ tyaktaṁ kaḷiṁganagarapratipāla
<lb n="13" break="no"/>kābhyāṁ <g ref="sym:bar" type="punctuation">.</g> 3 tatō dīparttamadhuna dēvatānāṁ ca sa
<lb n="14" break="no"/>nnidhau <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> kōśē śrīkūrmanāthasya dī
<lb n="15" break="no"/>yyatē dīpamūlyakaṁ <g ref="sym:bar" type="punctuation">.</g> 4 <g ref="sym:bar" type="punctuation">.</g> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
</p>

