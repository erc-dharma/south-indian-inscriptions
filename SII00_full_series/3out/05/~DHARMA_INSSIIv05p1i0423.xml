<p>
<lb n="1"/><hi rend="grantha"><unclear>sva</unclear>sti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> <hi rend="grantha">śrī</hi>komāṟapaṉmarāṉa <hi rend="grantha">tribhu</hi> vanacca<hi rend="grantha">kra</hi>
<lb n="2" break="no"/><unclear>va</unclear>ttikaḷ Emmaṇṭalamuṅkoṇṭaruḷiya <hi rend="grantha">śrī</hi>kula
<lb n="3" break="no"/>cekaratevaṟku yāṇṭu <hi rend="grantha"><unclear>2</unclear>6</hi> vatu <hi rend="grantha">praści</hi> kanāyaṟṟu
<lb n="4"/>Irupattiraṇṭān tiyatiyum Amarapa<hi rend="grantha">kṣa</hi>ttu <hi rend="grantha">dvi</hi>ti
<lb n="5"/>yaiyum putaṉkiḻamaiyum peṟṟa puṉarpūca<unclear>ttu</unclear>
<lb n="6" break="no"/>nāḷ kiḻvempanāṭṭut tirunelveli Uṭaiyār
<lb n="7"/>tirunelveliyuṭaiyanāyaṉār koyil nima
<lb n="8" break="no"/>ntakkāṟa <gap reason="lost" quantity="4" unit="character"/> perunteruvil vāṇi
<lb n="9" break="no"/>yanakarattom <gap reason="lost" quantity="3" unit="character"/> kkiḻ kulacekara
<lb n="10" break="no"/>ṉmāḷikaiyil <unclear>pirāṉ</unclear>kuṭaiyāṉ Aḻakaṉ
<lb n="11"/>Āḷkkoṇṭāṉ taṉapālar tanta poruḷ ko
<lb n="12" break="no"/>ṇṭu Emmi licaintu Ināyaṉār koyilil
<lb n="13"/>pollātapiḷḷaiyāṟkuc ca<hi rend="grantha"><unclear>nti</unclear></hi> yātipattu
<lb n="14" break="no"/>kku nāḷ Oṉṟukku Aḷakku meṇṇai Uḻak
<lb n="15" break="no"/>ku Ivveṇṇai Uḻakkum nāṭoṟum Eṅka
<lb n="16" break="no"/>ḷ varkkattā<unclear>rāṟ cantirātittavaṟ kuṭuppa</unclear>
<lb n="17" break="no"/>tākak kallile veṭṭikkuṭuttom
<lb n="18"/>Ivai taṉmapālaṉ Eḻuttu Ivai can
<lb n="19" break="no"/><unclear>mai</unclear>ceṉātipati taṟkuṟi <gap reason="lost" quantity="4" unit="character"/> 
<lb n="20"/>peṟ <gap reason="lost" quantity="2" unit="character"/> koṉ <gap reason="lost" quantity="1" unit="character"/> [yaḻa <gap reason="lost" quantity="1" unit="character"/> tiru <gap reason="lost" quantity="1" unit="character"/> ṉaṉ] Eḻu
<lb n="21" break="no"/>ttu <supplied reason="undefined"><g type="ddanda">.</g></supplied>
