<p>
<lb n="1"/><hi rend="grantha">svasti śrīḥ <g type="ddanda">.</g><g type="dashLong">.</g>kṣo</hi>ṇī<hi rend="grantha">ṁ rakṣa</hi>ti<hi rend="grantha"> bhūmipe kali</hi>yu<hi rend="grantha">ge rājādhirājāhva</hi>ye<hi rend="grantha"> taistairddīpakra</hi>te<hi rend="grantha"> śi</hi>vāya<hi rend="grantha"> vihi</hi>tā<hi rend="grantha">śśrī</hi> Oṟṟiū<hi rend="grantha">rā</hi>ya<hi rend="grantha"> yāḥ <supplied reason="undefined"><g type="danda">.</g></supplied> gā</hi>va<hi rend="grantha">stāḥ prakalayya</hi>
<lb n="2"/>ta<hi rend="grantha">tga</hi>ṇanayā<hi rend="grantha"> kā</hi>ya<hi rend="grantha">sthamaittrīkarā dvāreśaśca</hi>tu<hi rend="grantha">rā</hi>nano<hi rend="grantha"> maṭhapa</hi>ti<hi rend="grantha">sdhitya<supplied reason="omitted">r</supplied>tthamālekha</hi>ya<hi rend="grantha">t <supplied reason="undefined"><g type="ddanda">.</g></supplied> svasti śrī <supplied reason="undefined"><g type="ddanda">.</g></supplied> ti</hi> ripuvaṉaccakkaravarttikaḷ <hi rend="grantha">śrī</hi>rā<hi rend="grantha">jādhi</hi> rā<hi rend="grantha">jade</hi> varkku yāoṉpatāmatu
<lb n="3"/><hi rend="grantha">ja</hi>yaṅkoṇṭacoḻamaṇṭalattup puḻaṟkoṭṭattu Uṭaiyār tiruoṟṟiyūruṭaiyārkku muṉpil Āṇṭukaḷil palarum vaitta tirununtāviḷakkukaḷ kalveṭṭillātaṉa koyiṟkaṇakkut tiruoṟṟiyūruṭai
<lb n="4" break="no"/>yāṉ Uṟavākkiṉāṉ kaṇakkil kaṇṭu kal veṭṭiṉapaṭi Uṭaiyār tiruoṟṟiyūruṭaiyārkku Ikkoyilil t<unclear>e</unclear>varaṭiyāḷ cāṇi Oṟṟiāḻvi vaitta tirunantāviḷakku Oṉṟukku viṭṭa pacu muppattiraṇṭukku Ittevar tiruvi
<lb n="5" break="no"/>ḷakkukuṭi tiripuvanacuntaratteru maṉṟāṭikaḷil paṭampakkaṉ vallamuṭaiyāṉ Aḷakku ney nāṟpattaiññāḻiyum perāyira moṟṟi Aḷakku ney nāṟpattaiññāḻiyum Ippaṭiyāl vanta ney Aḷakka kaṭavomānom <supplied reason="undefined"><g type="ddanda">.</g></supplied>
</p>

