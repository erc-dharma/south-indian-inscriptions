<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> tiruvāykkeḻvikkumel <hi rend="grantha">śrī</hi>komāṟavaṉmarāṉa <hi rend="grantha">tribhu</hi> vaṉacca<hi rend="grantha">kra-</hi> vattikaḷ coṇāṭuvaḻa<unclear>ṅkiya</unclear>ruḷiya <hi rend="grantha">śrīsunda</hi> rapāṇṭiya<hi rend="grantha">de</hi> vaṟku yāṇṭu patiṉo<unclear>ṉṟā</unclear>
<lb n="2" break="no"/>vatu <hi rend="grantha">prasāda</hi> ñ ceytaruḷivanta <hi rend="grantha">śrī</hi>mukappaṭi <hi rend="grantha">tribhu</hi> vaṉaccakkaravartti koṉeriṉmaikoṇṭāṉ tirunelveliyāṉa kulacekaraccatu<hi rend="grantha">rvvedi</hi> maṅkala
<lb n="3" break="no"/>ttu <hi rend="grantha">sabhai</hi> yāṟku taṅkaḷūr Aṉā<hi rend="grantha">di</hi> yāka Oṭṭiṉapaṭi kācum nellum Eṭṭuttarattile nilamaṭakki kaṭamaiyiṟuttu vantatākavum patiṉoṉṟā
<lb n="4" break="no"/>vatu nāḷile tāṅkaḷ tarattaiyuṅ kulaittu virivile kaṭamai Iṟukkaveṇumeṉṟu coṉṉārkaḷāka kaṇṭiyatevar coṉṉār Appaṭi
<lb n="5"/>ceyyakkaṭavatalla paṇṭāṭu paḻanaṭai Iṟuttuvanta tarattile muṉpu Iṟuttuvantapaṭiye Iṟukka Ivai teṉṉavatarayaṉ Eḻuttiṉāl yā
<lb n="6" break="no"/>ṇṭu patiṉoṉṟāvatu nāḷ nāṉūṟṟaḻepattu nālile Ivai vicaiyarāyaṉ Eḻuttiṉālum <unclear>Ivai pa</unclear>llavarāya ṉe<supplied reason="omitted">ḻu</supplied>ttiṉālum <hi rend="grantha">prasā</hi>
<lb n="7" break="no"/><hi rend="grantha">da</hi> ñceytaruḷi vantatu <hi rend="grantha"><g type="pc"/> svasti <g type="pc"/></hi>
</p>

