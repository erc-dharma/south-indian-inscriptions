<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> korā<hi rend="grantha">ja</hi>ke<hi rend="grantha">sa</hi>rivaruma
<lb n="2" break="no"/>kku yāṇṭu <num value="17"><g type="numeral">10</g> 7</num> Āvatu tiru
<lb n="3" break="no"/>nettānattu <hi rend="grantha">ma hāde</hi> var
<lb n="4" break="no"/>kku coḻapperumānaṭikaḷ ta
<lb n="5" break="no"/>vayūr kiḻāraṭikaḷ kuṭutta Ā
<lb n="6" break="no"/>ṭu nūṟu Ivvāṭu Iṭaiyāva
<lb n="7" break="no"/>ḻi Aṭuttu Oru noṉtāvi<supplied reason="omitted">ḷa</supplied>kku E
<lb n="8" break="no"/>rippomānom tirunettāna
<lb n="9" break="no"/>ttu <hi rend="grantha">sabha</hi> yom Itu paṉmā<hi rend="grantha">he</hi>
<lb n="10" break="no"/><hi rend="grantha">śvara rakṣai <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi><note n="239-1"><hi rend="italic">Puḷḷis</hi> are marked in this inscription.</note>
