<!--<h4><hi rend="italic">First face.</hi></h4>-->

<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> tiri
<lb n="2"/>puvaṉaccakkara
<lb n="3" break="no"/>vattikaḷ [<hi rend="grantha">śrī</hi>]vira
<lb n="4" break="no"/>rācentiracoḻa
<lb n="5" break="no"/>tevaṟku yāṇṭu 
<lb n="6"/>Añcāvatu I<hi rend="grantha">ṣa</hi>
