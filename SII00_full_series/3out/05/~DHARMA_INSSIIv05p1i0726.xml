<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> koccaṭaiyapaṉmarāṉa Uṭaiyār <hi rend="grantha">śrī</hi>cuntaracoḻapāṇṭiyatevarkku yāṇṭu <hi rend="grantha"><num value="21">2 <g type="numeral">10</g> 1</num> rāja <gap reason="lost" quantity="5" unit="character"/> </hi>
<lb n="2"/>y<unclear>ā</unclear>r paṭai catturuciṅkaril kaiññāyaṉ kāricolaiyeṉ <hi rend="grantha">śrī</hi>kaiyilāyamuṭaiyārkku vaicca ti <gap reason="lost" quantity="5" unit="character"/> 
<lb n="3"/>llil veṭṭu veṭṭiṉa kalveṭṭiṉāl Avaṉitu pūmiyākātey nam pūmiyāy Avaṉ Aṉantaratti <gap reason="lost" quantity="5" unit="character"/> 
<lb n="4"/>caṅkūtum Āḷ Iraṇṭum nikki caṇṭai nālukkum timilai Oṉṟukkum kaiymmaṇi Īraṇaiykkum ceyaka <gap reason="lost" quantity="5" unit="character"/> 
<lb n="5"/>Ivvarikecarimaṅkalattu perunāṉ kellai kiḻellai Āykkuṭikkālukku mekkuma teṉ ṉel<unclear>lai</unclear> mā<unclear>ñani</unclear> <gap reason="lost" quantity="5" unit="character"/> 
<lb n="6"/><hi rend="grantha">mahāsabh<supplied reason="omitted">ai</supplied></hi> yom <hi rend="grantha">śrī</hi>kayilā<hi rend="grantha">sa</hi>ttu perumānaṭikaḷukku Ipparicu Ippūmiyil pattumāc cey tiru<unclear>va</unclear> <gap reason="lost" quantity="5" unit="character"/> 
<lb n="7"/>Innālveli nilamum nikki niṉṟa nila mellām tiruccennaṭaikkum tirumeypūccukkum tiruva<unclear>mi</unclear> <gap reason="lost" quantity="5" unit="character"/> 
<lb n="8"/><unclear>ca</unclear>mppuṟamāy nicatam Eṇṇāḻi Ariciyum kaṟiyamutum neyyamitum tayir Amitum Aṭaikkāya <gap reason="lost" quantity="5" unit="character"/> 
<lb n="9"/>m Ikkāḷamutikaḷaiy Arikecarimaṅkalattil(k) kuḷattil pācipaṟṟuk koṇṭu caṅ(k)kiraṇ ṭūtuvārākavum <gap reason="lost" quantity="5" unit="character"/> 
<lb n="10"/>m paṇiviṭaiyum Evātitākavum Ikkoyilil paṇiceyyakkaṭava Āḷ muṭṭil Ā <gap reason="lost" quantity="5" unit="character"/> 
<lb n="11"/>kkiṉārum kaṅkaiyoṭu kumariyiṭai ceytār ceyta pāvam koḷvārākavum Ipparicu Ivva <gap reason="lost" quantity="5" unit="character"/> 
<lb n="12"/> <gap reason="lost" quantity="3" unit="character"/> caṭaiyaṉ Āyiravaṉ Eḻuttu <g ref="sym:doubleBar" type="punctuation">.</g> Itu paṉmāye<hi rend="grantha">śvara rakṣ<unclear>ai</unclear></hi> <g ref="sym:bar" type="punctuation">.</g><g ref="sym:bar" type="punctuation">.</g><g ref="sym:bar" type="punctuation">.</g>
