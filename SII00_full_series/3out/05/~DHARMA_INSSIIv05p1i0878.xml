<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> A</hi>ne<hi rend="grantha">kamahīmaṇḍalarājādhirāja parameśvara pa<supplied reason="omitted">ra</supplied></hi>
<lb n="2" break="no"/><hi rend="grantha">ma</hi>va<hi rend="grantha">mśotbha</hi>va<hi rend="grantha"> pal</hi> lava<hi rend="grantha">kula</hi>ti<hi rend="grantha">laka bhāradvājagotrapa</hi>vi<hi rend="grantha">tra laḷi</hi>tā<hi rend="grantha"/>
<lb n="3" break="no"/><hi rend="grantha">rddhacaṅradhara khaṭvāṅgadvaja kaḍu</hi>vāyu<hi rend="grantha">paraghoṣa</hi>ṇa<hi rend="grantha"> vṛṣabhalāñcha</hi>na<hi rend="grantha"> veṅ<unclear>gi</unclear></hi>
<lb n="4" break="no"/>nā<hi rend="grantha">tha kāñcīpura</hi>va<hi rend="grantha">rādhīśvara kāmakoṭyambikālabdha</hi>va<hi rend="grantha">raprasāda nijase</hi>va<hi rend="grantha">kā</hi>
<lb n="5" break="no"/><hi rend="grantha">bhara</hi>ṇa<hi rend="grantha"> samarapracaṇḍa caladaṅkabhaira</hi>va<hi rend="grantha"> bhu</hi>vaninā<hi rend="grantha">rā</hi>yaṇa<hi rend="grantha"> bhujaga</hi>vi<hi rend="grantha">bhūṣa</hi>ṇa
<lb n="6"/>no<hi rend="grantha"><unclear>ḍu</unclear>va</hi>ṭi<hi rend="grantha">sāhasārju</hi>na<hi rend="grantha"> śrīpūrvadikbhāgasaptaśa</hi>tā<hi rend="grantha">grahārapra</hi>ti<hi rend="grantha">ṣṭhāpaka gaṅgā</hi>
<lb n="7" break="no"/><hi rend="grantha">jalapra</hi>vā<hi rend="grantha">ha nityakrīḍā</hi>vino<hi rend="grantha">da A</hi>ne<hi rend="grantha">karipunrapa</hi>ti<hi rend="grantha"> ma</hi>ṇi<hi rend="grantha">maku</hi>ṭa<hi rend="grantha">gha</hi>ṭita<hi rend="grantha">cara</hi>ṇā<hi rend="grantha">ra</hi>
<lb n="8" break="no"/>vi<hi rend="grantha">nda bhūlokacā<unclear>tu</unclear>rvarṇṇāśra</hi>ya<hi rend="grantha"> dha<unclear>rma</unclear>pra</hi>ti<hi rend="grantha">ṣṭhi</hi>tā<hi rend="grantha">bhara</hi>ṇa <hi rend="grantha">śrī</hi>mukkaṇkāṭuveṭṭi va<hi rend="grantha">mśa</hi>
<lb n="9" break="no"/>t tavatarittaruḷiya <hi rend="grantha">tripurā</hi>n=ta<hi rend="grantha">ka</hi> tevar matucūtaṉ tevaraicaṉeṉ <hi rend="grantha">tribhu</hi> vaṉacca- <hi rend="grantha">kra</hi> vattikaḷ
<lb n="10"/><hi rend="grantha">śrī</hi>vicaiyakaṇ<unclear>ṭa</unclear>kopālatevarkku yāṇṭu <num value="18"><g type="numeral">10</g> 8</num> vatu <hi rend="grantha">ja</hi>yaṅkoṇṭacoḻamaṇṭalattu ma<unclear>ṇ</unclear> <gap reason="lost" quantity="2" unit="character"/> 
<lb n="11"/>tiraimā<hi rend="grantha">sa</hi>ttile Eṉṉuṭaiya <hi rend="grantha">janma</hi>na<hi rend="grantha">kṣatram</hi> pūram tī<hi rend="grantha">rttha</hi> mākat tirunāḷ Eḻuntaruḷi Aruḷa A <gap reason="lost" quantity="3" unit="character"/> 
<lb n="12"/>kku nāyaṉār vicaiyakaṇṭakopālatevar kuṭuttaruḷiṉa tirumukappaṭi Immaṇṭalattu Ī <gap reason="lost" quantity="3" unit="character"/> 
<lb n="13"/>vat<unclear>ā</unclear>ṉaṅkaḷ nikki Ivvūr nāṟpāṟ kellai Uṭpaṭṭa naṉcai puṉcai nila nāṉṉellai<note n="359-1">Read kellai.</note> <gap reason="lost" quantity="4" unit="character"/> 
<lb n="14"/>vvūril nām koḷḷakkaṭava kaṭamai Āyam kācukaṭamai veṭṭi Ūrccarikai taṟiyiṟai
<lb n="15"/><supplied reason="omitted">mā</supplied>vaṭai maravaṭai maṟṟum Epperppaṭṭa Iṟaikaḷum poṉvari kuturaivari Etirpa <gap reason="lost" quantity="3" unit="character"/> 
<lb n="16"/>ṟṟum Epperppaṭṭa Iṟaikaḷum Iṉṉāyaṉār cittirait tirunāḷ Eḻuntaruḷi Aruḷa <gap reason="lost" quantity="3" unit="character"/> 
<lb n="17"/>m melāṉūr Iṟaiyili tevatāṉamāka Iṭṭeṉ <hi rend="grantha">tri</hi> purāntakatevaṉ matucūtaṉ tevaraicaṉeṉ I <gap reason="lost" quantity="3" unit="character"/> 
<lb n="18"/>tu <hi rend="grantha">śrīmāheśvara rakṣaiḥ <g ref="sym:tam-pillaiyarCuli" type="punctuation"> <gap reason="lost" quantity="1" unit="character"/> </g></hi>
</p>

