<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> tiruvaḻutivaḷanāṭṭu <hi rend="grantha">brahmade</hi> yam civaiku<unclear>n</unclear>tamāṉa rā<hi rend="grantha">jentra</hi> cca<supplied reason="omitted">tu</supplied><hi rend="grantha">rvedi</hi> maṅkalattu <hi rend="grantha">ma hāsabhai</hi> yo molai
<lb n="2"/>Uttara <hi rend="grantha">deśa</hi> ttu <hi rend="grantha">svastigrāma</hi> ttu <hi rend="grantha">parāśaragotra</hi> ttu <hi rend="grantha">soma</hi> nā<hi rend="grantha">tha</hi> paṇṭitar makaṉ Aṉantacivapaṇṭitaṟkku <hi rend="grantha">śrī</hi>virapāṇṭiya<hi rend="grantha">de</hi> vaṟku yā 
<lb n="3" break="no"/>ṇṭu <num value="15"><g type="numeral">10</g> 5</num><g type="dash"/>vatu kāttikaimāta<supplied reason="omitted">t</supplied>tu <num value="13"><g type="numeral">10</g> 3</num>- tiyatiyum <hi rend="grantha">Aparapakṣa</hi> ttu <hi rend="grantha">saptami</hi> yum viyāḻakkiḻamaiyum peṟṟa <hi rend="grantha">ma</hi> kattunāḷ U<hi rend="grantha">dakapūrva</hi> kam<choice><sic>a</sic><corr>ā</corr></choice>ka <hi rend="grantha">dharmadā</hi> ṉam paṇṇi kuṭut<unclear>ta</unclear>
<lb n="4"/>nilamāvatu Ivūṟ vaṭakiḻpiṭākai va<hi rend="grantha">ra</hi> kuṇamaṅkalattu Aḷḷampaḷḷakkaṭṭaḷai kotukulavāykkālukku teṟku mutaṟk kāl <gap reason="lost" quantity="4" unit="character"/> peruvatikku meṟ
<lb n="5" break="no"/>kum mutal pāṭaka tamaṇaipaṭi nilam nālumāvil m<unclear>e</unclear>kkaṭaiya nilam <unclear>Ira</unclear>ṇṭumā Innilam Iraṇṭumāvum Itakimatimutal Ivūṟ <hi rend="grantha">śrī</hi>kailā<hi rend="grantha">sa</hi>mu<unclear>ṭ</unclear>aiya nāya
<lb n="6" break="no"/>ṉāṟ koyilil nāyaṉāṟ Aḻakāṇṭār Eḻunta<supplied reason="omitted">ru</supplied>ḷivitta Aḻa<supplied reason="omitted">ka</supplied>pperumāḷ nāyakaṟkku Amutupaṭi cāttuppaṭi Uḷḷiṭṭa ni<supplied reason="omitted">t</supplied>tam nimantaṅkaḷukku nāyaṉāṟ I
<lb n="7" break="no"/>nilam Iraṇṭumāvil kaṭamai Antarāyam kuṭuttaruḷiṉamaiyil nāṅkaḷum Inilam Iraṇ<unclear>ṭu</unclear>māvum Ivaṟkku U<hi rend="grantha">da</hi> ka<hi rend="grantha">pūrva</hi> māka <hi rend="grantha">dā</hi> ṉam paṇṇiṉa
<lb n="8" break="no"/>maiyil Inilattukku kaṟpūravilai kāriyavārāḻcciyum <hi rend="grantha">sabhā</hi> viṉiyo<hi rend="grantha">ga</hi> mum maṟṟum Eppeṟpaṭṭa varikaḷum tavintom Ippaṭikku
<lb n="9"/>Iniyo<hi rend="grantha">ga</hi> m piṭipāṭāka koṇṭu tamakku <hi rend="grantha">dā</hi> nā<hi rend="grantha">dā</hi> na<hi rend="grantha">kra</hi>yavi<hi rend="grantha">kra</hi> yaṅkaḷukku Uriccāka <hi rend="grantha">Uda</hi> ka<hi rend="grantha">pūrva</hi> māka I<hi rend="grantha">nni</hi> lam Aṉu<hi rend="grantha">bha</hi> vikka Ivai kārāmpic<unclear>e</unclear>ṭṭu
<lb n="10"/><hi rend="grantha">śrīkṛṣṇa</hi> ṉ Eḻuttu Ivai kirāñci tiruvaraṅka<hi rend="grantha">de</hi>va<hi rend="grantha">bha</hi> ṭ<supplied reason="omitted">ṭa</supplied>ṉ Eḻuttu Ivai kāra<supplied reason="omitted">m</supplied>piceṭṭu <hi rend="grantha">ṛṣi</hi> ke<hi rend="grantha">śabha</hi> ṭṭa<hi rend="grantha">so</hi>mayā<hi rend="grantha">ji</hi> Eḻuttu Ivai pici<unclear>ṇ</unclear>ṭi <hi rend="grantha">śrīkṛ</hi>
<lb n="11" break="no"/><hi rend="grantha"><unclear>ṣṇa</unclear> bha</hi> <supplied reason="omitted">ṭ</supplied>ṭa<hi rend="grantha">so</hi>mayā<hi rend="grantha">ji</hi> Eḻuttu Ivai piciṇṭi coma<unclear>nā</unclear>taṉ Eḻuttu Ivai kārampiceṭṭu Aruḷāḷaperumāḷ Eḻuttu Ivai kirāñci para<note n="316-1">This inscription is left unfinished.</note>
