<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="undefined"><g type="ddanda">.</g></supplied> kopparakecaripaṉmaṟkku yāṇtu 3 Āvatu teṉkarai
<lb n="2" break="no"/>vaṭapa<unclear>ṉa</unclear>ṅkāṭṭunāṭṭu Āṟṟūruṭaiyāṉ koṟṟaṉ Aruḷmoḻiyāyiṉa
<lb n="3"/>vi<hi rend="grantha">ra</hi> nāraṇapallavaraiyaṉ tiruvaiyāṟṟu <hi rend="grantha">ma hāde</hi> varkku <unclear>ni</unclear>
<lb n="4" break="no"/>yati muṉṟu naṉ(ta)tāviḷakku Iravum pakalu(m) merivataṟku <hi rend="grantha">[ni</hi> rai]
<lb n="5" break="no"/>mati nāḻi Āḻākkiṉukkup puṉceyttiṭal kalli Akaḻi <unclear>tirutti</unclear>
<lb n="6"/>mayakkik kuṭutta nilattiṟ kellai kiḻpāṟ kellai Iḷaiya <gap reason="lost" quantity="3" unit="character"/> 
<lb n="7"/>ḻattār <unclear>vi</unclear>ḷakkucceykkum naṅkai paravaiyār viḷakkucceykku <unclear>meṟku</unclear>
<lb n="8" break="no"/>n teṉpāṟ kellai cattirampuṟattār vāykkālukku vaṭakkum me
<lb n="9" break="no"/>lpāṟ kellai naṉtavāṉattukkuk kiḻakkum vaṭapāṟ kellai Aka<unclear>kki</unclear> 
<lb n="10" break="no"/>yāṉ velikkuk kiḻakkoṭiya vāykkālukkut teṟkum Ivicai<unclear>tta</unclear>
<lb n="11"/>perunāṉ kellaiyil Akappaṭṭa nilam Uṇṇila moḻiviṉṟi ca<hi rend="grantha">ntrā</hi>
<lb n="12" break="no"/>tittaval Akanāḻikaiyile muṉṟuviḷakku merivatāka vaitteṉ vi<unclear>ra</unclear>
<lb n="13" break="no"/><unclear>n</unclear>āraṇappallavaraiyaṉeṉ Itu pa<hi rend="grantha">nmā heśvara ratṣai <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi>
</p>

