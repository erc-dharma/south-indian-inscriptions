<lb n="31" break="no"/>ramaṁṭapābhirāmaṁ <g ref="sym:doubleBar" type="punctuation">.</g> mā
<lb n="32" break="no"/>rtaṁḍānvayatiḷakōbhamā
<lb n="33" break="no"/>t bhaktyā kānhōjikṣitipatirā
<lb n="34" break="no"/>tanōnmanōjñaṁ <g ref="sym:doubleBar" type="punctuation">.</g> <supplied reason="omitted">5</supplied> Ātrēyagō
