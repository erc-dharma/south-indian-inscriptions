<lb n="1"/><hi rend="grantha">dhairyādambudhisāmyamākalayatā</hi>
<lb n="2" break="no"/><hi rend="grantha">bhai<unclear>mi</unclear>kṣitīśānvayōttāsē</hi>
<lb n="3" break="no"/><hi rend="grantha">nōdayavarmmaṇā nṛpavarēṇātyā</hi>
<lb n="4" break="no"/><hi rend="grantha">darāt kāritē śrīmadrūpyataṭā</hi>
<lb n="5" break="no"/><hi rend="grantha">katīramahitaśrīnīlakaṇṭhālayē</hi>
<lb n="6"/><hi rend="grantha">nirvvṛttaḥ kalaśō tsavō vi</hi>
<lb n="7" break="no"/><hi rend="grantha">jayatē śrīdēvavaryyōjvalaḥ</hi>
<lb n="8"/><hi rend="grantha">kōlambē ma</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ñ</seg><hi rend="grantha">juḷēkṣaṇivṛṣabhagatē</hi>
<lb n="9"/><hi rend="grantha">tvaṣṭhabhē saumyavārē dvādaśyām siṁ</hi>
<lb n="10" break="no"/><hi rend="grantha">harāśau pavanajatanayakṣmāpavaryya</hi>
<lb n="11" break="no"/><hi rend="grantha">ḥ pragalbhaḥ śrīmadvarṇṇavatā karataṭagi</hi>
<lb n="12" break="no"/><hi rend="grantha">riśasyālayam <gap reason="lost" quantity="1" unit="character"/> yivitvā śrī grāma</hi>
