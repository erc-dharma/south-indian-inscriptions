<lb n="1"/>ko<supplied reason="omitted">p</supplied>parakecaripaṉmaṟku yāṇṭu muṉṟāvatu tevatā
<lb n="2" break="no"/>ṉam pātirippuliyūr pāratāyaṉ nilaṉ kumārar <hi rend="grantha">bhaṭṭassa</hi> hyā<hi rend="grantha"/>
<lb n="3" break="no"/>tipya<hi rend="grantha">so</hi> māciyār tammuṭaiya koṟṟantaikollaip
<lb n="4"/>patiṉaiñcu miḻalaipulattu Iraṇṭu māvum Erippulattu
<lb n="5" break="no"/>k kālum ve<unclear>ḷā</unclear>ṉpulattu Eḻunūṟu kamukum pāttiyum teṅka
<lb n="6" break="no"/>ñaceri munnūṟu mivai Aiyvar <hi rend="grantha">brāhma</hi> ṇarkku <hi rend="grantha"><unclear>bra</unclear>hmadev(ā)</hi>
<lb n="7" break="no"/><hi rend="grantha">mā</hi> ka Avar <unclear>kā</unclear>ṭṭiṉa ceriyile yillam Ottik kuṭiiruntu Aṉupa
<lb n="8" break="no"/>vippatākavum Ivai <unclear>vi</unclear>ṟṟukkoḷḷavum Oṟṟivaikkavum pe
<lb n="9" break="no"/>ṟā<unclear>tārā</unclear>kak kuṭutteṉ <hi rend="grantha">ssahyā</hi>ti pya<hi rend="grantha"> so</hi> māciyeṉ I
<lb n="10" break="no"/>tu <hi rend="grantha">sa</hi>vai yār ra<hi rend="grantha">kṣai</hi> Itu <hi rend="grantha">rakṣi</hi> ppār cipātam Eṉ ṟalai
<lb n="11"/>mela <supplied reason="undefined"><g type="ddanda">.</g></supplied>
