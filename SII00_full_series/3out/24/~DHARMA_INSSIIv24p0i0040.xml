<p>
<lb n="1"/> <gap reason="lost" quantity="15" unit="character"/> <hi rend="grantha">svastiśrī</hi> pukaḻ cūḻn=ta puṇari Akaḻ cūḻn=ta puviyil ponnemi <gap reason="lost" quantity="15" unit="character"/> koṭṭattu <gap reason="lost" quantity="10" unit="character"/> putumaṇam <gap reason="lost" quantity="10" unit="character"/> porppari naṭāttik kīrtti <gap reason="lost" quantity="10" unit="character"/> ppāvaiyum tanimaiyum tavi<supplied reason="omitted">r</supplied>ntu punita
</p>

