<p>
<lb n="1"/><hi rend="grantha">rājade</hi>vaṟkku yāṇṭu <num value="24">2 <g type="numeral">10</g> 4</num>vatu tiruvaraṅkat <gap reason="lost" quantity="10" unit="character"/> 
<lb n="2"/><hi rend="grantha">de</hi>yam vempaṟṟūrākiya Avaṉināraṇaccatu<hi rend="grantha">rvve</hi>ti <gap reason="lost" quantity="8" unit="character"/> 
<lb n="3"/> <gap reason="lost" quantity="6" unit="character"/> Āḻvār paṅkuṉit tirunāḷilum Aiyppikait tirunāḷi <gap reason="lost" quantity="5" unit="character"/> 
<lb n="4"/>tu nicatam Iraṇṭu paruppup poṉakam paḻampaṭi Amitu ceytaru <gap reason="lost" quantity="7" unit="character"/> 
<lb n="5"/>canti<unclear>rāti</unclear>ttaval celvatāka vaiytta mutaṟ poṉ <hi rend="grantha"><num value="10"><g type="numeral">10</g></num>ç</hi> ru ma <gap reason="lost" quantity="6" unit="character"/> 
<lb n="6"/>vippom tiruvaraṅkattu <hi rend="grantha">sabhai</hi>yom Itu <hi rend="grantha">śrī va</hi>yi<hi rend="grantha">ṣṇa</hi>va<hi rend="grantha">rakṣ<unclear>ai</unclear></hi>
</p>

<p><hi rend="bold">RĀJĒNDRA I</hi></p>

