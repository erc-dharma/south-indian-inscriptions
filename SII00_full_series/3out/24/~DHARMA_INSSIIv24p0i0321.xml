<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">śrīmat kīlakanādni hāyanavarē</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">vai</seg><hi rend="grantha">śākhamāsi sthirē vārē vāsavamantriṇa śśu<supplied reason="omitted">bha</supplied> tithau sampūrṇaśīta dvatau</hi><note n="328-2">Read <hi rend="grantha">dyutau</hi></note><g type="danda">.</g>
<lb n="2"/><hi rend="grantha">dvāram raṅgapatē rvimāna vaḷabhī ḷaddhyaṅgatām rājatīm śrī mānaṇṇapama ntrisūnu rakarōt śrīpatyamātyēśvaraḥ §</hi>
</p>

