<lb n="27"/><hi rend="grantha">kanakamayam vimānamakhi</hi>
<lb n="28" break="no"/><hi rend="grantha">lam śayanañca harēri</hi>
<lb n="29" break="no"/><hi rend="grantha">ha sukṛtādarādakṛ</hi>
<lb n="30" break="no"/><hi rend="grantha">ta sundarapāṇḍyanṛpa<unclear>ḥ</unclear> <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi>
<lb n="31"/><hi rend="grantha">Ārūḍassakalā vi</hi>
<lb n="32" break="no"/><hi rend="grantha">jitya kakubhō raṅ</hi>
<lb n="33" break="no"/><hi rend="grantha">gē dvitīyāntulā</hi>
<lb n="34" break="no"/><hi rend="grantha">martthaiḥ kēraḷa cō</hi>
<lb n="35" break="no"/><hi rend="grantha">ḷa hō</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">y</seg><hi rend="grantha">saḷa kula</hi>
