<lb n="40" break="no"/><hi rend="grantha">pāṇḍyadēva<unclear>nṛū</unclear>pati</hi>
<lb n="41" break="no"/><hi rend="grantha">rhaimāñca<unclear>ca</unclear>krē harēḥ <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi>
