<p>
<lb n="1"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> pautrō bukkanarēndra</hi>
<lb n="2" break="no"/><hi rend="grantha">sya dauhitrō rāmabhūpatēḥ <g ref="sym:bar" type="punctuation">.</g></hi>
<lb n="3"/><hi rend="grantha">vidyatē hi virūpākṣō rā</hi>
<lb n="4" break="no"/><hi rend="grantha">jā hariharātmajaḥ <g ref="sym:bar" type="punctuation">.</g></hi>
<lb n="5"/><hi rend="grantha">svasti śrī <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> vimānam gōpuram vaprammu</hi>
<lb n="6" break="no"/><hi rend="grantha">nā maṇḍapādikam <g ref="sym:bar" type="punctuation">.</g> puram p<unclear>ā</unclear></hi>
<lb n="7" break="no"/><hi rend="grantha">ccilitikhyātam kṛtandattañca cakriṇē <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi> 
</p>

