<p>
<lb n="1"/><hi rend="grantha">svastiśrīḥ <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> śrī kāntaḥ kamalāsanastimirabhiddēvō manū rāghavō</hi>
<lb n="2"/><hi rend="grantha">yatrā<unclear>dy</unclear>āḥ kalikālacōḷanṛpatirvviśvakṣitiśōpyatha <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> tadvamśya<unclear>ḥ</unclear>kila dā</hi>
<lb n="3" break="no"/><hi rend="grantha">yabhīmanṛpatistannandanō pēttabhūn<choice><sic>a</sic><corr>ā</corr></choice>thastajjani rē</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṟa</seg><hi rend="grantha">siddhirajani śrītammu</hi>
<lb n="4" break="no"/><hi rend="grantha">siddhistataḥ <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> § svastiśrī śśākavarṣē rasakara śaśibhūsammitē tammusiddhikṣō</hi>
<lb n="5" break="no"/><hi rend="grantha">ṇīndrō sāndrakirtti ssavitṛ kulavibhurmmanmasiddhānujanmā <supplied reason="undefined"><g ref="sym:bar" type="punctuation">.</g></supplied> śrīdēvyāmē</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṟa</seg> <hi rend="grantha">siddhēru</hi>
<lb n="6"/><hi rend="grantha">dita</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">uru</seg><hi rend="grantha">matamṇōmaṇim paṇṭarāṣṭrē grāmam śrīraṅganallūriti punarabhidhandatta</hi>
<lb n="7"/><hi rend="grantha">vānnraṅgadhāmmē <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> §</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">maturāntakappottappiccoḻaṉāṉa nalla</seg><hi rend="grantha">siddhara</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">can ci</seg>
<lb n="8" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">raṅkanātaṟkku tiruviṭaiyāṭṭamāka viṭṭa paṭṭaiyanāṭṭu muṇompūṭṭiyāna ciraṅ</seg>
<lb n="9" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">kanallūr Ittaṉmattai Iṟakkiṉāruṇṭākil kaṅkaik karaiyil nūṟāyiram ko</seg><hi rend="grantha">brāhmaṇa</hi>
<lb n="10" break="no"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">rai vatitta pāpam koḷvān Ippaṭikku nellūril tiruppāṟkaṭal tirumuṟṟattu</seg>
<lb n="11"/><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tiruvācalile kalveṭṭu<unclear>ka</unclear></seg>
</p>

<p><hi rend="bold">PĀṆḌYAS.</hi></p>

