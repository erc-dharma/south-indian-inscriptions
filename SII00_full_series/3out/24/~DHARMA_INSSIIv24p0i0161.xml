<lb n="1"/><hi rend="grantha">svastiśrī <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi> tiripuvaṉaccakkaravattikaḷ <hi rend="grantha">śrī</hi>rā<hi rend="grantha">jarājade</hi>vaṟku yāṇṭu <num value="28">2 <g type="numeral">10</g> 8</num> Etirāmāṇṭu <hi rend="grantha">so</hi>mala<hi rend="grantha">de</hi>viyār tāti māccavai makaṉ <hi rend="grantha">so</hi>makkaṉ taṉakkun tāyā
<lb n="2" break="no"/>ṟkun tantaikku naṉṟāka <hi rend="grantha">śrī</hi>raṅkanātaṉukku tiruṉantavaṉañceytu tirumālai Eṭukka Iṭavai Irā<hi rend="grantha">ja</hi>ma<hi rend="grantha">he</hi>ntira <gap reason="lost" quantity="3" unit="character"/> pakkal koṇṭa tiruṉan <gap reason="lost" quantity="5" unit="character"/> 
<lb n="3"/>tiruvaravaṇaippiramātirāyar tirunan=tavaṉattukku meṟkum vicaiyarāyar vāykkālukku vaṭakku vaṇṭuvarāvati ṉampi tiruṉan=tavaṉattukku kiḻakkum meṟku
<lb n="4"/>ṉokkip pokiṟapperuvaḻikku teṟku ṉaṭuvuḷppaṭṭa nilattu [p(pa)paraviṉa] maranilai Oḻi<supplied reason="omitted">ya</supplied> nikki Uḷḷa pūmi ta<hi rend="grantha">t</hi>kā<hi rend="grantha">loji</hi>ta<hi rend="grantha">t</hi><note n="191-1">Read ta<hi rend="grantha">tkāloci</hi>ta</note> <hi rend="grantha">kra</hi>yamāka Araimaṉai mariyāti po
<lb n="5" break="no"/>ṉ Irupatum ku<supplied reason="omitted">ṭu</supplied>ttu Iṭavai tiruvaraṅka<hi rend="grantha">dāsa</hi>r tiruṉantava<supplied reason="omitted">ṉa</supplied>ñceyvārāka <hi rend="grantha">dhā</hi>rāpū<hi rend="grantha">rvakamā</hi>ka cantirātittava<hi rend="grantha">t</hi> naṭappatāka Ippaṭi kalveṭṭikkuṭutteṉ <hi rend="grantha">so</hi>mak kaṉeṉ <supplied reason="undefined"><g type="ddanda">.</g></supplied>
