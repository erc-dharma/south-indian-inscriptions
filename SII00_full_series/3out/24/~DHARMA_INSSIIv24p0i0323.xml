<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī vijayakṣmāpanandanē lōkanandanē <g type="danda">.</g> pratāpadēvarāyākhyē pārtthivē rakṣati kṣitīm <g type="danda">.</g> <supplied reason="omitted">1</supplied> yaśōlōkē śakasyābdē saumyē mithunagē ravau <supplied reason="undefined"><g type="danda">.</g></supplied> Uttaraprōṣṭa</hi>
<lb n="2" break="no"/><hi rend="grantha">pāt kṛṣṇaṣaṣṭhī śōbhanaviddinē [<g type="ddanda">.</g>2*] jananī maratakaval</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">lī</seg> <hi rend="grantha">janakō yasya khalu dakṣiṇāmūrttiḥ <g type="danda">.</g> grāmaśca cil</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">la</seg><hi rend="grantha">mantā gōtrābhijanaunitundinimapākhyau <g type="danda">.</g> <supplied reason="omitted">3</supplied> Anēna śrīrāmacandra</hi>
<lb n="3" break="no"/><hi rend="grantha">sarasvatyabhidhāt gurōḥ <g type="danda">.</g> Avāptapārivrājyēna bhōgavarddhanasamsadā <g type="danda">.</g> <supplied reason="omitted">4</supplied> bhaktyā śrīraṅgarājāya vyāsabhāratiyōginā <g type="danda">.</g> grāmassamarppitōnāmnā</hi>
<lb n="4"/><hi rend="grantha">hasticōḷēndramaṅgalam <g type="danda">.</g> <supplied reason="omitted">5</supplied> Agratō nivēdanīyamannama</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ṅaha</seg><hi rend="grantha">m harēragrimēṣu ṣaṭsu hēmabhājanēṣu ṣaḍrasam <supplied reason="undefined"><g type="danda">.</g></supplied> mālikāyugatrayam varānulēpa</hi>
<lb n="5" break="no"/><hi rend="grantha">nāmbarē dīpikācatuṣṭayam saṣōḍaśōpacārakam [<g type="danda">.</g>6*] vāsarē tṛtiyayāmmāgatē sadōtsavam vyāsabhāratīvidhātumēvamēva raṅgiṇē [<g type="danda">.</g>]</hi>
<lb n="6"/><hi rend="grantha">grāmmā <gap reason="lost" quantity="1" unit="character"/> jēśayāya cōḷamaṇḍalīgatam hasticōḷamaṅgalābhidhāna mādarāddāt <g type="danda">.</g> <supplied reason="omitted">7</supplied> vyāsabhāratyāśś</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">l</seg><hi rend="grantha">ōkāḥ śrīraṅgarājārppaṇamastu <supplied reason="undefined"><g type="ddanda">.</g></supplied></hi>
</p>

