<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">

<p>
<lb n="1"/>paritāpi varu<hi rend="grantha">ṣa</hi>m mārkaḻi mātam <hi rend="grantha">1—</hi>
<lb n="2"/>U koneriteva ma<hi rend="grantha">hā</hi>—
<lb n="3"/>Irācāviṉ Ava<hi rend="grantha">saram</hi>
<lb n="4"/>Āka nāḷatu mutal Utaiya—
<lb n="5"/>kālattile Orutaḷikai
<lb n="6"/>mucarotaram Āka perumā—
<lb n="7"/>ḷ Amutu ceytu Aruḷum pa—
<lb n="8"/>ṭikku Ava<hi rend="grantha">sara</hi> kaṭṭaḷaik—
<lb n="9"/>ku cetta piccāṇṭār ko—
<lb n="10"/>yil viṭuveli nilam <hi rend="grantha">3—</hi>
<lb n="11"/>li Inta muvelinilattil
<lb n="12"/><hi rend="grantha">Ubh</hi>aiyamum koṇṭu can—
<lb n="13"/>tiṟātittiyavaraiyum Ava<hi rend="grantha">sa—</hi>
<lb n="14"/><hi rend="grantha">ra</hi>kaṭṭaḷai naṭakkaṭava—
<lb n="15"/>tu Ākavum <supplied reason="undefined"><g type="danda">.</g></supplied>
</p>

