<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svasti śrī śakābdam 1493</hi>- <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">Itaṉmel cellāniṉṟa</seg> <hi rend="grantha">prajō</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">tpatti</seg> <hi rend="grantha">samvatsara</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttu</seg> <hi rend="grantha">vṛ<unclear>ścika</unclear></hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">nāyaṟṟu</seg> <hi rend="grantha">pūrvva</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">pakṣattu</seg> <hi rend="grantha">dvādaśi</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">yu</seg>—<note n="477-1">Continuation is lost.</note>
<lb n="2"/><hi rend="grantha">Uhai</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">yamāka Amutu ceytaruḷum Ava</seg><hi rend="grantha">sa</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">rakaṭ(ṭa)ḷaikku tiruviḷaiyāṭṭa<unclear>m</unclear>māka</seg> <hi rend="grantha">grā</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">maṅkaḷ vi <gap reason="lost" quantity="3" unit="character"/> kku nācciyār śrīra</seg><hi rend="grantha">ṅga</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">nāya—</seg><note n="477-1">Continuation is lost.</note>
<lb n="3"/><hi rend="grantha">nyagōtratti Āpastampasūtra</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ttu</seg> <hi rend="grantha">yējuśśākhā<unclear>dhyā</unclear>yi</hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">Āṉa viravalli Aṇṇaṅkāṟku kaṭṭaḷaiiṭṭa taḷikai Oṉṟum</seg> <hi rend="grantha">Ācandrārkasthā—</hi><note n="477-1">Continuation is lost.</note>
<lb n="4"/><hi rend="grantha">dānapālanayōrmmaddhyē dānāt śrēyōnupā <g ref="sym:bar" type="punctuation">.</g> lanam [<g ref="sym:bar" type="punctuation">.</g>] dānātsvargamavāpnōti pālanādaccutam</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">pa</seg><hi rend="grantha">dam <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi> <seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">Ippaṭikku Inta</seg> <hi rend="grantha">śilāśāsanam—</hi><note n="477-1">Continuation is lost.</note> 
</p>

