<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">svastiśrī <supplied reason="omitted">ḥ</supplied> prauḍhaśrīdēvarāyādalabhata vimala mmauktika chśatramuccam saudhāna ddham samṛddham</hi>
<lb n="2"/><hi rend="grantha">kanakajakalaśam kāhaḷē dīpikē ca <g type="danda">.</g> prāpat sauvarṇamañcam maṇigaṇakhacitam maṅgala</hi>
<lb n="3" break="no"/><hi rend="grantha">snānapāthōvāham haimam kaḍāram vijayanagarapatēruttamō nampirāyaḥ [<g type="danda">.</g>1*] dantyākhēṭakadēvarāyanṛ</hi>
<lb n="4" break="no"/><hi rend="grantha">patiprāptasphuranmauktikachśatrōtbhāsitasaudhahēmakalaśīdīpadvayīkāhaḷaḥ <g type="danda">.</g> śrīmānuttamarā</hi>
<lb n="5" break="no"/><hi rend="grantha">ya Ēṣa vijayakṣōṇīpatēḥ kāñcanam mañcam hēmakaḍāramamciētayaśāḥ prāpat pratāpōjvalaḥ <g type="danda">.</g> [<g type="danda">.</g>2*]</hi>
<lb n="6"/><hi rend="grantha">kāśyapānva(vā)yasindhu śītarōcirartthinām kāṅkṣitārtthavarggasiddhiragraṇīma rmanasvinā<supplied reason="omitted">m</supplied> <g type="danda">.</g> rāśiraṣṭavaibhavasya raṅgadhāma</hi>
<lb n="7" break="no"/><hi rend="grantha">dhūṣṭhahō</hi><note n="322-2">Read <hi rend="grantha">dhurvvahō</hi></note> <hi rend="grantha"><g type="danda">.</g> ramyamārggakiṅkarastu dēvarāyabhūpatēḥ <g type="danda">.</g> [<g type="danda">.</g>3*] pārśva sēvamāna hastisa ccatuṣpradīpikā bhavanarājahēmakum</hi>
<lb n="8" break="no"/><hi rend="grantha">bhbhākaḍāhamañcasāmrājya</hi><note n="322-3">The mistake of <hi rend="italic">yati bhagga</hi> has occurred in the syllable <hi rend="grantha">mrā</hi> in this word.</note> <hi rend="grantha">cinhamauktikātapatrabhadrakāhaḷam mānyavarggabhūṣaṇāni vāhanāni cāgrahīt <g type="danda">.</g> <supplied reason="omitted">4</supplied></hi>
<lb n="9"/><hi rend="grantha">śubhamastu <supplied reason="undefined"><g type="danda">.</g></supplied> yasminnyastabharasvayam phaṇipatau nidrāti raṅgē hariḥ pādam yasya samarccayantisattammau</hi>
<lb n="10" break="no"/><hi rend="grantha">lisrajāpārtthivāḥ yasyōpēndrēsamō mahēndrayaśasa<supplied reason="omitted">ḥ</supplied>śrīcakrarājōnuja ssākṣāduttamarāya</hi>
<lb n="11" break="no"/><hi rend="grantha">ēṣa bhuvanē sañcāri raṅgādhipaḥ <g type="danda">.</g> [<g type="danda">.</g>5*]</hi> 
</p>

