<lb n="1"/><hi rend="grantha">śubhamastu svastiśrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> śakābdam <num value="1547"><g type="numeral">1000</g> 5 <g type="numeral">100</g> 4 <g type="numeral">10</g> 7</num></hi> Itaṉ mel cellā niṉ<supplied reason="omitted">ṟa</supplied> <hi rend="grantha">kṣa</hi>ya varu<hi rend="grantha">ṣa</hi>m
<lb n="2"/>kāttikai <hi rend="grantha"><num value="15"><g type="numeral">10</g> 5</num>§</hi> viru<hi rend="grantha">kṣi</hi>kanāyaṟṟu <hi rend="grantha">pūrvapakṣa</hi>ttu cattamiyum kuruvāra
<lb n="3" break="no"/>mum peṟṟa cataiyana<hi rend="grantha">kṣatra</hi>ttu ṉāḷ teṉkarai pāṇṭikulācanivaḷanā
<lb n="4" break="no"/>ṭṭu viḻāvaṟāviti vaḷanāṭṭut tiruvaraṅkam tiruppati perumāḷ <hi rend="grantha">śrī</hi>ra<hi rend="grantha">ṅga</hi>nātateva
<lb n="5" break="no"/>r <hi rend="grantha">śrī</hi>paṇṭārattukku tirumaṅkaiyāḻvār <hi rend="grantha">śrī</hi>kāriyam pārkkiṟa tecāntari Aḻakiya
<lb n="6" break="no"/>ciyaneṉ teṇṭaṉ camarpittu poliyūṭṭu <hi rend="grantha">śi</hi>lācā<hi rend="grantha">sa</hi>nam paṇṇikkuṭutta
<lb n="7" break="no"/>paṭi perumāḷ <hi rend="grantha">śrī</hi>ra<hi rend="grantha">ṅga</hi>ṉātatevaṟku tiru <gap reason="lost" quantity="10" unit="character"/> 
<lb n="8"/>maṅkai Āḻvār tivyappirapantam namperumāḷ <gap reason="lost" quantity="5" unit="character"/> 
<lb n="9"/>kai Āḻvār<note n="508-2">The rest of the writing is highly damaged and indistinct.</note> 
</p>

