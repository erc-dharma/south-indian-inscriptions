<lb n="1"/>yāṇṭu <num value="25">2 <g type="numeral">10</g> 5</num> Āvatu Āḻvār kanmikaḷom Uṭaiyār <hi rend="grantha">śrīrājentra</hi>tevar nampi rāṭṭiyār rā<hi rend="grantha">ja</hi>rā<hi rend="grantha">ja</hi>n Arumoḻiyārāna tennavan māteviyār
<lb n="2"/>tām munpu tiruttuvitta nilattukku vaṭak<unclear>kiṭai</unclear> nilam katili Āḻvārkku Iṟai Iṟutti Iṟai mikuti koṇṭu <hi rend="grantha"><unclear>bha</unclear>ha</hi>varkaḷukku <hi rend="grantha">bhikṣai</hi> vaikka
<lb n="3"/>kaṭavārākavum Iṅke kāṭu veṭṭikaḷ peṇṭāṭṭi rā<hi rend="grantha">ja</hi> māṇikkam Iraṇṭu tiru nāḷilum Eḻā nāḷaikku tiruppāñcāṭik kīḻp parappum
<lb n="4"/><hi rend="grantha">Akṣa</hi>tai Aricikku tiruttivitta nilam kālmā <gap reason="lost" quantity="10" unit="character"/> Iṟai mikuti
