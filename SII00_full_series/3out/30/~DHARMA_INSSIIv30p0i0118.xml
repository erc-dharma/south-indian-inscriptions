<div type="edition" xml:lang="und" rendition="class:grantha maturity:vernacular">

<p>
<lb n="1"/><hi rend="grantha">Ādāvagnira pūjaya ccivamajam śrī</hi>
<lb n="2" break="no"/><hi rend="grantha">pōntai nātham pūnastrē tāyāntri</hi>
<lb n="3" break="no"/><hi rend="grantha">daśārccitam himakara lādhudhaṅpā</hi>
<lb n="4" break="no"/><hi rend="grantha">parē sākṣādrēsāmaśa nmīni<supplied reason="omitted">bhi</supplied><unclear>śca</unclear>na</hi>
<lb n="5"/><hi rend="grantha">kratantai rēvaśa</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">c</seg><hi rend="grantha">ai</hi><seg xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">ta<supplied reason="omitted">H</supplied></seg> <hi rend="grantha">sthalam mānnyā</hi>
<lb n="6"/><hi rend="grantha">yam vana nāyakaḥ kalidhugēsam</hi>
<lb n="7"/><hi rend="grantha">sthāpya gandhādibhiḥ</hi>
</p>

