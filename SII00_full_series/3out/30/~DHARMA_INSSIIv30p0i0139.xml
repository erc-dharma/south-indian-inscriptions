<lb n="1"/><hi rend="grantha">svastiśrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></hi> matirai koṇṭa koppara
<lb n="2" break="no"/>ke<hi rend="grantha">sa</hi>ripaṉmaṟkku yāṇṭu mu<supplied reason="omitted">ppa</supplied>tteḻā
<lb n="3" break="no"/>vatu tāmarkkoṭṭattut tiruvekam
<lb n="4" break="no"/>papuṟattu <hi rend="grantha">rājamallacca</hi>tu<hi rend="grantha"> rvvedi</hi>maṅ
<lb n="5" break="no"/>kalam yāḷuṅkaṇattāruḷ kūṭal kiḻār
<lb n="6"/>maṇiciva<hi rend="grantha">bhaṭṭa ssarvvakra</hi>tukkaḷ maka
<lb n="7" break="no"/>ṉ <hi rend="grantha">mahāde</hi>va<hi rend="grantha">bhaṭṭa</hi>ṉ <hi rend="grantha">śrī</hi>pontai
<lb n="8" break="no"/>y perumā<supplied reason="omitted">na</supplied>ṭikaḷukku Oru no<hi rend="grantha">ndā</hi>vi<supplied reason="omitted">ḷakku</supplied>kku vai
<lb n="9" break="no"/>tta poṉ patiṉāṟkaḻañcaraiy I
<lb n="10" break="no"/>ppoṉṉāl vaṉta palicaip po
<lb n="11" break="no"/>ṉ koṇṭu ca<hi rend="grantha">ndrāditya</hi>vaṟ Iravum paka<supplied reason="omitted">lum</supplied>
