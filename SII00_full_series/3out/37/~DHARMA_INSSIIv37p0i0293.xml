<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<!--<h4>First Face.</h4>-->

<p>
<lb n="1"/>naṁdana saṁvvatsara 
<lb n="2"/>vayiśākha ba 5 A 
<lb n="3" break="no"/>penukalapāṁṭi 
<lb n="4"/>nu naṁdavaraṁ tippireḍḍi koḍukulu kasa 
<lb n="6" break="no"/>vana pedatippana yeṟa 
</p>

<!--<h4>Second Face.</h4>-->

<p>
<lb n="7" break="no"/>dippana nala 
<lb n="8"/>nāgana cinatippa 
<lb n="9" break="no"/>na cinanāgana ja 
<lb n="10" break="no"/>nan tama taṁḍri 
<lb n="11"/>tippireḍiki tama 
<lb n="12"/>talli tippasānki 
<lb n="13" break="no"/>ṁ puṇyamu 
<lb n="14"/>gāṁ beṭiṁci 
<lb n="15" break="no"/>na daṁrmmagāḍi 
<lb n="16"/>maṁgaḷama 
<lb n="17" break="no"/>hā śrī <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> 
</p>

<!--<h4>Third Face.</h4>-->

<p>
<lb n="18"/>svadattā dvigu 
<lb n="19" break="no"/>ṇaṁ puṇyaṁ 
<lb n="20"/>paradattānupāla 
<lb n="21" break="no"/>naṁ paradattāpa 
<lb n="22" break="no"/>hārēṇa sva 
<lb n="23" break="no"/>dattaṁ niṣphalaṁ 
<lb n="24"/>bhavēt <supplied reason="undefined"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> 
</p>

