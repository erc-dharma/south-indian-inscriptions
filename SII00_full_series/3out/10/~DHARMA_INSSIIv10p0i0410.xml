<lb n="1"/>svasti śrīśubhaśakavaruṣa 
<lb n="2" break="no"/>ṁbulu 1188 Agu neṁ 
<lb n="3" break="no"/>ṭi kṣayasaṁvatsara kārtti 
<lb n="4" break="no"/>ka ba 13 gu śrīmatu mō 
<lb n="5" break="no"/>ṭṭupalli pracanna cennakēśa 
<lb n="6" break="no"/>vadēvaraku mōṭṭupalli 
<lb n="7"/>gollamaṁddaḍu Akhaṁḍa 
<lb n="8" break="no"/>dīpānaku Icinamōdā 
<lb n="9" break="no"/>lu 25 vīniṁ jēkoni kī 
<lb n="10" break="no"/>ḍaguṁppu mārebōya 
<lb n="11" break="no"/>ṁḍu putrānupavitrika 
<lb n="12" break="no"/>ṁ naḍapaṁgalavāṁḍu kī 
<lb n="13" break="no"/>ḍḍaguṁppu mārebōI 
<lb n="14" break="no"/>niki vritti kēsāvuramu<unclear>na</unclear> 
<lb n="15"/>dēvara naṁbidēvarājūnu 
<lb n="16"/>puruṣōttamapeddini yici 
<lb n="17" break="no"/>nacēnu na 10 <g ref="sym:doubleBar" type="punctuation">.</g> 
