<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>svasti samastapraśastisa 
<lb n="2" break="no"/>hitaṁ śrīmanmahāmaṁ 
<lb n="3" break="no"/>ḍḍalēśvara vīranārāya 
<lb n="4" break="no"/>ṇa cōḍabaddigadēvarāju 
<lb n="5" break="no"/>lu śakavaruṣaṁbulu 
<lb n="6"/>1183 ṇḍagu nēṁṭṭi ka 
<lb n="7" break="no"/>rkkāṭakasaṁkrāṁttināṁḍḍu 
</p>

<!--<h4>Face B.</h4>-->

<p>
<lb n="8"/>śrīnāthanābhīnīrajasaṁbhūta 
<lb n="9"/>brahmaṇaḥ purā <g ref="sym:bar" type="punctuation">.</g> jātā viśvaguṇā 
<lb n="10" break="no"/>kṣīṇalakṣmī rājaparaṁparā <g ref="sym:bar" type="punctuation">.</g> ta 
<lb n="11" break="no"/>syā baddigabhū pōbhū dvīranārā 
<lb n="12" break="no"/>yaṇāṁkitaḥ <g ref="sym:bar" type="punctuation">.</g> <unclear>cō</unclear>ḍadōraya 
<lb n="13"/>bhū<unclear>pō</unclear>nya putrōbhū dasyanaṁdda 
<lb n="14" break="no"/>naḥ <g ref="sym:doubleBar" type="punctuation">.</g> śrīśākābdē purāṣṭādaśaśaśi 
<lb n="15" break="no"/>gaṇitē karkkasaṁkrāntikālē sa prādā 
<lb n="16" break="no"/>ddīpa miṣṭaprada manavarataṁ cō 
</p>

<!--<h4>Face C.</h4>-->

<p>
<lb n="17" break="no"/>ḍabaddikṣitīśaḥ <g ref="sym:bar" type="punctuation">.</g> śrīmadbra 
<lb n="18" break="no"/>hmēśvarā yāśaśiravivi 
<lb n="19" break="no"/>śadaṁ gōkanāṁkgasya pautē sta 
<lb n="20" break="no"/>ddīpārtthaṁ ca vēlēṭijanapa 
<lb n="21" break="no"/>damahiṁ viṁśatidrōṇa 
<lb n="22"/>saṁkhyāṁ <g ref="sym:doubleBar" type="punctuation">.</g> 
</p>

