<lb n="1"/>svasti samadhigatapaṁcamahāśa 
<lb n="2" break="no"/>bdamahāmaṁḍḍalēśvara bhōganu 
<lb n="3" break="no"/>rēśvara durjjayakulavārddhivardha 
<lb n="4" break="no"/>na saṁpūrnnacaṁdra satyahariścaṁ 
<lb n="5" break="no"/>dra kīrttikāminīkusumakōdaṁḍa 
<lb n="6"/>bālamārttaṁḍa paga<unclear>pa</unclear>ṟabhīma 
<lb n="7"/>saṁgrāmarāma rājakaṇṭhīrava 
<lb n="8"/>karavālabhairava kīttibhaṁḍāracū 
<lb n="9" break="no"/>ṟakāṟa Annanaṁkakāṟa nāmādi 
<lb n="10"/>samastapraśastisahituṁ ḍaina śrīma 
<lb n="11" break="no"/>dīvanikaṁḍravāṭikēśavadēvanṛpā 
<lb n="12" break="no"/>luṁḍu muktīśvaraśrīmahādēvara 
<lb n="13"/>kakhaṁḍadīpamunakai Iccina mō 
<lb n="14" break="no"/>dālu 25 vī<unclear>ni</unclear>ṁ jillasūrebōyi 
<lb n="15" break="no"/>ṁḍu naḍipi<unclear>ḍi</unclear>vāṁḍu <g ref="sym:bar" type="punctuation">.</g> 
