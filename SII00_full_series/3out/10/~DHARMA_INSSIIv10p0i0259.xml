<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śrībhāmādhipatē rnnābhipadmā da 
<lb n="2" break="no"/>jani vākpatiḥ <g ref="sym:bar" type="punctuation">.</g> ta syājasya mukhā 
<lb n="3"/>jjāta śrīvatsamunipuṁga 
<lb n="4" break="no"/>vaḥ <g ref="sym:doubleBar" type="punctuation">.</g> ta danvavāyē kuladīpa kōbhū 
<lb n="5" break="no"/>t śrīprōlanāryya ssujanābjasū 
<lb n="6" break="no"/>ryyaḥ tasmā daja nyātmakulābthi 
<lb n="7" break="no"/>caṁdrō brahmāhvaya ścēvali 
<lb n="8" break="no"/>nādhamukhyaḥ <g ref="sym:doubleBar" type="punctuation">.</g> tasya dvijēṁdra 
<lb n="9" break="no"/>sya babhūva bhāryyā śrīyakka 
<lb n="10" break="no"/>māṁbā lalanābhirāmā <g ref="sym:bar" type="punctuation">.</g> tābhyā 
<lb n="11"/>mabhū ddhīnidhi rannimaṁci rvviriṁ 
<lb n="12" break="no"/>citulyō vilasatkaḷābhiḥ <g ref="sym:doubleBar" type="punctuation">.</g> kṣōṇī 
<lb n="13" break="no"/>pālaśirōvibhūṣaṇa mabhū 
<lb n="14"/>dājñā yadīyā sadā <g ref="sym:bar" type="punctuation">.</g> ya syā 
<lb n="15" break="no"/>sī nsurayōṣitāṁ bhasavārē 
<lb n="16"/>pratyartthināṁ kuṁṭani <g ref="sym:bar" type="punctuation">.</g> kīrtti 
<lb n="17"/>ryyasya digaṁganāsaha 
<lb n="18" break="no"/>carī dīpaḥ pratāpō bhuvaḥ <g ref="sym:bar" type="punctuation">.</g> 
<lb n="19"/>tasmi nkurvvati rājya midda ma 
<lb n="20" break="no"/>tulaṁ tyāgāṁkapōtādhi 
<lb n="21" break="no"/>pē <g ref="sym:doubleBar" type="punctuation">.</g> dhanadhānyādisaṁpūrṇnē nāta 
<lb n="22" break="no"/>vāṭīmahītalē <g ref="sym:bar" type="punctuation">.</g> śākābdē <unclear>vē</unclear>da 
<lb n="23"/>lōkēśamitē śrīmukhavatsa 
<lb n="24" break="no"/>rē <g ref="sym:doubleBar" type="punctuation">.</g> parōpakārasaṁpatti 
<lb n="25" break="no"/>siddhayē puṇyavṛddhayē 
<lb n="26"/>tulyāṁ kṣīranadīkulyāṁ 
<lb n="27"/>kāvēryyā kṛtavā nasau <g ref="sym:doubleBar" type="punctuation">.</g> 
<lb n="28"/>pōtāvurākhyaṁ pradhitā 
<lb n="29" break="no"/>grahāraṁ hiṁtālatā 
<lb n="30" break="no"/>lāgurunālikēraiḥ <g ref="sym:bar" type="punctuation">.</g> vi 
<lb n="31" break="no"/>bhrājitōdyānajalāśayā 
<lb n="32" break="no"/>ḍhyaṁ kṣōṇīvadhū<unclear>hyā</unclear>bhara 
<lb n="33" break="no"/>ṇaṁ sma<unclear>dha</unclear>ttē <g ref="sym:doubleBar" type="punctuation">.</g> rājāka<unclear>lpa</unclear>ta 
<lb n="34" break="no"/>yā vṛṣadhvajatayā <gap reason="lost" quantity="1" unit="character"/> 
<lb n="35"/>lāji<unclear>rā</unclear>tuktayā <g ref="sym:bar" type="punctuation">.</g> śaśva 
<lb n="36"/><unclear>tsō</unclear>matayā narastutatayā 
<lb n="37"/>suśrīprabhābhṛttayā māṁ 
<lb n="38"/>matvā samamātta nēti kṛta 
<lb n="39" break="no"/>vān tasmiN bhava śśaṁbhavē <g ref="sym:bar" type="punctuation">.</g> ta 
<lb n="40" break="no"/>smai suṁdaramaṁdiraṁ <gap reason="lost" quantity="2" unit="character"/> 
<lb n="41"/>makarōt śrīyanimaṁci 
<lb n="42"/> <gap reason="lost" quantity="3" unit="character"/> prādā nnivarttanānā 
</p>

<!--<h4>Next Face.</h4>-->

<p>
<lb n="43"/> <gap reason="lost" quantity="2" unit="character"/> ṣaṭkaṁ tasmai saśaṁbhavē <g ref="sym:bar" type="punctuation">.</g> havi 
<lb n="44"/> <gap reason="lost" quantity="2" unit="character"/> rccanādyartthaṁ pōtabhūpā 
<lb n="45"/> <gap reason="lost" quantity="1" unit="character"/> <unclear>śā</unclear>sanāt <g ref="sym:doubleBar" type="punctuation">.</g> yāgaiḥ kṣētrē su 
<lb n="46" break="no"/>rakṣōṇīsuratuṣṭikṛta ssadā 
<lb n="47"/>saṁrakṣaṇaṁ svabaṁdhūnā ma 
<lb n="48"/> <gap reason="lost" quantity="4" unit="character"/> madyutaṁ <g ref="sym:doubleBar" type="punctuation">.</g> 
<lb n="49"/>svadattāṁ paradattāṁ vā yō ha 
<lb n="50" break="no"/>rēti vasuṁdharāṁ sa tiryya 
<lb n="51" break="no"/><unclear>ktva</unclear> mavāpnōti jāyamānaḥ 
<lb n="52"/>punaḥ punaḥ <g ref="sym:doubleBar" type="punctuation">.</g> 
</p>

<p><hi rend="italic">Note:</hi>—The year 1134 should be taken as an expired year.</p>

