<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>svasti śakābdaṁbulu 
<lb n="2"/>1016 ṇḍavu nēṇḍu śrīma 
<lb n="3" break="no"/>danaṁttavarmmadēvara pra 
<lb n="4" break="no"/>varddhamānavijayarā 
<lb n="5" break="no"/>jyasaṁvatsaraṁbulu 
<lb n="6"/>65 gu śrāhi tulā śukla 
<lb n="7" break="no"/>kārtya punnamayu guru 
<lb n="8" break="no"/>vāramuna vihāravāḻa 
<lb n="9"/>vīṭa śrīpādamulu gaṁgga 
<lb n="10" break="no"/>snānamu sēyunavasaramu 
<lb n="11" break="no"/>na Alluṁ jōḍaga<unclear>ṁ</unclear>ggarāju 
<lb n="12"/>śrīpādamulaku vinna 
</p>

<!--<h4>Second Side.</h4>-->

<p>
<lb n="13" break="no"/>vamusēsi yānati 
<lb n="14"/>paḍiṁ danatallida<unclear>ṇḍru</unclear> 
<lb n="15" break="no"/>kula dharmmugā nēṟada 
<lb n="16"/>paṁppuna sārakināṇṭi 
<lb n="17"/>lōpalaṁ danajītava 
<lb n="18" break="no"/>ṭṭainama ṟuceṟvu Iṁddula 
<lb n="19"/>sōmīśvaradēvaraku 
<lb n="20"/>Akhaṇḍavarttidīpamu 
<lb n="21" break="no"/>lu reṇṭiki reṇḍu vuṭlu 
<lb n="22" break="no"/>nu yamudunakuṁ bu 
<lb n="23" break="no"/>ṭṭeṇḍunu Ācāryyabhō 
<lb n="24" break="no"/>gamu vuṭṭeṇḍunuṁ gā be 
<lb n="25" break="no"/>rasi nāluvuṭlunēla 
<lb n="26"/>Īceṟvuḍigguvalana 
<lb n="27"/>Ācaṁdrārkkamunakuṁ be 
<lb n="28" break="no"/>ṭṭitimi 
</p>

<!--<h4>Third Side.</h4>-->

<p>
<lb n="29"/>dīni nevvarēni 
<lb n="30"/>kālaviparīta 
<lb n="31" break="no"/>mulaṁ<unclear>ddu</unclear> vi 
<lb n="32" break="no"/>cchinnamu sēsi 
<lb n="33"/>rēni gaṁgga kaṟu 
<lb n="34" break="no"/><unclear>ta</unclear> vēyuga 
<lb n="35" break="no"/>vulala vadhi 
<lb n="36" break="no"/>ṁcina paḍu 
<lb n="37" break="no"/>pāpamuna 
<lb n="38" break="no"/>ṁ baḍaṁggala 
<lb n="39" break="no"/>vāru 
</p>

