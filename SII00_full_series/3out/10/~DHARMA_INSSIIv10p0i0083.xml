<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>svasti sakavarṣaṁbulu 1047 
<lb n="2"/>nēṇḍi makaramāsamuna griṣna 
<lb n="3"/>yēkādaśiyu sukravāra 
<lb n="4" break="no"/>mu nāṇḍu śrīmanmahāmaṇḍalē 
<lb n="5" break="no"/>śvara kolaniyakettugaṇḍaṇḍu 
<lb n="6"/>ḍuttikavāsukiravisōmīśva 
<lb n="7" break="no"/>ramahādēvaraku nilipina 
<lb n="8"/>Akhaṇḍavattidīpamunaku ni 
<lb n="9" break="no"/>ṁdula manniyatīṟupayiḍ<unclear>li</unclear> yā 
<lb n="10" break="no"/>caṁdrārkamu niccitimi dīniṁ jēko 
<lb n="11" break="no"/>ni yiṁdula sānimunnūṟuvuru 
<lb n="12"/><unclear>ni</unclear>tyamummaḍibhīma 
<lb n="13"/>mānika māneṁḍu neyi vōya 
<lb n="14" break="no"/>ṁgalavāru 
</p>

<!--<h4>Second Face.</h4>-->

<p>
<lb n="15"/>kolanu yē 
<lb n="16" break="no"/>vārēlirēni yiṁdu 
<lb n="17" break="no"/>la manniyatīṟu 
<lb n="18"/>yīdīpamunaku 
<lb n="19"/>sariṁpaṁgalavāru 
<lb n="20"/>dīni<unclear>ki</unclear> vighnamu sē 
<lb n="21" break="no"/>sinavāru gaṁga 
<lb n="22"/> <gap reason="lost" quantity="1" unit="character"/> kaṟuta kavalala 
<lb n="23"/>jaṁpinavāru bha 
<lb n="24" break="no"/>ranāsi pracinavā 
<lb n="25" break="no"/>ru pe<unclear>dda</unclear>koḍuku kāpa 
<lb n="26" break="no"/>lamuna guḍicina<unclear>vāru</unclear> 
</p>

