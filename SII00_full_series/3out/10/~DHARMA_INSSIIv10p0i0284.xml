<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śrīmacceṁdrārthamauḷē rudabhava 
<lb n="2"/>davanipālacūḍārccitāṁghiḥ 
<lb n="3"/>kāḍveṭṭibhālanētrō dvijavarasa 
<lb n="4" break="no"/>mitē ssaptakagrāmadātā <g ref="sym:bar" type="punctuation">.</g> snātvā 
<lb n="5"/>gaṁggāṁbhasi <gap reason="lost" quantity="1" unit="character"/> vyajāyatē 
<lb n="6"/> <gap reason="lost" quantity="1" unit="character"/> rarṇavvīralakṣmīnivāsa stadva 
<lb n="7" break="no"/>ṁśā<unclear>syē</unclear>lalā mājani nijajanatā 
<lb n="8"/>pālanārāyaṇēśaḥ <g ref="sym:bar" type="punctuation">.</g> 1 <g ref="sym:bar" type="punctuation">.</g> tatputrō 
<lb n="9"/>mitratējā Udayananṛpati śśatruvallī 
<lb n="10"/>vidātrō gōrājāmāḍa <gap reason="lost" quantity="1" unit="character"/> tu rdvijabudha 
<lb n="11"/>janatājātamaṁdārabhūjaḥ <g ref="sym:bar" type="punctuation">.</g> tatsū 
<lb n="12" break="no"/>nu rddhārmmi kōbhū tsakalanuravarārārā <unclear>dhakō</unclear> 
<lb n="13"/>dānaśīlō vīrāmitrā <gap reason="lost" quantity="2" unit="character"/> gō vibhavasura 
</p>

<!--<h4>South Face, Bottom.</h4>-->

<p>
<lb n="14"/>pati rnnāgadēvakṣitīśaḥ <g ref="sym:bar" type="punctuation">.</g> 2 <g ref="sym:bar" type="punctuation">.</g> śākā 
<lb n="15" break="no"/>bdē śailabāṇakṣitiśaśigaṇitē bhā 
<lb n="16" break="no"/>skarēcōttarāsyē so dādācaṁdratā 
<lb n="17" break="no"/>raṁ satataśikha mabhīṣṭārddhasiddhyai 
<lb n="18"/>pradīpaṁ <g ref="sym:bar" type="punctuation">.</g> śrīmadbrahmēśvarāya 
<lb n="19"/>kṣiti matiphaladāṁ viṁśatidrō 
<lb n="20" break="no"/>ṇarūpāṁ taddīpārddhaṁ gavāṁ 
<lb n="21"/>cēṁdriya yugaḷamitiṁ mā 
<lb n="22" break="no"/>ragōpālakāṁkē <g ref="sym:doubleBar" type="punctuation">.</g> 3 <g ref="sym:doubleBar" type="punctuation">.</g> Asmaddēvā 
<lb n="23" break="no"/>ya tēnāsi dattā jalamahi varā <g ref="sym:bar" type="punctuation">.</g> savvrīhi 
<lb n="24"/>phaladā marttucataṣkāṁgā nivēdyasūḥ <g ref="sym:bar" type="punctuation">.</g> 
</p>

