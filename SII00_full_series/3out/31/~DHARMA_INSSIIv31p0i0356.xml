<div type="edition" xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">

<p>
<lb n="1"/>śivanāmatrayaṁ śivaśaṁbhō mahādēva <g ref="sym:bar" type="punctuation">.</g> dhyānaṁ <g ref="sym:bar" type="punctuation">.</g> 
<lb n="2"/>dhamārrdhadhaṁ śivannityaṁ kāmadaṁ śuṁbhumēvaca <g ref="sym:bar" type="punctuation">.</g> mōkṣapradaṁ 
<lb n="3"/>mahādēvaṁ <g ref="sym:bar" type="punctuation">.</g> dhyāyetsarvārdhasiddhayē <g ref="sym:bar" type="punctuation">.</g> phalaśruti <g ref="sym:bar" type="punctuation">.</g> manōvākkā 
<lb n="4" break="no"/>yajaṁ pāpaṁ kōṭijanmārjjitaṁ marhāśivaśaṁbhō mahādēva <g ref="sym:bar" type="punctuation">.</g> 
<lb n="5"/>kīrttinādēva gacciti śivanāmakayaṁ yastu sakpatpaṁti 
<lb n="6"/>mānavaḥ <g ref="sym:bar" type="punctuation">.</g> mahāpātakānāṁ pākarmucyatē nātra saṁśayaḥ <g ref="sym:bar" type="punctuation">.</g> 
<lb n="7"/>paṁcākṣara svarūpatyāt nkāmakāṁttargakuryataḥ 
<lb n="8"/>Aṣṭākṣara svarūpatvātnnāmatraya mudāhṛtaṁ 
<lb n="9"/>śaivannāma krayaṁlōke <g ref="sym:bar" type="punctuation">.</g> jayatisma sanātanaṁ 
<lb n="10"/>sadāśiva makhīṁdrēṇa guruṇā saṁprakāśitaṁ <g ref="sym:doubleBar" type="punctuation">.</g> 
</p>

