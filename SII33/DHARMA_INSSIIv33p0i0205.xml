                <p>
                    <lb n="1"/>śālivāhana śakābdaṁ 
                    <lb n="2"/>Ānaṁdanāma saṁmastaraṁ caitra śuddha daśami 
                    <lb n="3"/>śukravāramu kū<choice><sic>ṭ</sic><corr>ḍ</corr></choice>ina yī śubhadinamaṁdu 
                    <lb n="4"/>śrīraṁganādhuni<choice><sic>g</sic><corr>k</corr></choice>i śrījiḍḍuviśvanāthanāyini 
                    <lb n="6"/>gārivalla yī baṁgāru goḍugu cēya 
                    <lb n="7" break="no"/>baḍi prabhavanāma saṁvasvaraṁ mārga 
                    <lb n="8" break="no"/>śīriṣa nela rippēru cēyabaḍinadi 
                    <lb n="9"/><seg xml:lang="eng-Latn" rendition="class:latin maturity:undetermined">December 1927.</seg>
                </p>
                
