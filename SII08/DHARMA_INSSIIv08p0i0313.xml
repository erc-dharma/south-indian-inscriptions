	<text xml:space="preserve">
		<body>
			
			<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
				
				<p>
					<lb n="1"/><hi rend="grantha">svasti śrī</hi> <g ref="sym:bullet-double-hollow" type="symbol">*</g><g ref="sym:tam-pillaiyarCuli" type="ideogram">@</g><!--CHECK SYMBOL, updated from "pc"--> Ā<hi rend="grantha">dhi</hi>rā<hi rend="grantha"><unclear>ja</unclear>ma<unclear>ṅ</unclear>galyapura</hi>ttu Uṭaiyār tiruvī
					<lb n="2" break="no"/>raṭṭāṉamuṭaiya nāyaṉār koyil tānattā<supplied reason="omitted">r</supplied>kkum tevakaṉmi koyil
					<lb n="3" break="no"/>kaṇakkarkkum <unclear>ciṟu</unclear>muṟi <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> Uṭaiyār tiruvīraṭṭāṉamuṭaiya nāyaṉārkku 
					<lb n="4"/><unclear>yāṇṭu</unclear> <num value="10"><unclear><g type="numeral">10</g></unclear></num> paṅkuṉimātamutal tiruvotta<unclear>cā</unclear>mattu<unclear>t</unclear> tiruppaḷḷikkaṭṭilil
					<lb n="5"/>Eṟiyaruḷiṉāl Amutuceytaruḷa namperāl kaṭṭiṉa kāliṅkarāyaṉcanti
					<lb n="6" break="no"/>kku A<surplus>m</surplus>mutupaṭi paṭiveñcaṉattukku Urattipaṟṟil nām kāṇiyā
					<lb n="7" break="no"/>kak koṇṭa Atiyaṉūr<unclear>p</unclear>āṟ kāraṇai Innāḷmutal kār pacāṉa
					<lb n="8" break="no"/>m cittiraikkār puṉcai puṟavaṭai <unclear>pu</unclear>ṟavuṭal ceṭṭiṟai maṉai
					<lb n="9" break="no"/>iṟai cekkiṟai taṟiiṟai taṭṭārppāṭṭam <unclear>ku</unclear>ḷavaṭai māva
					<lb n="10" break="no"/>ṭai poṉvari kūṟṟilakkaik kaṭaikkūṭ<unclear>ṭi</unclear>lakkai viṭaip
					<lb n="11" break="no"/>per mātappaṭi vaṭṭaṅ kaṇkūli Aḷappaṉa mukappaṉa niṟuppaṉa
					<lb n="12"/>virippaṉa maṭippaṉa maṟṟum Eppeṟpa<unclear>ṭ</unclear>ṭa Aṉaittāyaṅ
					<lb n="13" break="no"/>kaḷum Uṭpaṭa tirunāmattukkāṇi Iṟaiyiliyāka tantom
					<lb n="14"/>Ippaṭikku kaikkoṇṭu Ivvūrilum nāṟpārkkellai
					<lb n="15" break="no"/>yilum tiruccūla<hi rend="grantha">sthā</hi>paṉam paṇṇi tirukkaṭṭaḷaiyilum mut
					<lb n="16" break="no"/>tūṟṟukkūṟṟattu ka<unclear>p</unclear>palūrāṉa Ulakaḷantacoḻanallūr karu
				</p>
				
