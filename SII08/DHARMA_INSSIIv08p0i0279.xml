	<text xml:space="preserve">
		<body>
			
			<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
				
				<p>
					<lb n="1"/><g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g> <hi rend="grantha">svasti śrī</hi> <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> makatecaṉ poṉparappiṉa vā
					<lb n="2" break="no"/>ṇakovataraiyaṉ tiṭṭaikuṭiyāṉa tirucciṟṟam
					<lb n="3" break="no"/>pala<hi rend="grantha">ca</hi>tu<hi rend="grantha">rvva</hi>timaṅkalattu nāyaṉār Ūruṭaiya
					<lb n="4" break="no"/>nāyaṉārkku makataimaṇṭalam teṉkarai toḻuvū
					<lb n="5" break="no"/>rpaṟṟil 5<g ref="sym:dash" type="punctuation">.</g>vatu cittiraimātamutalukku poṉparappiṉāṉcan
					<lb n="6" break="no"/>tikku tirunāmattukkāṇi Iṟaiyiliyāka tanta vākaiyūr nāṉ
					<lb n="7" break="no"/>kellaik kuṭpaṭṭa naṉcai puṉcai nattam natta<supplied reason="omitted">p</supplied>puṉcai karai
					<lb n="8" break="no"/>ppuṉcai meṉokkiṉa maram kīṇokkiya turavu Uṭpaṭṭa nilat
					<lb n="9" break="no"/>til paḻantevatāṉam tiruviṭaiyāṭṭam paḷḷiccantam paṭṭa<unclear>r</unclear>ka
					<lb n="10" break="no"/>ḷ Iṟaiyili nīṅkalāṉa naṉcai puṉcai nattam nattappuṉcai ka
					<lb n="11" break="no"/>raippuṉcaiy taṟiIṟai taṭṭārppāṭṭam cekkiṟai Uḷppaṭ
					<lb n="12" break="no"/>ṭa <hi rend="grantha">sakala prāpti</hi>kaḷum Uṭpaṭa Iṉṉāḷmutal poṉparap
					<lb n="13" break="no"/>piṉāṉcantikku tirunāmattukkāṇi Iṟaiyiliyāka tantom <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> Ippa 
					<lb n="14" break="no"/>ṭikku <hi rend="grantha">cantrā</hi>tittava<hi rend="grantha">t</hi> cellak kallilum cempilum veṭṭi
					<lb n="15" break="no"/>kkoḷḷavum coṉṉom <supplied reason="subaudible"><g ref="sym:bar" type="punctuation">.</g></supplied> Ippaṭi ceyteṉ Ivai tiruviṭai
					<lb n="16" break="no"/>marutuṭaiyāṉ Eḻuttu <supplied reason="subaudible"><g ref="sym:bar" type="punctuation">.</g></supplied> Ivai tuḷai<surplus>p</surplus><hi rend="grantha">bramā</hi>rāyaṉ Eḻuttu I⌈
					<lb n="17" break="no"/>vai kulottuṅkaveḷār Eḻuttu <supplied reason="subaudible"><g ref="sym:bar" type="punctuation">.</g></supplied> Ivai Iḷaiyaperumāḷ Eḻuttu <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied>
				</p>
				
