			<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
				
				<p>
					<lb n="1"/><hi rend="grantha">svasti śrī</hi> <g type="pc">.</g> cakalapuvaṉaccakkaravattikaḷ <hi rend="grantha">śrī</hi>kopperuñciṅ
					<lb n="2" break="no"/>katevaṟku yāṇṭu <num value="16"><g type="numeral">10</g> 6</num><g type="dash"/>Āvatu Irā<hi rend="grantha">jā</hi>tirācavaḷanāṭṭu tirumuṉaip
					<lb n="3" break="no"/>pāṭi kiḻāmurnāṭṭu Ātirācamaṅkaliyapurattu Uṭaiyār tiruviraṭ
					<lb n="4" break="no"/>ṭāṉamuṭaiya ṉāyaṉāṟku paṉaiyūrnāṭṭu viḻuppuram piramatecamāna
					<lb n="5"/><hi rend="grantha">ja</hi>ṉanātaccaruppetimaṅkalattuk kāṇiUṭaiya colaikkoṉ makaṉ
					<lb n="6"/>Aruḷāḷaṉ tiyākaviṉotaṉeṉ Iṉṉāyanāṟku tirinuntāviḷakku Oṉ
					<lb n="7" break="no"/>ṟukku Ivāṇṭaip paṅkuṉimātam<surplus>p</surplus> piṟanta patiṉāṟāntiyati nāḷmutal nā
					<lb n="8" break="no"/>ṉ viṭṭa pacu <num value="32">3 <g type="numeral">10</g> 2</num><g type="dash"/>m I<hi rend="grantha">ṣa</hi>pam 1<g type="dash"/>m kaikkoṇṭu tirinuntāviḷakkukku
					<lb n="9"/>Atikaināyakaṉ ṉāḻiyāle ṉāḷ 1<g type="dash"/>kku Uḻakku ney tirumaṭaippa
					<lb n="10" break="no"/>ḷḷip paṇṭārattu cantirātittavarai Aḷakkakkaṭavatākak kaikkoṇṭom I<unclear>v</unclear>ūr maṉṟāṭikkuṭimakkaḷil curakkoṉ caṅkaṉum perāyiramuṭaiyāṉum Ivviruvom <supplied reason="subaudible"><g type="danda">.</g></supplied> Itu paṉmā<hi rend="grantha">he</hi>cura ra<hi rend="grantha"><unclear>kṣai</unclear></hi> <supplied reason="subaudible"><g type="ddanda">.</g></supplied>
				</p>
				
