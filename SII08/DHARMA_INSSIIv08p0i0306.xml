	<text xml:space="preserve">
		<body>
			
			<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
				
				<p>
					<lb n="1"/><hi rend="grantha">svasti śrī</hi> <supplied reason="subaudible"><g type="ddanda">.</g></supplied> tirumaṉṉi vaḷara Irunilamaṭantai
					<lb n="2" break="no"/>yum poṟceyappāvaiyum cīrttaṉicce
					<lb n="3" break="no"/>lviyum taṉ perunteviyarāki Iṉpuṟa neṭu
					<lb n="4" break="no"/>tiya<unclear>ru</unclear>ḻiyuḷ Iṭaituṟaināṭum tuṭarvaṉaveli
					<lb n="5" break="no"/>p paṭar vaṉavāciyum cuḷḷicūḻmatiṭ <gap reason="lost" quantity="2" unit="character"/> 
					<lb n="6"/><gap reason="lost" quantity="5" unit="character"/> kkaiyum naṇṇal karumuraṇ maṇṇai
					<lb n="7" break="no"/>kkaṭakkamum porukaṭaliḻattaraicartam muṭiyu <gap reason="lost" quantity="1" unit="character"/> 
					<lb n="8"/>Āṅkavar teviya roṅkeḻil muṭiyu<supplied reason="omitted">m</supplied> muṉṉava
					<lb n="9" break="no"/>rpakkaṟ ṟeṉṉavaṉ vaitta cuntaramuṭiyum I
					<lb n="10" break="no"/>n=ti raṉāramum teṇṭirai yiḻamaṇṭala muḻuva
					<lb n="11" break="no"/>tum Eṟipaṭaik keraḷaṉ muṟaimaiyil cūṭuṅ
					<lb n="12"/>kulataṉamākiya palarpukar muṭi<unclear>yu</unclear>ñ ceṅkatir
					<lb n="13" break="no"/>mālaiyuñ caṅkatirvelait tolperuṅkā
					<lb n="14" break="no"/>valp palapaḻantivuṉ ceruviṟṟiṉavil Iru
					<lb n="15" break="no"/>pattorukāl Araicuka<unclear>ḷai</unclear>k kaṭṭa paracurāmaṉ
					<lb n="16"/>velvaruñ cāṉti<unclear>mai</unclear>ṟṟivaraṇ karuti Irutti
					<lb n="17" break="no"/>ya cempoṟ ṟiruttaku muṭiyum payaṅkoṭu pa
					<lb n="18" break="no"/>ḻimika muyaṅkiyil mutukiṭṭoḷitta <hi rend="grantha">ja</hi><supplied reason="omitted">ya</supplied>ciṅka
					<lb n="19" break="no"/>ṉ Aḷapperumpuka<surplus>ḻ</surplus>ḻoṭu piṭi Iraṭṭapāṭi E
					<lb n="20" break="no"/>ḻaraiilakkamum navanetik kulamte malai
					<lb n="21" break="no"/>kaḷum vikkiramavirac cakkara<supplied reason="omitted">k</supplied>koṭṭamum mutirpaṭava
					<lb n="22" break="no"/>lla maturamaṇṭalamuṅ <choice><sic>kāviṭai</sic><corr>kulapperu</corr></choice>
				</p>
				
