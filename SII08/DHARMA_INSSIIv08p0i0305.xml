			<div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">
				
				<p>
					<lb n="1"/>valaṅko ḷāḻivarai yāḻi naṭātti Irucuṭa
					<lb n="2" break="no"/>raḷavu morukuṭai niḻaṟṟa vira<hi rend="grantha">siṁhāsa</hi><supplied reason="omitted">na</supplied><unclear>t</unclear>tu
					<lb n="3"/>mukkokkiḻāṉaṭikaḷoṭum viṟṟirun=taḷiya
					<lb n="4"/>kopparakecaripa<hi rend="grantha">nma</hi>rāṉa <hi rend="grantha">tri</hi>puvanaccakkaravart
					<lb n="5" break="no"/>tikaḷ <hi rend="grantha">śrī</hi>vikkiramacoḻatevarkku yāṇṭu 4<g ref="sym:dash" type="punctuation">.</g>
					<lb n="6" break="no"/>vatu kaṅkaikoṇṭacoḻavaḷanāṭṭut tiru
					<lb n="7" break="no"/>muṉaippāṭik kiḻāṉmurnāṭṭu <hi rend="grantha">brahma</hi>teyam
					<lb n="8"/>ciṟuputtūr peruṅkuṟi<hi rend="grantha">sabhai</hi>yom Eṅka
					<lb n="9" break="no"/>ḷūr tirumāliruñcolai yāḻvār koyilile
					<lb n="10"/>kūṭṭaṅ kuṟaivaṟak kūṭiyirun=tu <hi rend="grantha"><unclear>ja</unclear></hi>va⌈
					<lb n="11" break="no"/><hi rend="grantha">st</hi>ai paṇṇinapaṭi Eṅkaḷūrkku viniyokak ku
					<lb n="12" break="no"/>ṟaippaṭutta <hi rend="grantha">sabhā</hi>viniyokattukku veṟu <hi rend="grantha"><supplied reason="omitted">dra</supplied></hi>
					<lb n="13" break="no"/><hi rend="grantha">vya</hi>millāmaiyāl Eṅkaḷūrile ciṟitu nilam
					<lb n="14"/>viṟṟākilum Aṭutta viniyoka<unclear>mu</unclear>m viniyokikka
					<lb n="15"/>veṇṭiṉamaiyāl Iṉṉāṭṭu Ātirā<hi rend="grantha">ja</hi>maṅka
					<lb n="16" break="no"/>lyapurattu <hi rend="grantha">śrī</hi>kovin=taviṇṇakaril niṉṟaruḷiṉa pa
					<lb n="17" break="no"/>rama<hi rend="grantha">svā</hi>mikaḷukkuc ciṟṟāmuruṭaiyāṉ kūttaṉ
					<lb n="18"/>paḷḷikoṇṭāṉāṉa viḻiñattaraiyan tirumantira
					<lb n="19" break="no"/>ppoṉakattu<unclear>k</unclear>ku vaitta nilattukku <unclear>nā</unclear>ṅkaḷ
					<lb n="20"/><hi rend="grantha">sabhai</hi>vilaiyāka viṟṟu Iṟaiyili ceytukuṭutta 
					<lb n="21"/>nilamāvatu I<supplied reason="omitted">v</supplied>vūrt teṉkaḻani yiraṭṭaikkaṇ
					<lb n="22" break="no"/>ṇāṟṟukku melainārācattukku mekkum teṉpā
					<lb n="23" break="no"/>ṟkellai kaṇṇikkālukku vaṭakkum melpā
					<lb n="24" break="no"/>ṟkellai Aḻiñciṟkaṇṇāṟṟukkuk kiḻakkum vaṭapā
					<lb n="25" break="no"/>ṟkellai Aruḷāḷavāykkālukku teṟkumāka I<unclear>ṉṉāṉ</unclear>
					<lb n="26" break="no"/>kellaikku muṭ<surplus>p</surplus>paṭṭa nilam patiṉālaṭikkolāl
					<lb n="27"/>Oruveli Iṉṉila
				</p>
				
