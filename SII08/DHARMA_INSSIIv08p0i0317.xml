				<p>
					<lb n="1"/><g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g> <hi rend="grantha">svasti śrī</hi> <supplied reason="subaudible"><g ref="sym:doubleBar" type="punctuation">.</g></supplied> tiripuvaṉaccakkaravattikaḷ <hi rend="grantha">śrī</hi>kulottuṅkacoḻa<hi rend="grantha">de</hi>vaṟku yāṇṭu <num value="29">2 <g type="numeral">10</g> 9</num><g ref="sym:dash" type="punctuation">.</g>vatu Irā<hi rend="grantha">ja</hi> <gap reason="lost" quantity="4" unit="character"/> 
					<lb n="2"/>ṉāṭṭut tirumuṉaippāṭik kiḻāmurṉāṭṭu Ātirā<hi rend="grantha">ja</hi>maṅkalliyapurattu Uṭaiyār tiruviraṭ <gap reason="lost" quantity="5" unit="character"/> 
					<lb n="3"/>ṭaiya ṉāyaṉāṟku kūṭa lacalakulottumaṉ Eḻicaimokapperumāḷ maṇavāṇapperumāḷāṉa va <gap reason="lost" quantity="4" unit="character"/> 
					<lb n="4"/>ṇṭaperumāḷāṉa kāṭavarāyar nāyaṉāṟku ĀṭiAruḷavum ce<supplied reason="omitted">l</supplied>la pālamutukkum cantirāti<supplied reason="omitted">t</supplied>tava <seg type="aksara"><seg type="component" subtype="body"><gap reason="lost" quantity="1" unit="component"/></seg>ai</seg> <gap reason="lost" quantity="4" unit="character"/> 
					<lb n="5"/>tāka viṭṭa pacu Aimpatu <supplied reason="subaudible"><g ref="sym:bar" type="punctuation">.</g></supplied> Itu <hi rend="grantha">pa</hi>ṉmā<hi rend="grantha">heśva</hi>ra <hi rend="grantha">rakṣai</hi>
				</p>
				
